                )

            # 检查是否是PyTorch Lightning checkpoint（包含state_dict而不是weight）
            if gpt_checkpoint and "state_dict" in gpt_checkpoint and "weight" not in gpt_checkpoint:
                logger.info("[模型转换] 检测到PyTorch Lightning checkpoint，转换为精简格式...")
                # 提取weight和config
                from collections import OrderedDict
                converted_gpt = OrderedDict()
                converted_gpt["weight"] = OrderedDict()
                
                # 从state_dict中提取模型权重（去掉"model."前缀）
                state_dict = gpt_checkpoint["state_dict"]
                for key, value in state_dict.items():
                    # PyTorch Lightning会在key前加上"model."前缀，需要去掉
                    if key.startswith("model."):
                        new_key = key[6:]  # 去掉"model."前缀
                    else:
                        new_key = key
                    # 转换为half精度以匹配官方格式
                    if value.dtype == torch.float32:
                        converted_gpt["weight"][new_key] = value.half()
                    else:
                        converted_gpt["weight"][new_key] = value
                
                # 提取config（从hyper_parameters中）
                if "hyper_parameters" in gpt_checkpoint:
                    converted_gpt["config"] = gpt_checkpoint["hyper_parameters"]
                else:
                    # 如果没有hyper_parameters，尝试从其他地方获取config
                    logger.warning("[模型转换] 未找到config，使用默认配置")
                    converted_gpt["config"] = {}
                
                # 添加info
                epoch = gpt_checkpoint.get("epoch", 0)
                converted_gpt["info"] = f"GPT-e{int(epoch) + 1}"
                
                # 保存转换后的模型（覆盖原文件）
                from GPT_SoVITS.process_ckpt import my_save
                my_save(converted_gpt, str(gpt_path))
                logger.info(f"[模型转换] GPT模型已转换为精简格式: {gpt_path}")
                
                # 更新文件大小信息
                new_size = gpt_path.stat().st_size / 1024 / 1024
                logger.info(f"[模型转换] 转换后文件大小: {new_size:.2f} MB")
        except Exception as e:
            logger.warning(f"[模型转换] GPT模型转换失败: {str(e)}，将使用原始格式")
            import traceback
            logger.warning(traceback.format_exc())
        
        # 检查SoVITS模型格式，如果是完整checkpoint，转换为精简格式
        try:
            # 尝试加载模型，如果文件损坏或格式不对，跳过转换
            sovits_checkpoint = None
            try:
                sovits_checkpoint = torch.load(str(sovits_path), map_location="cpu", weights_only=False)
            except Exception as load_error:
                logger.warning(
                    f"[模型转换] SoVITS模型文件加载失败（可能已为精简格式或文件损坏）: {str(load_error)}，跳过转换"
                )

            # 检查是否是完整checkpoint（包含model而不是weight）
            if sovits_checkpoint and "model" in sovits_checkpoint and "weight" not in sovits_checkpoint:
                logger.info("[模型转换] 检测到完整SoVITS checkpoint，转换为精简格式...")
                # 提取weight和config
                from collections import OrderedDict
                converted_sovits = OrderedDict()
                converted_sovits["weight"] = OrderedDict()
                
                # 从model中提取模型权重
                model_state = sovits_checkpoint["model"]
                for key, value in model_state.items():
                    # 跳过enc_q（量化器），与官方格式保持一致
                    if "enc_q" in key:
                        continue
                    # 转换为half精度以匹配官方格式
                    if value.dtype == torch.float32:
                        converted_sovits["weight"][key] = value.half()
                    else:
                        converted_sovits["weight"][key] = value
                
