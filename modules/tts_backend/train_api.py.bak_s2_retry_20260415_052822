                iteration = sovits_checkpoint.get("iteration", 0)
                epoch = sovits_checkpoint.get("epoch", 0)
                converted_sovits["info"] = f"{int(epoch)}epoch_{int(iteration)}iteration"
                
                # 保存转换后的模型（覆盖原文件）
                from GPT_SoVITS.process_ckpt import my_save2
                my_save2(converted_sovits, str(sovits_path), params.model_version)
                logger.info(f"[模型转换] SoVITS模型已转换为精简格式: {sovits_path}")
                
                # 更新文件大小信息
                new_size = sovits_path.stat().st_size / 1024 / 1024
                logger.info(f"[模型转换] 转换后文件大小: {new_size:.2f} MB")
        except Exception as e:
            logger.warning(f"[模型转换] SoVITS模型转换失败: {str(e)}，将使用原始格式")
            import traceback
            logger.warning(traceback.format_exc())
        
        train_tasks[task_id]["model_path"] = str(exp_dir)
        train_tasks[task_id]["gpt_path"] = str(gpt_path)
        train_tasks[task_id]["sovits_path"] = str(sovits_path)
        train_tasks[task_id]["version"] = params.model_version
        
        # 验证生成的模型文件
        # torch已在文件顶部导入，直接使用即可
        
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n{'='*60}\n")
            f.write(f"[模型验证] 开始验证训练生成的模型文件...\n")
            f.write(f"{'='*60}\n")
            
