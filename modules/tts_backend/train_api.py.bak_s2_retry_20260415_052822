                train_tasks[task_id]["ref_text"] = ref_text
                train_tasks[task_id]["ref_language"] = ref_language
                with open(log_path, "a", encoding="utf-8") as f:
                    f.write(f"\n参考音频已提取: {ref_audio_path}\n")
                    f.write(f"参考文本(稳态短提示): {ref_text}\n")
            else:
                logger.warning("未能从训练数据中提取参考音频和文本")
        except Exception as e:
            logger.warning(f"提取参考音频和文本失败: {str(e)}")
            import traceback
            logger.warning(traceback.format_exc())

        train_tasks[task_id]["progress"] = 96
        train_tasks[task_id]["message"] = "训练完成，查找模型文件..."
        
        # 优先在训练输出目录中查找模型文件（user_models下的实际训练输出）
        # 如果找不到，再回退到全局目录（用于预训练模型的快速体验）
        # exp_dir 已经是 output_path/processed，避免重复拼接 processed/processed
        s1_output_dir = exp_dir / f"logs_s1_{params.model_version}"
        s2_output_dir = exp_dir / f"logs_s2_{params.model_version}"
        
        gpt_path = None
