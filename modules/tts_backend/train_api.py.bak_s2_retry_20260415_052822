        located_semantic = _locate_prepare_output(exp_dir, "6-name2semantic", ".tsv") or (exp_dir / "6-name2semantic.tsv")
        check_items = [
            (f"2-name2text ({located_phoneme.name})", located_phoneme, "文件"),
            ("3-bert", exp_dir / "3-bert", "目录"),
            ("4-cnhubert", exp_dir / "4-cnhubert", "目录"),
            ("5-wav32k", exp_dir / "5-wav32k", "目录"),
            (f"6-name2semantic ({located_semantic.name})", located_semantic, "文件"),
        ]
        
        if "Pro" in version:
            check_items.append(("7-sv_cn", exp_dir / "7-sv_cn", "目录"))
        
        all_valid = True
        for name, path, path_type in check_items:
            if not path.exists():
                logf.write(f"❌ {name} ({path_type}): 不存在\n")
                all_valid = False
            elif path_type == "目录":
                files = list(path.glob("*"))
                if len(files) == 0:
                    logf.write(f"❌ {name} ({path_type}): 目录为空\n")
                    all_valid = False
                else:
                    total_size = sum(f.stat().st_size for f in files if f.is_file())
                    logf.write(f"✅ {name} ({path_type}): {len(files)} 个文件, {total_size / 1024 / 1024:.2f} MB\n")
            else:  # 文件
                size = path.stat().st_size
                if size == 0:
                    logf.write(f"❌ {name} ({path_type}): 文件为空\n")
                    all_valid = False
                else:
                    logf.write(f"✅ {name} ({path_type}): {size / 1024:.2f} KB\n")
        
        if all_valid:
            logf.write(f"\n✅ 所有预处理输出验证通过！\n")
        else:
            logf.write(f"\n⚠️ 部分预处理输出验证失败，但将继续训练（如果可能）\n")
        
        logf.write(f"{'='*60}\n")


def _build_s1_config(
    task_id: str,
    exp_name: str,
    exp_dir: Path,
    version: str,
    job_dir: Path,
    semantic_path: Path,
    phoneme_path: Path,
    batch_size: int = 8,
    epochs: int = 10,
    learning_rate: float = 1e-5,
    fast_mode: bool = False,
    dataset_sample_count: int = 0,
) -> Path:
    """构建S1 GPT训练配置"""
    config_file = "s1longer-v2.yaml" if version != "v1" else "s1longer.yaml"
    template = BASE_DIR / "GPT_SoVITS" / "configs" / config_file
    if not template.exists() and version != "v1":
        template = BASE_DIR / "GPT_SoVITS" / "configs" / "s1longer.yaml"
    
    config = yaml.safe_load(template.read_text(encoding="utf-8"))
    
    train_block = config.setdefault("train", {})
    train_block["exp_name"] = exp_name
    
    # 检测是否有GPU可用
    has_gpu = torch.cuda.is_available()
    
    # 强制使用官方参数：S1使用15轮，每5轮保存一次，batch_size=8，precision="16-mixed"
    # 不进行任何动态调整，确保与官方参数完全一致
    if fast_mode:
        if has_gpu:
            # GPU快速模式：更少的epochs，但保持官方batch_size=8
            effective_epochs = max(3, min(epochs, 5))  # 快速模式最多5轮
            effective_batch_size = 8  # 强制使用官方值8
        else:
            # CPU快速模式：最少epochs，但保持官方batch_size=8（如果OOM则报错）
            effective_epochs = max(3, min(epochs, 5))
            effective_batch_size = 8  # 强制使用官方值8
        # 快速模式：如果epochs>=5，每5轮保存；否则只在最后保存
        train_block["save_every_n_epoch"] = 5 if effective_epochs >= 5 else effective_epochs
        train_block["if_save_every_weights"] = True
    else:
        # 正常训练模式：强制使用官方参数
        if has_gpu:
            # GPU训练：强制使用官方参数
            effective_epochs = 15  # 官方值：15轮
            effective_batch_size = 8  # 官方值：batch_size=8（不根据数据集大小调整）
        else:
            # CPU训练：也使用官方参数（如果OOM则报错，不自动降级）
            effective_epochs = 15  # 官方值：15轮
            effective_batch_size = 8  # 官方值：batch_size=8
        # 正常模式：每5轮保存一次（官方值）
        train_block["save_every_n_epoch"] = 5  # 官方值：每5轮保存一次
        train_block["if_save_every_weights"] = True
    
    # 强制使用官方参数，忽略传入的参数（确保与官网完全一致）
    train_block["batch_size"] = 8  # 官方值：强制使用8
    train_block["epochs"] = 15 if not fast_mode else max(3, min(epochs, 5))  # 官方值：正常模式15轮，快速模式3-5轮

    tiny_dataset = int(dataset_sample_count or 0) > 0 and int(dataset_sample_count or 0) <= TINY_DATASET_THRESHOLD
    if tiny_dataset and _env_flag("TRAIN_TINY_SAVE_LAST_ONLY", ENTERPRISE_OPT_DEFAULT_ON):
        # 小数据集训练时仅保留最终checkpoint，减少保存开销。
        train_block["save_every_n_epoch"] = max(1, int(train_block["epochs"]))
        train_block["if_save_latest"] = True
        logger.info(
            f"[S1配置] tiny_dataset保存优化已启用: sample_count={dataset_sample_count}, "
            f"save_every_n_epoch={train_block['save_every_n_epoch']}"
        )
    
    # 记录实际使用的参数（用于调试）
    logger.info(f"[S1配置] 强制使用官方参数: batch_size=8, epochs={train_block['epochs']} (传入参数: batch_size={batch_size}, epochs={epochs}, fast_mode={fast_mode})")
    
    # 设置学习率：始终覆盖模板中的默认值，确保实际使用的是传入的learning_rate
    # 官方推荐 S1 学习率为 1e-5，这里默认也是 1e-5，如需调整可通过 TrainParams 传入
    if "lr_init" in train_block:
        train_block["lr_init"] = learning_rate
    if "learning_rate" in train_block:
        train_block["learning_rate"] = learning_rate
    logger.info(f"[S1配置] 设置学习率: {learning_rate}")
    
    # 优化数据加载（CPU训练时减少workers）
    data_block = config.setdefault("data", {})
    if not has_gpu:
        data_block["num_workers"] = 0  # CPU训练时禁用多进程，避免开销
        # CPU训练时禁用precision混合精度，使用fp32
        if train_block.get("precision") == "16-mixed":
            train_block["precision"] = "32-true"  # CPU不支持16位，使用32位
    else:
        # GPU训练：优化数据加载性能
        # 增加num_workers到8（但不超过CPU核心数），提升数据加载速度
        cpu_count = os.cpu_count() or 4
        data_block["num_workers"] = min(8, cpu_count)
        # 启用pin_memory加速CPU到GPU数据传输
        data_block["pin_memory"] = True
        # 启用persistent_workers避免每个epoch重新创建worker
        data_block["persistent_workers"] = True
        # 设置prefetch_factor，每个worker预取更多数据
        data_block["prefetch_factor"] = 4
        # GPU训练时强制使用16-mixed精度（官方值）
        train_block["precision"] = "16-mixed"  # 官方值：强制使用FP16混合精度
        # batch_size已经是8，不需要梯度累积
    
    # 启用验证以找到最佳模型（根据文档，验证是必要的）
    # 优化验证频率：每3个epoch验证一次，减少验证时间
    train_block["val_check_interval"] = None  # 禁用每个epoch内的验证
    train_block["check_val_every_n_epoch"] = 3  # 每3个epoch验证一次（减少验证时间）
    
    gpt_weight_dir = _get_versioned_path("GPT_weight_version2root", version, "GPT_weights_v2Pro")
    train_block["half_weights_save_dir"] = str(gpt_weight_dir)
    train_block["if_save_latest"] = True
    # 确保保存精简格式（weight + config + info），而不是完整的PyTorch Lightning checkpoint
    train_block["if_save_every_weights"] = True  # 必须为True，才能保存精简格式
    
    pretrained_gpt = _get_versioned_path("pretrained_gpt_name", version,
                                         getattr(global_config, "pretrained_gpt_path", config.get("pretrained_s1") or _default_pretrained_gpt_path(version)) if global_config else (config.get("pretrained_s1") or _default_pretrained_gpt_path(version)))
    config["pretrained_s1"] = str(pretrained_gpt)
    config["train_semantic_path"] = str(semantic_path)
    config["train_phoneme_path"] = str(phoneme_path)
    config["output_dir"] = str(exp_dir / f"logs_s1_{version}")
    
    tmp_path = job_dir / "tmp_s1.yaml"
    tmp_path.write_text(yaml.safe_dump(config, allow_unicode=True), encoding="utf-8")
    
    return tmp_path


def _build_s2_config(
    exp_name: str,
    exp_dir: Path,
    version: str,
    job_dir: Path,
    target_batch_size: int = 1,
    max_segment_size: int = 20480,  # 官方值：20480
    max_epochs: int = 8,  # 官方值：8轮
    fast_mode: bool = False,  # 快速训练模式
    gpu_numbers: str = "0",  # 与官网一致，写入 train.gpu_numbers
    dataset_sample_count: int = 0,
) -> Path:
    """构建S2 SoVITS训练配置"""
    if version in {"v2Pro", "v2ProPlus"}:
        config_file = "s2v2Pro.json"
    else:
        config_file = "s2.json"
    template = BASE_DIR / "GPT_SoVITS" / "configs" / config_file
    if not template.exists() and version in {"v2Pro", "v2ProPlus"}:
        template = BASE_DIR / "GPT_SoVITS" / "configs" / "s2.json"
    
    data = json.loads(template.read_text(encoding="utf-8"))
    
    # name 字段应该在配置文件的顶层，而不是 train 块中（与官方 auto_train_infer.py 一致）
    data["name"] = exp_name
    
    train_block = data.setdefault("train", {})
    # 写入 gpu_numbers，保持与官方 webui/auto_train_infer 的配置一致
    # 供 s2_train.py 中 hps.train.gpu_numbers 使用
    train_block["gpu_numbers"] = str(gpu_numbers)
    # 强制使用官方参数：batch_size=8，不进行任何动态调整
    train_block["batch_size"] = 8  # 官方值：强制使用8
    logger.info(f"[S2配置] 强制使用官方参数: batch_size=8 (传入参数: target_batch_size={target_batch_size}, max_epochs={max_epochs}, fast_mode={fast_mode})")
    
    # 强制使用官方参数：S2使用8轮，每4轮保存一次，batch_size=8，fp16_run=True
    # 不进行任何动态调整，确保与官方参数完全一致
    if fast_mode:
        # 快速模式：S2训练3-5轮
        adjusted_max_epochs = min(max_epochs, 5)
    else:
        # 正常模式：强制使用官方值8轮
        adjusted_max_epochs = 8  # 官方值：强制使用8轮
    
    train_block["epochs"] = adjusted_max_epochs
    total_epochs = int(train_block["epochs"])
    logger.info(f"[S2配置] 强制使用官方参数: epochs={total_epochs} (传入参数: max_epochs={max_epochs}, fast_mode={fast_mode})")
    
    # 添加/覆盖保存相关配置字段（s2_train.py需要这些字段）
    # 官方值：每4轮保存一次
    if fast_mode:
        # 快速模式：如果epochs>=4，每4轮保存；否则只在最后保存
        train_block["save_every_epoch"] = 4 if total_epochs >= 4 else total_epochs
        train_block["if_save_latest"] = 1  # 保存最新模型（覆盖式）
        train_block["if_save_every_weights"] = True  # 必须为True，才能保存精简格式（weight + config + info）
    else:
        # 正常模式：每4轮保存一次（官方值）
        train_block["save_every_epoch"] = 4  # 官方值：每4轮保存一次
        train_block["if_save_latest"] = 1  # 保存最新模型（覆盖式）
        train_block["if_save_every_weights"] = True  # 必须为True，才能保存精简格式（weight + config + info）
    
    tiny_dataset = int(dataset_sample_count or 0) > 0 and int(dataset_sample_count or 0) <= TINY_DATASET_THRESHOLD
    if tiny_dataset and _env_flag("TRAIN_TINY_SAVE_LAST_ONLY", ENTERPRISE_OPT_DEFAULT_ON):
        train_block["save_every_epoch"] = max(1, total_epochs)
        train_block["if_save_latest"] = 1
        logger.info(
            f"[S2配置] tiny_dataset保存优化已启用: sample_count={dataset_sample_count}, "
            f"save_every_epoch={train_block['save_every_epoch']}"
        )

    data_block = data.setdefault("data", {})
    # 确保exp_dir指向processed目录（包含2-name2text.txt等文件）
    data_block["exp_dir"] = str(exp_dir)
    # 优化S2数据加载性能（如果使用PyTorch DataLoader）
    # 注意：S2训练可能使用自定义数据加载，这些参数可能不会直接生效
    # 但设置它们可以确保如果训练脚本支持，就会使用这些优化
    if torch.cuda.is_available():
        # 这些参数会在s2_train.py中通过环境变量或配置传递
        # 如果训练脚本支持DataLoader，这些参数会生效
        pass  # S2的数据加载在训练脚本中控制，通过环境变量优化
    hop_length = int(data_block.get("hop_length", 640) or 640)
    # 官方值：segment_size=20480
    official_segment_size = 20480  # 官方值
    segment_size = int(train_block.get("segment_size", official_segment_size) or official_segment_size)
    # 使用官方值，但确保是hop_length的倍数
    segment_size = official_segment_size
    if segment_size % hop_length != 0:
        segment_size = segment_size - (segment_size % hop_length)
    segment_size = max(hop_length, segment_size)
    train_block["segment_size"] = segment_size
    
    pretrained_s2g = _get_versioned_path("pretrained_sovits_name", version, getattr(global_config, "pretrained_sovits_path", train_block.get("pretrained_s2G") or _default_pretrained_s2g_path(version)) if global_config else (train_block.get("pretrained_s2G") or _default_pretrained_s2g_path(version)))
    train_block["pretrained_s2G"] = str(pretrained_s2g)
    
    # 尝试获取 s2D 路径（v2Pro 可能需要）
    if "Pro" in version:
        try:
            s2d_attr = getattr(global_config, "pretrained_sovits_d_path", None) if global_config else None
            s2d_path = None
            if isinstance(s2d_attr, dict):
                s2d_path = s2d_attr.get(version)
            elif isinstance(s2d_attr, str):
                s2d_path = s2d_attr
            if not s2d_path and train_block.get("pretrained_s2G"):
                # 尝试从 s2G 路径推断 s2D 路径
                s2g_path = _resolve_path(train_block["pretrained_s2G"])
                if "s2G" in s2g_path.name:
                    s2d_candidate = s2g_path.with_name(s2g_path.name.replace("s2G", "s2D", 1))
                    if s2d_candidate.exists():
                        s2d_path = str(s2d_candidate)
            if s2d_path:
                train_block["pretrained_s2D"] = str(_resolve_path(s2d_path))
        except Exception:
            pass  # s2D 不是必需的
    data["s2_ckpt_dir"] = str(exp_dir / f"logs_s2_{version}")
    sovits_weight_dir = _get_versioned_path("SoVITS_weight_version2root", version, "SoVITS_weights_v2Pro")
    data["save_weight_dir"] = str(sovits_weight_dir)
    data.setdefault("model", {})["version"] = version
    data["version"] = version
    
    # 强制设置fp16_run=True（官方值）
    train_block["fp16_run"] = True  # 官方值：强制使用FP16训练
    
    tmp_path = job_dir / "tmp_s2.json"
    tmp_path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    return tmp_path


