            else:
                # 如果找不到同名生成器权重，尝试全局选择最新的生成器权重（排除 D_* 判别器）。
                all_pths = list(sovits_weight_dir.glob("*.pth"))
                backup_best = _pick_latest_sovits_generator_checkpoint(all_pths)
