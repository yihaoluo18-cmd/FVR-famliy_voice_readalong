        if sovits_path is None:
            sovits_weight_dir = _get_versioned_path("SoVITS_weight_version2root", params.model_version, "SoVITS_weights_v2Pro")
            named_candidates = list(sovits_weight_dir.glob(f"{exp_name}*.pth"))
