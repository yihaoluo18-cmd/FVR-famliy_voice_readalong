def _find_free_gpu(min_free_memory_mb: int = 4096) -> Optional[int]:
    """查找空闲的GPU（单卡，保持向后兼容）
    
    Args:
        min_free_memory_mb: 最小空闲内存（MB），默认4GB
    
    Returns:
        可用的GPU索引，如果没有找到则返回None
    """
    gpus = _find_free_gpus(min_free_memory_mb=min_free_memory_mb, num_gpus=1)
    return gpus[0] if gpus else None


def _find_free_gpus(min_free_memory_mb: int = 4096, num_gpus: int = 4) -> List[int]:
    """查找多个空闲的GPU
    
    Args:
        min_free_memory_mb: 每个GPU的最小空闲内存（MB），默认4GB
        num_gpus: 需要查找的GPU数量，默认4张
    
    Returns:
        可用的GPU索引列表，按空闲内存从多到少排序
    """
    if not torch.cuda.is_available():
        return [0] if num_gpus >= 1 else []
    
    try:
        import subprocess
        result = subprocess.run(
            ['nvidia-smi', '--query-gpu=index,memory.used,memory.total', '--format=csv,noheader,nounits'],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode != 0:
            # 如果nvidia-smi失败，返回默认GPU列表
            return list(range(min(num_gpus, torch.cuda.device_count())))
        
        free_gpus = []
        for line in result.stdout.strip().split('\n'):
            if line:
                parts = line.split(', ')
                if len(parts) >= 3:
                    gpu_idx = int(parts[0])
                    mem_used = int(parts[1])
                    mem_total = int(parts[2])
                    mem_free = mem_total - mem_used
                    if mem_free >= min_free_memory_mb:
                        free_gpus.append((gpu_idx, mem_free))
        
        if free_gpus:
            # 按空闲内存从多到少排序
            free_gpus.sort(key=lambda x: x[1], reverse=True)
            # 返回前 num_gpus 个GPU
            selected_gpus = [gpu[0] for gpu in free_gpus[:num_gpus]]
            return selected_gpus
        else:
            # 如果没有足够的空闲GPU，选择使用最少的
            all_gpus = []
            for line in result.stdout.strip().split('\n'):
                if line:
                    parts = line.split(', ')
                    if len(parts) >= 3:
                        gpu_idx = int(parts[0])
                        mem_used = int(parts[1])
                        all_gpus.append((gpu_idx, mem_used))
            if all_gpus:
                all_gpus.sort(key=lambda x: x[1])
                # 返回使用最少的 num_gpus 个GPU
                selected_gpus = [gpu[0] for gpu in all_gpus[:num_gpus]]
                return selected_gpus
            # 如果都没有，返回前 num_gpus 个GPU（即使显存不足）
            total_gpus = torch.cuda.device_count()
            return list(range(min(num_gpus, total_gpus)))
    except Exception as e:
        print(f"查找空闲GPU失败: {e}，使用默认GPU列表")
        total_gpus = torch.cuda.device_count() if torch.cuda.is_available() else 1
        return list(range(min(num_gpus, total_gpus)))


def _run_command(
    task_id: str,
    description: str,
    command: List[str],
    log_file: str,
    env_overrides: Optional[Dict[str, str]] = None,
):
    """执行命令并记录日志，支持进度更新"""
    env = os.environ.copy()
    if env_overrides:
        env.update({k: str(v) for k, v in env_overrides.items() if v is not None})
    
    # 自动选择空闲GPU（如果使用CUDA且未在环境变量中指定）
    # 多卡训练：S2训练使用4张卡，S1训练使用2张卡（GPT模型较小，多卡收益有限）
    if torch.cuda.is_available() and "CUDA_VISIBLE_DEVICES" not in env:
        # 根据任务类型选择不同的最小空闲显存要求和GPU数量
        if "GPT" in description or "s1" in description.lower():
            # S1 GPT训练：使用2张卡，每张至少8GB空闲
            min_memory_mb = 8192
            num_gpus = 2
        else:
            # S2 SoVITS训练：使用4张卡，每张至少4GB空闲
            min_memory_mb = 4096
            num_gpus = 4
        
        free_gpus = _find_free_gpus(min_free_memory_mb=min_memory_mb, num_gpus=num_gpus)
        if free_gpus:
            # 将GPU列表转换为环境变量格式（用逗号分隔）
            gpu_str = ",".join(map(str, free_gpus))
            env["CUDA_VISIBLE_DEVICES"] = gpu_str
            env["_CUDA_VISIBLE_DEVICES"] = gpu_str  # 兼容某些脚本
            # 只在日志文件中记录，不在控制台输出（避免干扰）
            with open(log_file, "a", encoding="utf-8") as logf:
                logf.write(f"[GPU选择] {description} 自动选择 {len(free_gpus)} 张GPU: {gpu_str} (每张至少需要 {min_memory_mb}MB 空闲显存)\n")
        else:
            with open(log_file, "a", encoding="utf-8") as logf:
                logf.write(f"[GPU警告] 未找到足够的空闲GPU（至少需要 {num_gpus} 张，每张 {min_memory_mb}MB），将使用默认GPU\n")
    
    # 确保Python路径包含项目根目录
    python_path = env.get("PYTHONPATH", "")
    project_paths = [
        str(BASE_DIR),
        str(BASE_DIR / "GPT_SoVITS"),
    ]

    # Prefer vendored pure-python dependencies (offline-safe).
    third_party_dir = BASE_DIR / "third_party"
    if third_party_dir.exists():
        project_paths.append(str(third_party_dir))

    if python_path:
        project_paths.append(python_path)
    env["PYTHONPATH"] = os.pathsep.join(project_paths)
    
    log_file_path = Path(log_file)
    log_file_path.parent.mkdir(parents=True, exist_ok=True)
    
    # 在执行命令前更新消息
    if task_id in train_tasks:
        # 根据描述更新消息
        if "step1" in description.lower() or "2-name2text" in description.lower():
            train_tasks[task_id]["message"] = "正在提取文本与BERT特征..."
        elif "step2" in description.lower() or "hubert" in description.lower():
            train_tasks[task_id]["message"] = "正在提取HuBERT特征（这可能需要一些时间）..."
        elif "step2b" in description.lower() or "sv" in description.lower():
            train_tasks[task_id]["message"] = "正在提取说话人特征..."
        elif "step3" in description.lower() or "semantic" in description.lower():
            train_tasks[task_id]["message"] = "正在生成语义token..."
        else:
            train_tasks[task_id]["message"] = f"正在执行: {description}"
    
    # 捕获错误输出
    error_output = []
    
    with open(log_file_path, "a", encoding="utf-8") as log_fp:
        log_fp.write(f"\n[{datetime.now().isoformat()}] {description}\n")
        log_fp.write(f"命令: {' '.join(command)}\n")
        log_fp.write(f"PYTHONPATH: {env['PYTHONPATH']}\n")
        # 记录GPU信息
        if torch.cuda.is_available():
            cuda_visible = env.get("CUDA_VISIBLE_DEVICES", "未设置")
            log_fp.write(f"CUDA_VISIBLE_DEVICES: {cuda_visible}\n")
            if cuda_visible != "未设置":
                try:
                    gpu_idx = int(cuda_visible)
                    log_fp.write(f"使用GPU: {gpu_idx} ({torch.cuda.get_device_name(gpu_idx)})\n")
                except:
                    pass
        else:
            log_fp.write(f"GPU可用: 否 (使用CPU，速度较慢)\n")
        log_fp.flush()
        
        process = subprocess.Popen(
            command,
            cwd=str(BASE_DIR),
            env=env,
            stdout=log_fp,
            stderr=subprocess.STDOUT,  # 将stderr重定向到stdout
            shell=False,
        )
        
        # 注册进程，用于API关闭时清理
        active_processes[task_id] = process
        
        # 非阻塞等待，定期检查进程状态和日志
        import re
        last_log_size = 0
        no_progress_count = 0
        max_no_progress = 600  # 10分钟没有进度更新则认为可能卡住（HuBERT处理较慢）
        last_progress_time = time.time()
        process_start_time = time.time()
        max_process_time = 3600  # 1小时超时（单个步骤最多1小时）
        
        while True:
            return_code = process.poll()
            if return_code is not None:
                # 进程已结束，从注册表中移除
                active_processes.pop(task_id, None)
                break
            
            # 检查进程是否超时
            elapsed_time = time.time() - process_start_time
            if elapsed_time > max_process_time:
                logger.warning(f"{description} 执行超时（{elapsed_time/60:.1f}分钟），终止进程")
                try:
                    process.terminate()
                    time.sleep(2)
                    if process.poll() is None:
                        process.kill()
                except:
                    pass
                return_code = -1
                active_processes.pop(task_id, None)
                break
            
            # 检查进程是否还在运行（防止进程变成僵尸进程）
            try:
                if process.poll() is None:
                    # 进程还在运行，继续等待
                    pass
            except:
                # 进程可能已经结束
                active_processes.pop(task_id, None)
                break
            
            # 检查日志文件是否有更新（表示进程还在运行）
            try:
                current_log_size = log_file_path.stat().st_size
                if current_log_size > last_log_size:
                    last_log_size = current_log_size
                    no_progress_count = 0
                    last_progress_time = time.time()
                    
                    # 尝试从日志中提取进度信息（每10次检查一次，避免频繁读取）
                    if task_id in train_tasks and no_progress_count % 10 == 0:
                        try:
                            # 只读取最后30行，避免读取整个文件
                            with open(log_file_path, "rb") as f:
                                try:
                                    f.seek(-5000, 2)  # 从文件末尾向前5000字节
                                except:
                                    f.seek(0)
                                log_tail = f.read().decode('utf-8', errors='ignore')
                                log_lines = log_tail.split('\n')[-30:]
                            
                            # 查找进度相关的日志
                            for line in reversed(log_lines):
                                if "进度" in line or "progress" in line.lower():
                                    # 提取进度信息
                                    match = re.search(r'(\d+)/(\d+)', line)
                                    if "HuBERT特征提取进度" in line:
                                        if match:
                                            current, total = match.groups()
                                            train_tasks[task_id]["message"] = f"正在提取HuBERT特征: {current}/{total}"
                                        else:
                                            train_tasks[task_id]["message"] = "正在提取HuBERT特征..."
                                        break
                                    elif "BERT特征提取进度" in line:
                                        if match:
                                            current, total = match.groups()
                                            train_tasks[task_id]["message"] = f"正在提取BERT特征: {current}/{total}"
                                        else:
                                            train_tasks[task_id]["message"] = "正在提取BERT特征..."
                                        break
                                    elif "SV特征提取进度" in line:
                                        if match:
                                            current, total = match.groups()
                                            train_tasks[task_id]["message"] = f"正在提取SV特征: {current}/{total}"
                                        else:
                                            train_tasks[task_id]["message"] = "正在提取SV特征..."
                                        break
                                    elif "语义token提取进度" in line:
                                        if match:
                                            current, total = match.groups()
                                            train_tasks[task_id]["message"] = f"正在生成语义token: {current}/{total}"
                                        else:
                                            train_tasks[task_id]["message"] = "正在生成语义token..."
                                        break
                        except Exception as e:
                            # 忽略读取错误，不影响主流程
                            pass
                else:
                    no_progress_count += 1
                    time_since_progress = time.time() - last_progress_time
                    if no_progress_count > max_no_progress or time_since_progress > max_no_progress * 2:
                        # 长时间没有进度，可能卡住了
                        if task_id in train_tasks:
                            elapsed_min = elapsed_time / 60
                            train_tasks[task_id]["message"] = f"{description} 执行中（已运行 {elapsed_min:.1f} 分钟，请检查日志或稍候）..."
                        # 如果超过20分钟没有进度，警告用户
                        if time_since_progress > 1200:  # 20分钟
                            logger.warning(f"{description} 已 {time_since_progress/60:.1f} 分钟没有进度更新，可能卡住")
            except:
                pass
            
            time.sleep(2)  # 每2秒检查一次
        
        return_code = process.returncode
        cmd_wall_s = time.time() - process_start_time
        try:
            cuda_vis = env.get("CUDA_VISIBLE_DEVICES", "")
            oom_fb = "CPU回退" in description
            emit_subprocess_wall(description, command, cuda_vis, return_code, cmd_wall_s, oom_cpu_fallback=oom_fb)
        except Exception:
            pass
    
    # 读取最后几行错误信息
    if return_code != 0:
        try:
            with open(log_file_path, "r", encoding="utf-8") as f:
                lines = f.readlines()
                # 获取最后20行作为错误信息
                error_lines = lines[-20:] if len(lines) > 20 else lines
                error_output = "".join(error_lines)
        except:
            error_output = "无法读取日志文件"
        
        error_msg = f"{description} 失败，退出码 {return_code}"
        if error_output:
            # 提取关键错误信息（最后几行）
            error_lines = error_output.strip().split('\n')
            for line in reversed(error_lines[-5:]):  # 最后5行
                if 'Error' in line or 'Traceback' in line or 'RuntimeError' in line or 'ValueError' in line:
                    error_msg += f"\n错误详情: {line.strip()}"
                    break
        
        # 更新任务状态
        if task_id in train_tasks:
            train_tasks[task_id]["message"] = error_msg
            train_tasks[task_id]["status"] = "failed"
        
        raise RuntimeError(error_msg)


def _locate_prepare_output(exp_dir: Path, prefix: str, suffix: str) -> Optional[Path]:
    """查找预处理输出文件"""
    # 先查找带 -0 后缀的文件
    candidate = exp_dir / f"{prefix}-0{suffix}"
    if candidate.exists():
        return candidate
    # 再查找不带后缀的文件
    candidate = exp_dir / f"{prefix}{suffix}"
    if candidate.exists():
        return candidate
    return None


def _ensure_header(file_path: Path, header: str):
    """确保文件有正确的表头"""
    if not file_path.exists():
        return
    with open(file_path, "r", encoding="utf-8") as f:
        first_line = f.readline().strip()
        if first_line != header:
            content = f.read()
            with open(file_path, "w", encoding="utf-8") as wf:
                wf.write(header + "\n")
                if first_line:
                    wf.write(first_line + "\n")
                wf.write(content)


def _find_latest_weight(weight_dir: Path, pattern: str, desc: str) -> Path:
    """查找最新的权重文件"""
    if not weight_dir.exists():
        raise FileNotFoundError(f"{desc}目录不存在: {weight_dir}")

    matches = list(weight_dir.glob(pattern))
    if not matches:
        raise FileNotFoundError(f"未找到{desc}: {pattern} in {weight_dir}")

    # 按修改时间排序，返回最新的
    matches.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return matches[0]


def _pick_latest_sovits_generator_checkpoint(candidates: list[Path]) -> Optional[Path]:
    """从候选 SoVITS 权重中优先选择可推理生成器权重（避免误选 D_ 判别器）。"""
    if not candidates:
        return None

    cleaned = []
    for p in candidates:
        try:
            name = p.name
        except Exception:
            continue
        lower = name.lower()
        if lower.startswith("d_") or "discriminator" in lower:
            continue
        cleaned.append(p)

    if not cleaned:
        return None

    # 训练目录通常产出 G_*.pth，优先使用。
    g_first = [p for p in cleaned if p.name.startswith("G_")]
    target = g_first if g_first else cleaned
    target.sort(key=lambda x: x.stat().st_mtime, reverse=True)
    return target[0]


def _count_dataset_samples(dataset_list_path: Path) -> int:
    """统计 dataset.list 的有效样本数。"""
    try:
        if not dataset_list_path.exists():
            return 0
        cnt = 0
        with open(dataset_list_path, "r", encoding="utf-8") as f:
            for line in f:
                t = line.strip()
                if t and "|" in t:
                    cnt += 1
        return cnt
    except Exception:
        return 0


def _decide_training_gpu_counts(sample_count: int, has_gpu: bool, max_visible_gpus: int = 1) -> Tuple[int, int, str]:
    """根据样本规模选择 S1/S2 推荐 GPU 数，降低小数据集开销并允许大数据集吃满空闲卡。"""
    if not has_gpu:
        return 1, 1, "cpu"

    visible = max(1, int(max_visible_gpus or 1))
    if sample_count <= TINY_DATASET_THRESHOLD:
        return 1, 1, "tiny_dataset"

    if sample_count <= SMALL_DATASET_THRESHOLD:
        # 小数据集主要避免 DDP 固定成本；S2 适度并行。
        return 1, min(visible, 2), "small_dataset"

    # 正常数据集：优先吃满可见 GPU，提升总体吞吐。
    return visible, visible, "normal_dataset"


def _build_prepare_cache_root(dataset_list_path: Path, version: str) -> Path:
    """基于数据集内容+版本构建稳定预处理缓存目录。"""
    try:
        payload = dataset_list_path.read_bytes()
    except Exception:
        payload = str(dataset_list_path).encode("utf-8", errors="ignore")
    h = hashlib.sha1()
    h.update(payload)
    h.update(f"|{version}|{TRAIN_PREP_CACHE_VERSION}".encode("utf-8"))
    digest = h.hexdigest()[:24]
    return BASE_DIR / "runtime" / "cache" / "tts_preprocess" / f"{version}_{digest}"


def _copy_file_if_exists(src: Path, dst: Path):
    if not src.exists() or (not src.is_file()):
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)


def _copy_dir_if_exists(src: Path, dst: Path):
    if not src.exists() or (not src.is_dir()):
        return
    if dst.exists():
        shutil.rmtree(dst, ignore_errors=True)
    shutil.copytree(src, dst)


def _prepare_step_specs(version: str) -> Dict[str, List[Tuple[str, str]]]:
    specs: Dict[str, List[Tuple[str, str]]] = {
        "step1": [("glob", "2-name2text*.txt"), ("dir", "3-bert")],
        "step2": [("dir", "4-cnhubert"), ("dir", "5-wav32k")],
        "step3": [("glob", "6-name2semantic*.tsv")],
    }
    specs["step2b"] = [("dir", "7-sv_cn")] if "Pro" in str(version or "") else []
    return specs


def _is_prepare_step_ready(root: Path, specs: List[Tuple[str, str]]) -> bool:
    if not specs:
        return True
    for kind, name in specs:
        if kind == "dir":
            p = root / name
            if (not p.exists()) or (not p.is_dir()):
                return False
            if not any(p.glob("*")):
                return False
        elif kind == "glob":
            matches = list(root.glob(name))
            if not matches:
                return False
            if not any(m.is_file() and m.stat().st_size > 0 for m in matches):
                return False
    return True


def _restore_prepare_step_cache(cache_root: Path, step_name: str, exp_dir: Path, specs: List[Tuple[str, str]]) -> bool:
    step_cache = cache_root / step_name
    if not _is_prepare_step_ready(step_cache, specs):
        return False

    for kind, name in specs:
        if kind == "dir":
            _copy_dir_if_exists(step_cache / name, exp_dir / name)
        elif kind == "glob":
            for src in step_cache.glob(name):
                if src.is_file():
                    _copy_file_if_exists(src, exp_dir / src.name)
    return _is_prepare_step_ready(exp_dir, specs)


def _save_prepare_step_cache(cache_root: Path, step_name: str, exp_dir: Path, specs: List[Tuple[str, str]]):
    if not specs:
        return
    step_cache = cache_root / step_name
    if step_cache.exists():
        shutil.rmtree(step_cache, ignore_errors=True)
    step_cache.mkdir(parents=True, exist_ok=True)

    for kind, name in specs:
        if kind == "dir":
            _copy_dir_if_exists(exp_dir / name, step_cache / name)
        elif kind == "glob":
            for src in exp_dir.glob(name):
                if src.is_file():
                    _copy_file_if_exists(src, step_cache / src.name)


def process_dataset(dataset_path: str, language: str, version: str, log_path: str = None) -> List[Dict]:
    """处理用户数据集（音频+文本对齐，与主程序预处理逻辑一致，增强容错&日志）"""
    processed = []
    text_files = [f for f in os.listdir(dataset_path) if f.endswith(".txt")]
    text_files = _limit_sentence_txt_files(text_files, MAX_DATASET_SENTENCES)
    for txt_file in text_files:
        try:
            with open(os.path.join(dataset_path, txt_file), "r", encoding="utf-8") as f:
                text = f.read().strip()
            audio_file = os.path.splitext(txt_file)[0] + ".wav"
            audio_path = os.path.join(dataset_path, audio_file)
            if not os.path.exists(audio_path):
                if log_path:
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"音频文件缺失：{audio_path}\n")
                continue
            audio = preprocess_audio(audio_path)
            # 用max_length防长文本
            text_parts = split_text(text, get_dict_language(version)[language], max_length=120)
            if not text_parts:
                if log_path:
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"文本切分失败（空）：{txt_file}\n")
                continue
            for part in text_parts:
                try:
                    if not TEXT_MODULES_AVAILABLE:
                        raise ImportError("text模块未安装，无法处理文本")
                    lang_code = get_dict_language(version)[language].replace("all_", "")
                    phones, word2ph, norm_text = clean_text(part, lang_code, version)
                    phones = cleaned_text_to_sequence(phones, version)
                except Exception as e:
                    if log_path:
                        with open(log_path, "a", encoding="utf-8") as logf:
                            logf.write(f"音素/清理异常：{txt_file} | {str(e)} | 文本片段: {part}\n")
                    continue
                processed.append({
                    "audio": audio.numpy(),
                    "phones": phones,
                    "text": norm_text,
                    "language": lang_code
                })
        except Exception as e:
            if log_path:
                with open(log_path, "a", encoding="utf-8") as logf:
                    logf.write(f"文件处理异常：{txt_file} | {str(e)}\n")
            continue
    return processed


def _create_dataset_list(dataset_path: str, output_path: str, language: str = "zh") -> Path:
    """创建数据集列表文件，格式：wav_path|spk_name|language|text
    
    Args:
        dataset_path: 数据集目录路径
        output_path: 输出目录路径
        language: 语言代码，支持: zh, en, ja, ko, yue (默认: zh)
    """
    dataset_list_path = Path(output_path) / "dataset.list"
    dataset_path_obj = Path(dataset_path)
    
    if not dataset_path_obj.exists():
        raise FileNotFoundError(f"数据集目录不存在: {dataset_path}")
    
    text_files = [f for f in os.listdir(dataset_path) if f.endswith(".txt")]
    # 只读取前 N 句，避免数据集过大
    text_files = _limit_sentence_txt_files(text_files, MAX_DATASET_SENTENCES)
    
    if not text_files:
        raise ValueError(f"数据集目录中没有找到文本文件: {dataset_path}")
    
    # 语言代码映射（确保使用预处理脚本支持的语言代码）
    language_map = {
        "中文": "zh",
        "中文（简体）": "zh",
        "中文（繁体）": "zh",
        "Chinese": "zh",
        "chinese": "zh",
        "English": "en",
        "english": "en",
        "日语": "ja",
        "Japanese": "ja",
        "japanese": "ja",
        "韩语": "ko",
        "Korean": "ko",
        "korean": "ko",
        "粤语": "yue",
        "Cantonese": "yue",
        "cantonese": "yue",
    }
    
    # 标准化语言代码
    lang_code = language_map.get(language, language).lower()
    if lang_code not in ["zh", "en", "ja", "ko", "yue"]:
        lang_code = "zh"  # 默认使用中文
    
    valid_pairs = []
    invalid_files = []
    
    with open(dataset_list_path, "w", encoding="utf-8") as f:
        for txt_file in sorted(text_files):
            audio_file = os.path.splitext(txt_file)[0] + ".wav"
            audio_path = dataset_path_obj / audio_file
            txt_path = dataset_path_obj / txt_file
            
            if not audio_path.exists():
                invalid_files.append(f"音频文件不存在: {audio_file}")
                continue
            
            if not txt_path.exists():
                invalid_files.append(f"文本文件不存在: {txt_file}")
                continue
            
            # 验证音频文件大小（至少1KB）
            try:
                if audio_path.stat().st_size < 1024:
                    invalid_files.append(f"音频文件太小（可能损坏）: {audio_file}")
                    continue
            except:
                invalid_files.append(f"无法读取音频文件: {audio_file}")
                continue
            
            # 读取文本内容
            try:
                with open(txt_path, "r", encoding="utf-8") as tf:
                    text_content = tf.read().strip()
                
                if not text_content:
                    invalid_files.append(f"文本文件为空: {txt_file}")
                    continue
            except Exception as e:
                invalid_files.append(f"读取文本文件失败 {txt_file}: {e}")
                continue
            
            # 格式：wav_path|spk_name|language|text
            # spk_name 使用文件名（不含扩展名）作为说话人ID
            spk_name = os.path.splitext(txt_file)[0]
            f.write(f"{audio_path}|{spk_name}|{lang_code}|{text_content}\n")
            valid_pairs.append((audio_file, txt_file))
    
    if invalid_files:
        # 使用print而不是logger（避免导入问题）
        print(f"警告: 数据集验证发现 {len(invalid_files)} 个无效文件（已跳过）")
        for msg in invalid_files[:10]:  # 只显示前10个
            print(f"  - {msg}")
        if len(invalid_files) > 10:
            print(f"  ... 还有 {len(invalid_files) - 10} 个无效文件")
    
    if not valid_pairs:
        raise ValueError(f"数据集目录中没有有效的音频-文本对: {dataset_path}")
    
    print(f"数据集列表创建成功: {len(valid_pairs)} 个有效文件对")
    
    return dataset_list_path


def _verify_audio_features_completeness(exp_dir: Path, version: str, log_file: str, task_id: str):
    """验证所有音频特征提取的完整性"""
    with open(log_file, "a", encoding="utf-8") as logf:
        logf.write(f"\n{'='*60}\n")
        logf.write(f"[音频特征完整性验证] 检查所有特征提取结果...\n")
        logf.write(f"{'='*60}\n")
        
        # 检查各个特征目录
        feature_dirs = {
            "32k音频": exp_dir / "5-wav32k",
            "HuBERT特征": exp_dir / "4-cnhubert",
        }
        
        if "Pro" in version:
            feature_dirs["SV特征"] = exp_dir / "7-sv_cn"
        
        # 统计每个目录的文件
        feature_stats = {}
        for name, dir_path in feature_dirs.items():
            if dir_path.exists():
                files = list(dir_path.glob("*.*"))
                feature_stats[name] = {
                    "count": len(files),
                    "files": files,
                    "valid": 0,
                    "invalid": []
                }
                
                # 验证文件可读性
                for f in files[:10]:  # 只检查前10个
                    try:
                        size = f.stat().st_size
                        if size > 0:
                            feature_stats[name]["valid"] += 1
                        else:
                            feature_stats[name]["invalid"].append(f.name)
                    except:
                        feature_stats[name]["invalid"].append(f.name)
            else:
                feature_stats[name] = {
                    "count": 0,
                    "files": [],
                    "valid": 0,
                    "invalid": [],
                    "missing": True
                }
        
        # 输出统计信息
        logf.write(f"\n[统计] 各特征文件数量：\n")
        for name, stats in feature_stats.items():
            if stats.get("missing"):
                logf.write(f"  ❌ {name}: 目录不存在\n")
            else:
                logf.write(f"  ✅ {name}: {stats['count']} 个文件 (有效: {stats['valid']}/{min(10, stats['count'])})\n")
                if stats['invalid']:
                    logf.write(f"     无效文件: {stats['invalid'][:3]}\n")
        
        # 检查文件数量一致性
        counts = [stats['count'] for stats in feature_stats.values() if not stats.get("missing")]
        if counts:
            max_count = max(counts)
            min_count = min(counts)
            
            if max_count != min_count:
                logf.write(f"\n⚠️ 警告: 特征文件数量不一致！\n")
                logf.write(f"   最大数量: {max_count}, 最小数量: {min_count}, 差异: {max_count - min_count}\n")
                
                # 找出缺失的文件
                wav32k_dir = feature_dirs.get("32k音频")
                if wav32k_dir and wav32k_dir.exists():
                    wav32k_files = {f.stem for f in wav32k_dir.glob("*.wav")}
                    
                    for name, dir_path in feature_dirs.items():
                        if name != "32k音频" and dir_path.exists():
                            feature_files = {f.stem for f in dir_path.glob("*.*")}
                            missing = wav32k_files - feature_files
                            if missing:
                                logf.write(f"   {name}缺失的文件 ({len(missing)} 个): {list(missing)[:5]}\n")
            else:
                logf.write(f"\n✅ 所有特征文件数量一致: {max_count} 个\n")
        
        # 检查关键特征是否存在
        critical_features = ["32k音频", "HuBERT特征"]
        if "Pro" in version:
            critical_features.append("SV特征")
        
        missing_critical = []
        for name in critical_features:
            stats = feature_stats.get(name, {})
            if stats.get("missing") or stats.get("count", 0) == 0:
                missing_critical.append(name)
        
        logf.write(f"\n{'='*60}\n")
        if missing_critical:
            logf.write(f"❌ 关键特征缺失: {', '.join(missing_critical)}\n")
            logf.write(f"   训练可能无法正常进行，请检查预处理日志。\n")
        else:
            logf.write(f"✅ 所有关键特征已提取完成\n")
        logf.write(f"{'='*60}\n")


def _run_prepare_steps(
    task_id: str,
    dataset_list_path: Path,
    exp_dir: Path,
    exp_name: str,
    version: str,
    log_file: str,
):
    """执行数据预处理步骤"""
    is_half = getattr(global_config, "is_half", True) if global_config else True
    bert_dir = _resolve_path(getattr(global_config, "bert_path", "GPT_SoVITS/pretrained_models/chinese-roberta-wwm-ext-large") if global_config else "GPT_SoVITS/pretrained_models/chinese-roberta-wwm-ext-large")
    ssl_dir = _resolve_path(getattr(global_config, "cnhubert_path", "GPT_SoVITS/pretrained_models/chinese-hubert-base") if global_config else "GPT_SoVITS/pretrained_models/chinese-hubert-base")
    # SV模型路径：优先使用配置中的路径，否则尝试多个可能的位置
    default_sv_paths = [
        "GPT_SoVITS/pretrained_models/sv/pretrained_eres2netv2w24s4ep4.ckpt",
        "GPT_SoVITS/pretrained_models/AI-ModelScope/GPT-SoVITS/sv/pretrained_eres2netv2w24s4ep4.ckpt",
    ]
    sv_path = None
    if global_config and hasattr(global_config, "sv_path") and global_config.sv_path:
        sv_path = _resolve_path(global_config.sv_path)
    else:
        # 尝试找到存在的SV模型文件
        for path in default_sv_paths:
            resolved = _resolve_path(path)
            if resolved.exists():
                sv_path = resolved
                break
        if sv_path is None:
            sv_path = _resolve_path(default_sv_paths[0])  # 使用默认路径，如果不存在会在运行时报错
    
    rec = _train_phase_get()
    if rec is not None:
        t_probe = time.perf_counter()
        probe: Dict[str, object] = {}
        for label, pth in (("bert_dir", bert_dir), ("cnhubert_dir", ssl_dir), ("sv_path", sv_path)):
            try:
                pp = Path(pth) if pth is not None else None
                if pp and pp.exists():
                    st = pp.stat()
                    probe[f"{label}_exists"] = True
                    probe[f"{label}_size_bytes"] = int(getattr(st, "st_size", 0) or 0)
                else:
                    probe[f"{label}_exists"] = False
            except Exception as ex:
                probe[f"{label}_err"] = str(ex)
        rec.emit("pretrained_paths_stat_probe", time.perf_counter() - t_probe, **probe)

    env_common = {
        "inp_text": str(dataset_list_path),
        "inp_wav_dir": "",
        "exp_name": exp_name,
        "opt_dir": str(exp_dir),
        "i_part": "0",
        "all_parts": "1",
        "is_half": str(is_half),
        "version": version,
    }

    prepare_cache_enabled = _env_flag("TRAIN_PREP_CACHE", ENTERPRISE_OPT_DEFAULT_ON)
    prepare_cache_root = _build_prepare_cache_root(dataset_list_path, version) if prepare_cache_enabled else None
    prepare_specs = _prepare_step_specs(version)

    if prepare_cache_root is not None:
        prepare_cache_root.mkdir(parents=True, exist_ok=True)
        with open(log_file, "a", encoding="utf-8") as logf:
            logf.write(f"[预处理缓存] 已启用，cache_root={prepare_cache_root}\n")


    def _run_prepare_command_with_fallback(description: str, command: List[str], extra_env: Dict[str, str]):
        try:
            _run_command(task_id, description, command, log_file, extra_env)
            return
        except RuntimeError as e:
            msg = str(e or "")
            lower = msg.lower()
