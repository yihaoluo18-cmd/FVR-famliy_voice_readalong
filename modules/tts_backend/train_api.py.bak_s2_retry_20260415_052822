def _inspect_sovits_weight_dict(weight_obj) -> tuple[bool, str]:
    if not isinstance(weight_obj, dict) or not weight_obj:
        return False, "SoVITS权重为空或非字典"

    keys = list(weight_obj.keys())
    key_count = len(keys)
    if key_count < 50:
        return False, f"SoVITS权重参数数量异常({key_count})"

    has_generator_prefix = any(
        k.startswith(("enc_p.", "dec.", "flow.", "ref_enc.", "quantizer."))
        for k in keys
    )
    has_discriminator_only = all(k.startswith("discriminators.") for k in keys[: min(64, key_count)])

    if has_discriminator_only and (not has_generator_prefix):
        return False, "检测到判别器(D_)权重，非可推理生成器模型"

    if not has_generator_prefix:
        return False, "SoVITS权重缺少生成器关键前缀(enc_p/dec/flow/ref_enc)"

    return True, f"SoVITS生成器权重有效(keys={key_count})"


def _validate_sovits_model_file(model_path: Path, version: str = "v2Pro") -> tuple[bool, str]:
    """校验 SoVITS 模型文件是否可用（严格区分生成器/判别器）。"""
    try:
        if not model_path.exists():
            return False, f"SoVITS模型不存在: {model_path}"
        size_mb = model_path.stat().st_size / 1024 / 1024
        if size_mb < 1.0:
            return False, f"SoVITS模型文件过小({size_mb:.2f}MB): {model_path}"

        try:
            from GPT_SoVITS.process_ckpt import load_sovits_new

            checkpoint = load_sovits_new(str(model_path))
            if isinstance(checkpoint, dict):
                weight_obj = checkpoint.get("weight") or checkpoint.get("model")
                ok, msg = _inspect_sovits_weight_dict(weight_obj)
                if ok:
                    return True, f"SoVITS模型校验通过({size_mb:.2f}MB): {msg}"
                return False, f"SoVITS模型校验失败({size_mb:.2f}MB): {msg}"
        except Exception:
            pass

        checkpoint = torch.load(str(model_path), map_location="cpu")
        if isinstance(checkpoint, dict):
            weight_obj = checkpoint.get("weight") or checkpoint.get("model")
            ok, msg = _inspect_sovits_weight_dict(weight_obj)
            if ok:
                return True, f"SoVITS模型兼容校验通过({size_mb:.2f}MB): {msg}"
            return False, f"SoVITS模型结构不符合生成器要求: {msg}"
        return False, f"SoVITS模型结构异常: {type(checkpoint)}"
    except Exception as e:
        return False, f"SoVITS模型加载失败: {e}"


def _collect_registered_sovits_paths_for_user(user_id: str) -> set[str]:
    """读取声音库，收集该用户已注册并应保留的 SoVITS 权重路径。"""
    user_key = re.sub(r"[^a-zA-Z0-9_\-]", "_", str(user_id or "").strip())
    if not user_key:
        return set()

    library_path = BASE_DIR / "voice_library.json"
    if not library_path.exists():
        return set()

    keep_paths: set[str] = set()
    try:
        with open(library_path, "r", encoding="utf-8") as f:
            data = json.load(f)
        if not isinstance(data, dict):
            return set()

        prefix = f"voice_{user_key}_"
        for info in data.values():
            if not isinstance(info, dict):
                continue
            sovits_path = str(info.get("sovits_path") or "").strip()
            if not sovits_path:
                continue
            sovits_abs = os.path.abspath(sovits_path)
            base_name = os.path.basename(sovits_abs)
            if base_name.startswith(prefix) and base_name.endswith(".pth"):
                keep_paths.add(sovits_abs)
    except Exception as e:
        logger.warning(f"[SoVITS清理] 读取 voice_library.json 失败，将只保留当前产物: {e}")

    return keep_paths


def _cleanup_user_stale_sovits_weights(
    user_id: str,
    version: str,
    keep_paths: Optional[set[str]] = None,
    current_task_id: Optional[str] = None,
    log_path: Optional[str] = None,
    remove_only_invalid: bool = False,
):
    """清理用户旧的 SoVITS 权重文件。"""
    keep_abs = {os.path.abspath(p) for p in (keep_paths or set())}
    removed = []

    def _should_remove(p: Path) -> tuple[bool, str]:
        p_abs = os.path.abspath(str(p))
        if p_abs in keep_abs:
            return False, "in_keep_set"
        if remove_only_invalid:
            ok, msg = _validate_sovits_model_file(p, version=version)
            return (not ok), msg
        return True, "stale_file"

    def _log(msg: str):
        if not log_path:
            logger.info(msg)
            return
        try:
            with open(log_path, "a", encoding="utf-8") as f:
                f.write(msg + "\n")
        except Exception:
            logger.info(msg)

    user_key = re.sub(r"[^a-zA-Z0-9_\-]", "_", str(user_id or "").strip())
    if not user_key:
        return

    try:
        sovits_weight_dir = _get_versioned_path("SoVITS_weight_version2root", version, "SoVITS_weights_v2Pro")
    except Exception:
        sovits_weight_dir = BASE_DIR / "SoVITS_weights_v2Pro"

    if sovits_weight_dir.exists():
        for p in sovits_weight_dir.glob(f"voice_{user_key}_*.pth"):
            try:
                rm, why = _should_remove(p)
                if rm:
                    p.unlink(missing_ok=True)
                    removed.append(str(p))
                    _log(f"[SoVITS清理] 已移除全局权重: {p} (原因: {why})")
            except Exception as e:
                _log(f"[SoVITS清理] 移除失败: {p}, err={e}")

    user_root = Path(TRAIN_OUTPUT_DIR) / user_key
    if user_root.exists() and user_root.is_dir():
        for task_dir in user_root.iterdir():
            if not task_dir.is_dir():
                continue
            s2_dir = task_dir / "processed" / f"logs_s2_{version}"
            if not s2_dir.exists():
                continue
            for p in s2_dir.glob("*.pth"):
                try:
                    rm, why = _should_remove(p)
                    if rm:
                        p.unlink(missing_ok=True)
                        removed.append(str(p))
                        _log(f"[SoVITS清理] 已移除任务权重: {p} (原因: {why})")
                except Exception as e:
                    _log(f"[SoVITS清理] 移除失败: {p}, err={e}")

    if removed:
        _log(f"[SoVITS清理] 本次共移除 {len(removed)} 个文件")

def run_training(task_id: str, dataset_path: str, output_path: str, log_path: str, params: TrainParams):
    """后台执行真实训练流程"""
    set_high_priority()
    
    # 初始化损失监控器
    loss_monitor = None
    try:
        from training_loss_monitor import monitor_training_loss
        loss_file = Path(log_path).parent / f"{Path(log_path).stem}_losses.json"
        loss_monitor = monitor_training_loss(Path(log_path), loss_file)
        logger.info(f"[损失监控] 已启动损失监控，数据将保存到: {loss_file}")
    except Exception as e:
        logger.warning(f"[损失监控] 启动损失监控失败: {e}，将继续训练但不监控损失")
    
    try:
        if TrainPhaseRecorder is not None:
            _tp_path = Path(log_path).parent / f"{Path(log_path).stem}_phases.jsonl"
            _train_phase_set(TrainPhaseRecorder(_tp_path))
            _train_phase_get().emit(
                "run_start",
                0.0,
                task_id=task_id,
                dataset_path=str(dataset_path),
                output_path=str(output_path),
                fast_mode=bool(getattr(params, "fast_mode", False)),
                model_version=str(params.model_version),
                phases_jsonl=str(_tp_path),
            )
        with open(log_path, "w", encoding="utf-8") as f:
            f.write(f"开始训练：{time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            # 兼容Pydantic v1和v2
            try:
                params_dict = params.model_dump() if hasattr(params, 'model_dump') else params.dict()
            except:
                params_dict = {"user_id": params.user_id, "model_version": params.model_version, 
                              "epochs": params.epochs, "batch_size": params.batch_size,
                              "learning_rate": params.learning_rate, "language": params.language,
                              "fast_mode": getattr(params, "fast_mode", False)}
            f.write(f"参数：{params_dict}\n")
            f.write(f"模型版本：{params.model_version}\n")

        # 创建实验目录
        # 确保exp_name包含user_id，使每个用户的模型权重分开保存
        exp_name = f"voice_{params.user_id}_{task_id[:8]}"
        exp_dir = Path(output_path) / "processed"
        job_dir = Path(output_path)
        exp_dir.mkdir(parents=True, exist_ok=True)
        job_dir.mkdir(parents=True, exist_ok=True)

        # 先清理该用户最近异常/损坏的 SoVITS 产物，避免重训时混入坏权重。
        _t_cleanup0 = time.perf_counter()
        try:
            _cleanup_user_stale_sovits_weights(
                user_id=params.user_id,
                version=params.model_version,
                keep_paths=set(),
                current_task_id=task_id,
                log_path=log_path,
                remove_only_invalid=True,
            )
        except Exception as cleanup_pre_err:
            logger.warning(f"[SoVITS清理] 预清理异常文件失败: {cleanup_pre_err}")
        _rec_c = _train_phase_get()
        if _rec_c is not None:
            _rec_c.emit("sovit_cleanup_precheck", time.perf_counter() - _t_cleanup0)
        
        train_tasks[task_id]["progress"] = 5
        train_tasks[task_id]["message"] = "创建数据集列表..."
        
        # 音频降噪除杂预处理（在创建数据集列表之前）
        _t_pur_all = time.perf_counter()
        if AUDIO_PURIFICATION_AVAILABLE:
            train_tasks[task_id]["message"] = "正在进行音频降噪除杂..."
            train_tasks[task_id]["progress"] = 3
            try:
                with open(log_path, "a", encoding="utf-8") as logf:
                    logf.write(f"\n{'='*60}\n")
                    logf.write(f"[音频降噪除杂] 开始处理数据集音频文件...\n")
                    logf.write(f"{'='*60}\n")
                
                # 查找所有音频文件
                audio_files = list(Path(dataset_path).glob("*.wav"))
                # 只处理前 N 句（按 sentence_{idx}.wav 排序），避免提纯步骤处理过多文件
                try:
                    import re
                    sent = []
                    other = []
                    for p in audio_files:
                        m = re.match(r"^sentence_(\d+)\.wav$", p.name)
                        if m:
                            sent.append((int(m.group(1)), p))
                        else:
                            other.append(p)
                    if sent:
                        sent.sort(key=lambda x: x[0])
                        audio_files = [p for _, p in sent[:MAX_DATASET_SENTENCES]]
                    else:
                        audio_files = sorted(other)[:MAX_DATASET_SENTENCES]
                except Exception:
                    audio_files = audio_files[:MAX_DATASET_SENTENCES]
                total_files = len(audio_files)
                
                if total_files > 0:
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"找到 {total_files} 个音频文件，开始降噪除杂处理...\n")
                    
                    # 创建临时目录存储提纯后的音频
                    purified_dir = Path(dataset_path) / "_purified_temp"
                    purified_dir.mkdir(exist_ok=True)
                    
                    success_count = 0
                    failed_count = 0
                    
                    purify_strategy = os.environ.get("TRAIN_AUDIO_PURIFY_STRATEGY", "deepfilternet3_wpe")
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"音频清洗策略: {purify_strategy} (去噪+去混响默认开启)\n")
                    for idx, audio_file in enumerate(audio_files):
                        try:
                            # 更新进度
                            progress = 3 + int((idx + 1) / total_files * 2)  # 3-5%
                            train_tasks[task_id]["progress"] = progress
                            train_tasks[task_id]["message"] = f"音频降噪除杂 ({idx + 1}/{total_files})..."
                            
                            # 提纯音频（默认开启去噪+去混响；失败时自动回退且不中断训练）
                            purified_file = purified_dir / audio_file.name
                            _t_one = time.perf_counter()
                            purify_meta = purify_audio_file(
                                str(audio_file),
                                str(purified_file),
                                enable_vocal_separation=False,
                                vocal_model="HP5",
                                enable_denoise=True,
                                enable_dereverb=True,
                                enable_deecho=False,  # 禁用去回声
                                verbose=False,  # 不显示详细日志
                            )
                            _rec_pf = _train_phase_get()
                            if _rec_pf is not None:
                                _rec_pf.emit(
                                    "audio_purify_file",
                                    time.perf_counter() - _t_one,
                                    file=str(audio_file.name),
                                    index=int(idx),
                                )
                            
                            # 替换原文件
                            shutil.move(str(purified_file), str(audio_file))
                            success_count += 1
                            with open(log_path, "a", encoding="utf-8") as logf:
                                logf.write(
                                    f"  - {audio_file.name}: denoise={purify_meta.get('denoise_engine', 'unknown')}, "
                                    f"dereverb={purify_meta.get('dereverb_engine', 'unknown')}, "
                                    f"spectral={purify_meta.get('spectral_gate_engine', 'none')}, "
                                    f"trim={purify_meta.get('silence_trim', 'none')}, "
                                    f"trim_sec={purify_meta.get('silence_trim_src_sec', 'na')}->{purify_meta.get('silence_trim_dst_sec', 'na')}\n"
                                )
                            
                        except Exception as e:
                            failed_count += 1
                            with open(log_path, "a", encoding="utf-8") as logf:
                                logf.write(f"⚠️ 音频文件 {audio_file.name} 处理失败: {str(e)}\n")
                            # 如果提纯失败，继续使用原文件
                            continue
                    
                    # 清理临时目录
                    try:
                        if purified_dir.exists():
                            shutil.rmtree(purified_dir)
                    except:
                        pass
                    
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"\n音频降噪除杂完成: 成功 {success_count}/{total_files}, 失败 {failed_count}/{total_files}\n")
                        logf.write(f"{'='*60}\n")
                else:
                    with open(log_path, "a", encoding="utf-8") as logf:
                        logf.write(f"未找到音频文件，跳过降噪除杂步骤\n")
                        logf.write(f"{'='*60}\n")
                        
            except Exception as e:
                with open(log_path, "a", encoding="utf-8") as logf:
                    logf.write(f"⚠️ 音频降噪除杂过程出错: {str(e)}\n")
                    logf.write(f"将继续使用原始音频文件进行训练\n")
                    logf.write(f"{'='*60}\n")
                logger.warning(f"音频降噪除杂失败: {e}，将继续使用原始音频")
        else:
            with open(log_path, "a", encoding="utf-8") as logf:
                logf.write("\n[音频降噪除杂] 模块不可用，跳过\n")
        _rec_pu = _train_phase_get()
        if _rec_pu is not None:
            _rec_pu.emit(
                "audio_purification_section_total",
                time.perf_counter() - _t_pur_all,
                purification_module_available=bool(AUDIO_PURIFICATION_AVAILABLE),
            )
        
        train_tasks[task_id]["progress"] = 5
        train_tasks[task_id]["message"] = "创建数据集列表..."
        
        # 创建数据集列表（使用训练参数中的语言设置）
        _t_ds = time.perf_counter()
        dataset_list_path = _create_dataset_list(dataset_path, str(job_dir), params.language)
        _rec_ds = _train_phase_get()
        if _rec_ds is not None:
            _rec_ds.emit("create_dataset_list", time.perf_counter() - _t_ds, list_path=str(dataset_list_path))

        dataset_sample_count = _count_dataset_samples(dataset_list_path)
        visible_gpu_count = torch.cuda.device_count() if torch.cuda.is_available() else 0
        s1_target_gpu_count, s2_target_gpu_count, gpu_policy_tag = _decide_training_gpu_counts(
            dataset_sample_count,
            torch.cuda.is_available(),
            max_visible_gpus=visible_gpu_count,
        )

        if _env_flag("TRAIN_USE_ALL_IDLE_GPU", ENTERPRISE_OPT_DEFAULT_ON) and visible_gpu_count > 0 and dataset_sample_count > TINY_DATASET_THRESHOLD:
            # 企业模式默认允许使用全部空闲卡（由 _find_free_gpus 实际筛出），以追求训练吞吐。
            s1_target_gpu_count = max(1, visible_gpu_count)
            s2_target_gpu_count = max(1, visible_gpu_count)
            gpu_policy_tag = f"{gpu_policy_tag}+all_idle"

        train_tasks[task_id]["dataset_sample_count"] = dataset_sample_count
        train_tasks[task_id]["gpu_policy"] = gpu_policy_tag
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(
                f"\n[训练资源策略] sample_count={dataset_sample_count}, policy={gpu_policy_tag}, "
                f"s1_gpus={s1_target_gpu_count}, s2_gpus={s2_target_gpu_count}\n"
            )
      
        # 数据预处理
        train_tasks[task_id]["message"] = "开始数据预处理..."
        _t_prep = time.perf_counter()
        _run_prepare_steps(
            task_id=task_id,
            dataset_list_path=dataset_list_path,
            exp_dir=exp_dir,
            exp_name=exp_name,
            version=params.model_version,
            log_file=log_path,
        )
        _rec_pr = _train_phase_get()
        if _rec_pr is not None:
            _rec_pr.emit("prepare_steps_total_wall", time.perf_counter() - _t_prep)
        
        # 查找预处理输出文件
        _t_post0 = time.perf_counter()
        semantic_path = _locate_prepare_output(exp_dir, "6-name2semantic", ".tsv")
        phoneme_path = _locate_prepare_output(exp_dir, "2-name2text", ".txt")
        if not semantic_path or not phoneme_path:
            raise FileNotFoundError("预处理输出缺失，请检查音频/文本质量")
        
        # 验证语义数据不为空
        try:
            import pandas as pd
            semantic_df = pd.read_csv(semantic_path, sep="\t", header=None, names=["name", "semantic"])
            if len(semantic_df) == 0:
                # 检查32k音频文件是否存在
                wav32k_dir = exp_dir / "5-wav32k"
                wav32k_files = list(wav32k_dir.glob("*.wav")) if wav32k_dir.exists() else []
                
                # 检查HuBERT特征文件是否存在
                hubert_dir = exp_dir / "4-cnhubert"
                hubert_files = list(hubert_dir.glob("*.pt")) if hubert_dir.exists() else []
                
                error_msg = (
                    f"语义数据为空！文件 {semantic_path} 中没有有效数据。\n"
                    f"\n诊断信息：\n"
                    f"- 32k音频文件数量: {len(wav32k_files)}\n"
                    f"- HuBERT特征文件数量: {len(hubert_files)}\n"
                    f"\n可能的原因：\n"
                )
                
                if len(wav32k_files) == 0:
                    error_msg += (
                        f"1. ❌ 所有32k音频文件缺失（5-wav32k目录为空）\n"
                        f"   - 这通常意味着HuBERT特征提取步骤中所有音频文件都被过滤掉了\n"
                        f"   - 检查日志中的 'nan filtered' 警告\n"
                        f"   - 可能原因：音频文件损坏、格式问题、或包含无效数据\n"
                    )
                elif len(hubert_files) == 0:
                    error_msg += (
                        f"2. ❌ HuBERT特征文件缺失（4-cnhubert目录为空）\n"
                        f"   - 虽然32k音频文件存在，但HuBERT特征提取失败\n"
                    )
                else:
                    error_msg += (
                        f"3. ❌ 语义token提取失败\n"
                        f"   - 32k音频和HuBERT特征都存在，但语义token提取失败\n"
                    )
                
                error_msg += (
                    f"\n建议：\n"
                    f"- 检查原始音频文件是否有效（格式、时长、质量）\n"
                    f"- 查看预处理日志中的详细错误信息\n"
                    f"- 确保至少有一些音频文件能够成功处理\n"
                )
                
                raise ValueError(error_msg)
            train_tasks[task_id]["message"] = f"数据验证通过：语义数据 {len(semantic_df)} 条"
        except Exception as e:
            if isinstance(e, ValueError) and "语义数据为空" in str(e):
                raise  # 重新抛出语义数据为空的错误
            logger.warning(f"验证语义数据时出错（继续训练）: {e}")
        
        # 确保文件有正确的表头
        canonical_semantic = exp_dir / "6-name2semantic.tsv"
        canonical_phoneme = exp_dir / "2-name2text.txt"
        if semantic_path != canonical_semantic:
            shutil.copyfile(semantic_path, canonical_semantic)
            semantic_path = canonical_semantic
        if phoneme_path != canonical_phoneme:
            shutil.copyfile(phoneme_path, canonical_phoneme)
            phoneme_path = canonical_phoneme
        _ensure_header(semantic_path, "name\tsemantic")
        _ensure_header(phoneme_path, "name\tphoneme\ttones\ttext")
        _rec_po = _train_phase_get()
        if _rec_po is not None:
            _rec_po.emit("post_prepare_locate_validate_header", time.perf_counter() - _t_post0)
        
        # S1 GPT 训练
        train_tasks[task_id]["progress"] = 65  # 确保超过60%，避免被清理缓存
        mode_text = "快速模式" if params.fast_mode else "正常模式"
        train_tasks[task_id]["message"] = f"开始 GPT 模型训练 ({mode_text})..."
        
        # 记录训练配置信息
        has_gpu = torch.cuda.is_available()
        gpu_info = f"GPU: {torch.cuda.get_device_name(0)}" if has_gpu else "CPU"
        
        # 强制使用官方参数，不进行任何显存优化
        # S1官方参数：batch_size=8, epochs=15
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n训练模式: {mode_text}\n")
            f.write(f"硬件: {gpu_info}\n")
            f.write(f"使用官方参数: batch_size=8, epochs=15 (S1)\n")
            f.write(f"注意: 已禁用显存优化，强制使用官方参数以确保与官网一致\n")
        
        s1_config_path = _build_s1_config(
            task_id=task_id,
            exp_name=exp_name,
            exp_dir=exp_dir,
            version=params.model_version,
            job_dir=job_dir,
            semantic_path=semantic_path,
            phoneme_path=phoneme_path,
            batch_size=8,  # 强制使用官方值
            epochs=15,  # 强制使用官方值
            learning_rate=params.learning_rate,
            fast_mode=params.fast_mode,
            dataset_sample_count=dataset_sample_count,
        )
        
        # 验证配置文件（确保使用官方参数）
        config_check = yaml.safe_load(Path(s1_config_path).read_text(encoding="utf-8"))
        actual_batch_size = config_check['train']['batch_size']
        actual_epochs = config_check['train']['epochs']
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n{'='*60}\n")
            f.write(f"[S1配置验证] 实际使用的训练参数:\n")
            f.write(f"  batch_size: {actual_batch_size} (官方值: 8)\n")
            f.write(f"  epochs: {actual_epochs} (官方值: 15)\n")
            f.write(f"  save_every_n_epoch: {config_check['train'].get('save_every_n_epoch', 'N/A')} (官方值: 5)\n")
            f.write(f"  precision: {config_check['train'].get('precision', 'N/A')} (官方值: 16-mixed)\n")
            if actual_batch_size != 8:
                f.write(f"  ⚠️ 警告: batch_size不是官方值8！\n")
            if actual_epochs != 15 and not params.fast_mode:
                f.write(f"  ⚠️ 警告: epochs不是官方值15！\n")
            f.write(f"{'='*60}\n")
        
        # 记录S1训练开始时间
        s1_start_time = time.time()
        
        # 确定用于S1训练的GPU编号（多卡训练：使用2张卡）
        # 如果环境变量中已设置，则使用；否则自动选择空闲GPU
        s1_gpu_env = os.environ.get("CUDA_VISIBLE_DEVICES")
        if s1_gpu_env is None:
            # 自动选择空闲GPU（至少需要2张GPU，每张至少8GB空闲显存用于GPT训练）
            if torch.cuda.is_available():
                free_gpus = _find_free_gpus(min_free_memory_mb=8192, num_gpus=s1_target_gpu_count)
                if free_gpus:
                    # 转换为逗号分隔的格式（用于CUDA_VISIBLE_DEVICES）
                    s1_gpu_env = ",".join(map(str, free_gpus))
                else:
                    s1_gpu_env = "0"  # 默认使用GPU 0
            else:
                s1_gpu_env = "0"
        
        s1_env = {
            "CUDA_VISIBLE_DEVICES": s1_gpu_env,
        }
        
        with open(log_path, "a", encoding="utf-8") as f:
            gpu_count = len(s1_gpu_env.split(",")) if s1_gpu_env else 1
            f.write(f"\n[S1训练] 使用 {gpu_count} 张GPU: {s1_gpu_env}\n")
        
        _run_command(
            task_id,
            "GPT (s1) 训练",
            [PYTHON_EXEC, "-s", str(BASE_DIR / "GPT_SoVITS" / "s1_train.py"), "--config_file", str(s1_config_path)],
            log_path,
            s1_env,
        )
        train_tasks[task_id]["progress"] = 75
        train_tasks[task_id]["message"] = "GPT 训练完成，准备 SoVITS 训练..."
        
        # 记录S1训练完成时间
        s1_duration = time.time() - s1_start_time
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n[S1训练] GPT模型训练完成，耗时: {s1_duration/60:.2f} 分钟\n")
        
        # S2 SoVITS 训练
        # 强制使用官方参数，不进行任何显存优化
        # S2官方参数：batch_size=8, epochs=8
        with open(log_path, "a", encoding="utf-8") as f:
