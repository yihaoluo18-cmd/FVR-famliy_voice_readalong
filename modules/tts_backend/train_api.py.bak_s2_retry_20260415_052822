        train_tasks[task_id]["progress"] = 95
        train_tasks[task_id]["message"] = "训练完成，提取参考音频和文本..."
        
        # 从训练数据中提取参考音频与短提示词（用于推理）
        ref_audio_path = None
        ref_text = None
        ref_language = params.language
        try:
            dataset_path_obj = Path(dataset_path)
            text_files = [f for f in os.listdir(dataset_path) if f.endswith(".txt")]
            text_files = _limit_sentence_txt_files(text_files, MAX_DATASET_SENTENCES)

            candidates = []
            import librosa
            for txt_file in sorted(text_files):
                try:
                    txt_path = dataset_path_obj / txt_file
                    text = txt_path.read_text(encoding="utf-8").strip()
                    if not text:
                        continue
                    audio_file = os.path.splitext(txt_file)[0] + ".wav"
                    audio_path = dataset_path_obj / audio_file
                    if not audio_path.exists():
                        continue

                    audio, sr = librosa.load(str(audio_path), sr=16000, mono=True)
                    duration = len(audio) / max(1, sr)
                    rms = float(np.sqrt(float(np.mean(np.square(audio))) + 1e-12))
                    snippet = _pick_ref_text_snippet(text, max_chars=48)
                    if not snippet:
                        continue
                    # 过滤近静音参考，避免训练后推理“有文件但没声音”。
                    if rms < 0.0012:
                        continue

                    # 评分：优先 4-8 秒 + 10-40 字稳态提示词 + 较高RMS
                    score = 0.0
                    if 4.0 <= duration <= 8.0:
                        score += 3.0
                    elif 3.0 <= duration <= 10.0:
                        score += 2.0
                    elif 2.0 <= duration <= 12.0:
                        score += 1.0

                    n = len(snippet)
                    if 10 <= n <= 40:
                        score += 3.0
                    elif 8 <= n <= 48:
                        score += 2.0
                    else:
                        score += 1.0

                    candidates.append((score, rms, abs(duration - 6.0), str(audio_path.resolve()), snippet))
                except Exception as e:
                    logger.warning(f"处理参考样本失败 {txt_file}: {str(e)}")

            if candidates:
                candidates.sort(key=lambda x: (x[0], x[1], -x[2]), reverse=True)
                _score, _rms, _d, ref_audio_path, ref_text = candidates[0]
            elif text_files:
                # 兜底：使用第一条，但提示词强制裁短
                txt_file = sorted(text_files)[0]
