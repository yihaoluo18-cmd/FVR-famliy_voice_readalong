                raw_text = txt_path.read_text(encoding="utf-8").strip()
                audio_file = os.path.splitext(txt_file)[0] + ".wav"
                audio_path = dataset_path_obj / audio_file
                if audio_path.exists():
                    ref_audio_path = str(audio_path.resolve())
                    ref_text = _pick_ref_text_snippet(raw_text, max_chars=40) or raw_text[:40]

            if ref_audio_path and ref_text:
