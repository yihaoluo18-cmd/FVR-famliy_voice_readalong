        # 查找SoVITS模型：优先在训练输出目录中查找
        if s2_output_dir.exists():
            # SoVITS模型文件直接保存在s2_output_dir下，文件名格式为 G_*.pth 和 D_*.pth
            # 推理时只需要G_*.pth（生成器模型）
            all_pths = list(s2_output_dir.glob("G_*.pth"))
            if all_pths:
                # 选择最新的G_*.pth文件
                sovits_path = max(all_pths, key=lambda p: p.stat().st_mtime)
