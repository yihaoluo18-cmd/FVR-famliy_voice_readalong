def set_high_priority():
    """设置进程优先级（复用主程序逻辑）"""
    if os.name != "nt":
        return
    p = psutil.Process(os.getpid())
    try:
        p.nice(psutil.HIGH_PRIORITY_CLASS)
        print("已将训练进程优先级设为 High")
    except psutil.AccessDenied:
        print("权限不足，无法修改训练进程优先级（请用管理员运行）")


def preprocess_audio(file_path: str, target_sr: int = 16000) -> torch.Tensor:
    """音频预处理（与主程序get_spepc逻辑对齐）"""
    audio, sr = torchaudio.load(file_path)
    # 转单声道
    if audio.shape[0] == 2:
        audio = audio.mean(0).unsqueeze(0)
    # 重采样
    if sr != target_sr:
        resampler = torchaudio.transforms.Resample(sr, target_sr)
        audio = resampler(audio)
    # 归一化
    max_val = audio.abs().max()
    if max_val > 1:
        audio /= max_val
    return audio.squeeze(0)


def split_text(text: str, language: str, max_length: int = 120) -> List[str]:
    """文本切分（复用主程序cut逻辑），超长句强制分割"""
    splits = {"，", "。", "？", "！", ",", ".", "?", "!", "~", ":", "：", "—", "…"}
    if not text:
        return []
    # 确保文本以标点结尾
    if text[-1] not in splits:
        text += "。" if language != "en" else "."
    # 按标点切分
    parts = []
    current = []
    for char in text:
        current.append(char)
        if char in splits:
            parts.append("".join(current))
            current = []
    if current:
        parts.append("".join(current))
    # 二次分割，限制长度
    final_parts = []
    for seg in parts:
        seg = seg.strip()
        if not seg:
            continue
        while len(seg) > max_length:
            final_parts.append(seg[:max_length])
            seg = seg[max_length:]
        if seg:
            final_parts.append(seg)
    return final_parts


def _resolve_path(path_str: str) -> Path:
    """解析路径，支持相对路径和绝对路径"""
    path = Path(path_str)
    if path.is_absolute():
        return path
    return BASE_DIR / path


def _get_versioned_path(attr_name: str, version: str, fallback: Optional[str] = None) -> Path:
    """从config中获取版本化路径"""
    if not global_config:
        if fallback:
            return _resolve_path(fallback)
        raise ValueError(f"{attr_name} 未配置且未提供备用路径")
    
    mapping = getattr(global_config, attr_name, None)
    candidate = None
    if isinstance(mapping, dict):
        candidate = mapping.get(version)
    elif isinstance(mapping, str):
        candidate = mapping
    if not candidate:
        candidate = fallback
    if not candidate:
        raise ValueError(f"{attr_name} 未配置且未提供备用路径")
    return _resolve_path(candidate)

