        self_check_passed = bool(gpt_self_ok and sovits_self_ok and ref_self_ok)

        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n[训练后自检] GPT: {'通过' if gpt_self_ok else '失败'} - {gpt_self_msg}\n")
            f.write(f"[训练后自检] SoVITS: {'通过' if sovits_self_ok else '失败'} - {sovits_self_msg}\n")
            f.write(f"[训练后自检] 参考信息: {'通过' if ref_self_ok else '失败'} - {ref_self_msg}\n")

        train_tasks[task_id]["self_check_passed"] = self_check_passed

        if not self_check_passed:
            train_tasks[task_id]["status"] = "failed"
            train_tasks[task_id]["progress"] = 100
            train_tasks[task_id]["message"] = "训练未通过模型自检，未注册音色，请重试训练。"
            with open(log_path, "a", encoding="utf-8") as f:
                f.write("\n[训练后自检] 未通过，已阻止注册到声音库。\n")

            # 自检失败时删除本次异常 SoVITS 产物，避免出现在后续流程中。
            try:
                _cleanup_user_stale_sovits_weights(
                    user_id=params.user_id,
                    version=params.model_version,
                    keep_paths=set(),
                    current_task_id=task_id,
                    log_path=log_path,
                    remove_only_invalid=False,
                )
            except Exception as cleanup_err:
                logger.warning(f"[SoVITS清理] 自检失败后清理异常产物失败: {cleanup_err}")
            return

        train_tasks[task_id]["status"] = "running"
        train_tasks[task_id]["progress"] = 99
        train_tasks[task_id]["message"] = "训练完成，正在注册音色..."

        # 注册模型到 VOICE_LIBRARY（使用延迟导入避免循环依赖）
        registration_ok = False
        registration_error = ""
        _skip_reg = os.environ.get("TRAIN_SKIP_VOICE_REGISTRATION", "").strip().lower() in ("1", "true", "yes")
        if _skip_reg:
            registration_ok = True
            train_tasks[task_id]["status"] = "completed"
            train_tasks[task_id]["progress"] = 100
            train_tasks[task_id]["message"] = "训练完成（已跳过音色注册，TRAIN_SKIP_VOICE_REGISTRATION=1）。"
            with open(log_path, "a", encoding="utf-8") as f:
                f.write("\n[TRAIN_SKIP_VOICE_REGISTRATION] 已跳过 wx_api 音色注册（CLI/性能测试用）。\n")
        if not _skip_reg:
            try:
                # 延迟导入，避免循环依赖
                import importlib
                # 从 wx_api 模块导入，而不是 api 模块
                try:
                    wx_api_module = importlib.import_module('modules.tts_backend.wx_api')
                except Exception:
                    wx_api_module = importlib.import_module('wx_api')
                register_voice_model = wx_api_module.register_voice_model
                generate_voice_id = wx_api_module.generate_voice_id

                # 生成 voice_id
                model_name = train_tasks[task_id].get("model_name", f"voice_{task_id[:8]}")
                voice_id = generate_voice_id()

                # 获取场景和情感信息
                scene = train_tasks[task_id].get("scene", "")
                emotion = train_tasks[task_id].get("emotion", "")

                # 获取参考音频和文本（从训练任务中）
                ref_audio_path = train_tasks[task_id].get("ref_audio_path")
                ref_text = train_tasks[task_id].get("ref_text")
                ref_language = train_tasks[task_id].get("ref_language", params.language)

                # 注册模型（包含参考音频和文本）
                registered = register_voice_model(
                    voice_id=voice_id,
                    model_name=model_name,
                    gpt_path=str(gpt_path),
                    sovits_path=str(sovits_path),
                    scene=scene,
                    emotion=emotion,
                    trained_at=time.strftime('%Y-%m-%dT%H:%M:%S'),
                    ref_audio_path=ref_audio_path,
                    ref_text=ref_text,
                    ref_language=ref_language,
                    model_type="user_trained",
                    owner_user_id=params.user_id,
                )

                if registered:
                    registration_ok = True
                    train_tasks[task_id]["voice_id"] = voice_id
                    with open(log_path, "a", encoding="utf-8") as f:
                        f.write(f"\n模型已注册：voice_id={voice_id}, name={model_name}\n")

                    # 只保留本次有效训练产物，清理该用户历史 SoVITS 权重。
                    try:
                        keep_paths = {str(sovits_path)} | _collect_registered_sovits_paths_for_user(params.user_id)
                        _cleanup_user_stale_sovits_weights(
                            user_id=params.user_id,
                            version=params.model_version,
                            keep_paths=keep_paths,
                            current_task_id=task_id,
                            log_path=log_path,
                            remove_only_invalid=False,
                        )
                    except Exception as cleanup_keep_err:
                        logger.warning(f"[SoVITS清理] 保留本次产物时清理旧文件失败: {cleanup_keep_err}")
                else:
                    registration_error = "模型注册失败"
                    with open(log_path, "a", encoding="utf-8") as f:
                        f.write(f"\n警告：模型注册失败\n")
            except Exception as e:
                import traceback
                registration_error = str(e)
                with open(log_path, "a", encoding="utf-8") as f:
                    f.write(f"\n警告：注册模型时出错：{str(e)}\n")
                    f.write(f"错误详情：{traceback.format_exc()}\n")
                print(f"[WARNING] 注册模型失败: {str(e)}")

        if registration_ok:
            train_tasks[task_id]["status"] = "completed"
            train_tasks[task_id]["progress"] = 100
            if not _skip_reg:
                train_tasks[task_id]["message"] = "训练完成！模型已注册，可直接应用。"
        else:
            train_tasks[task_id]["status"] = "failed"
            train_tasks[task_id]["progress"] = 100
            train_tasks[task_id]["message"] = f"训练完成但注册失败: {registration_error or '未知错误'}"

        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n训练完成：{time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"GPT模型：{gpt_path}\n")
            f.write(f"SoVITS模型：{sovits_path}\n")
        
    except Exception as e:
        error_msg = str(e)
        train_tasks[task_id]["status"] = "failed"
        train_tasks[task_id]["message"] = f"训练失败: {error_msg}"
        train_tasks[task_id]["progress"] = train_tasks[task_id].get("progress", 0)
        
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(f"\n训练失败：{error_msg}\n")
            try:
                # 确保traceback可用
                import traceback as tb
                f.write(f"错误详情：{tb.format_exc()}\n")
            except Exception as tb_err:
                f.write(f"错误类型：{type(e).__name__}\n")
                f.write(f"错误信息：{str(e)}\n")
                f.write(f"无法获取详细堆栈：{str(tb_err)}\n")
        
        # 清理训练失败的缓存文件（仅在预处理阶段失败时清理）
        # 如果已经进入GPT或SoVITS训练阶段，说明预处理成功，不应该清理
        try:
            if 'exp_dir' in locals() and exp_dir:
                # 检查是否已经进入GPT训练阶段（通过检查是否有GPT权重目录）
                gpt_weight_dir = _get_versioned_path("GPT_weight_version2root", train_tasks[task_id].get("version", "v2Pro"), "GPT_weights_v2Pro")
                gpt_trained = False
                if gpt_weight_dir.exists():
                    # 检查是否有训练好的GPT模型
                    gpt_files = list(gpt_weight_dir.glob(f"{exp_name}*.ckpt"))
                    if gpt_files:
                        gpt_trained = True
                
                # 只有在预处理阶段失败时才清理缓存
                # 如果GPT或SoVITS训练失败，保留预处理结果以便重新训练
                current_progress = train_tasks[task_id].get("progress", 0)
                # 预处理阶段：0-60%（BERT、HuBERT、SV、Semantic提取）
                # GPT训练阶段：60-80%
                # SoVITS训练阶段：80-100%
                if current_progress < 60:  # 预处理阶段失败
                    _cleanup_failed_training_cache(exp_dir, keep_logs=True)
                    with open(log_path, "a", encoding="utf-8") as f:
                        f.write(f"\n已清理训练失败的缓存文件（预处理阶段失败，progress={current_progress}%）\n")
                else:  # GPT或SoVITS训练失败
                    with open(log_path, "a", encoding="utf-8") as f:
                        f.write(f"\n保留预处理结果（GPT/SoVITS训练失败，progress={current_progress}%，可重新训练）\n")
        except Exception as cleanup_err:
            print(f"清理缓存失败: {cleanup_err}")
            with open(log_path, "a", encoding="utf-8") as f:
                f.write(f"清理缓存失败: {cleanup_err}\n")
        
        print(f"[ERROR] 训练任务 {task_id} 失败: {error_msg}")
    finally:
        _r_fin = _train_phase_get()
        if _r_fin is not None:
            try:
                _st = train_tasks.get(task_id, {}).get("status", "")
            except Exception:
                _st = ""
            _r_fin.emit("run_finished_wall", _r_fin.elapsed(), final_task_status=_st)
        _train_phase_set(None)


# ==================== 缓存清理函数 ====================
def _cleanup_failed_training_cache(exp_dir: Path, keep_logs: bool = True):
    """清理训练失败时的缓存文件
    
    Args:
        exp_dir: 实验目录路径（processed目录）
        keep_logs: 是否保留日志文件（默认True）
    """
    if not exp_dir or not exp_dir.exists():
        return
    
    cleanup_dirs = [
        "1-bert",           # BERT特征
        "2-name2text",      # 文本特征目录
        "3-bert",           # BERT特征（另一个目录）
        "4-cnhubert",       # HuBERT特征
        "5-wav32k",         # 32k音频
        "6-name2semantic",  # 语义token
    ]
    
    cleanup_files = [
        "2-name2text.txt",
        "6-name2semantic.tsv",
        "6-name2semantic-0.tsv",
    ]
    
    print(f"清理训练失败缓存: {exp_dir}")
    
    # 清理目录
    for dir_name in cleanup_dirs:
        dir_path = exp_dir / dir_name
        if dir_path.exists():
            try:
                shutil.rmtree(dir_path)
                print(f"  已删除目录: {dir_name}")
            except Exception as e:
                print(f"  删除目录失败 {dir_name}: {e}")
    
    # 清理文件
    for file_name in cleanup_files:
        file_path = exp_dir / file_name
        if file_path.exists():
            try:
                file_path.unlink()
                print(f"  已删除文件: {file_name}")
            except Exception as e:
                print(f"  删除文件失败 {file_name}: {e}")
    
    # 保留日志文件
    if keep_logs:
        log_files = list(exp_dir.glob("*.log"))
        for log_file in log_files:
            print(f"  保留日志文件: {log_file.name}")


# ==================== 进程清理函数 ====================
def cleanup_all_processes():
    """清理所有活跃的训练进程，释放GPU资源"""
    print("正在清理所有训练进程...")
    killed_count = 0
    
    # 清理注册的进程
    for task_id, process in list(active_processes.items()):
        try:
            if process.poll() is None:  # 进程还在运行
                print(f"  终止任务 {task_id} 的进程 (PID: {process.pid})")
                try:
                    process.terminate()
                    time.sleep(1)
                    if process.poll() is None:
                        process.kill()  # 强制终止
                    killed_count += 1
                except Exception as e:
                    print(f"    终止进程失败: {e}")
        except Exception as e:
            print(f"  检查进程状态失败 {task_id}: {e}")
    
    # 清空进程列表
    active_processes.clear()
    
    # 清理所有训练相关的Python进程（包括子进程）
    try:
        import psutil
        current_pid = os.getpid()
        for proc in psutil.process_iter(['pid', 'name', 'cmdline']):
            try:
                cmdline = proc.info.get('cmdline', [])
                if cmdline and any('prepare_datasets' in str(c) or 's1_train.py' in str(c) or 's2_train.py' in str(c) for c in cmdline):
                    if proc.info['pid'] != current_pid:
                        print(f"  终止训练子进程 (PID: {proc.info['pid']})")
                        proc.terminate()
                        time.sleep(0.5)
                        if proc.is_running():
                            proc.kill()
                        killed_count += 1
            except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
                pass
    except ImportError:
        # 如果没有psutil，使用subprocess查找
        try:
            result = subprocess.run(
                ['pgrep', '-f', 'prepare_datasets|s1_train.py|s2_train.py'],
                capture_output=True,
                text=True
            )
            if result.returncode == 0:
                for pid_str in result.stdout.strip().split('\n'):
                    if pid_str:
                        try:
                            pid = int(pid_str)
                            if pid != os.getpid():
                                print(f"  终止训练子进程 (PID: {pid})")
                                os.kill(pid, 15)  # SIGTERM
                                time.sleep(0.5)
                                try:
                                    os.kill(pid, 9)  # SIGKILL if still running
                                except:
                                    pass
                                killed_count += 1
                        except (ValueError, ProcessLookupError, PermissionError):
                            pass
        except:
            pass
    
    # 清理GPU缓存
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
        print("  GPU缓存已清理")
    
    print(f"清理完成，共终止 {killed_count} 个进程")
    return killed_count

