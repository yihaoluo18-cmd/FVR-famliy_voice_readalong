# 示例配置模板（不要在此文件中填真实密钥）。
# 使用方式：
# 1) 复制为 wx_api.env
# 2) 在 wx_api.env 中填入真实值

# 统一 AI 开关
SAFETY_AI_ENABLED=1

# 统一密钥（主变量）
AI_API_KEY=
# AI_API_KEY=sk-你的真实密钥

# OpenAI-compatible 网关（建议 DashScope）
AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 文本模型默认值（所有文本任务默认走这里）
AI_MODEL_TEXT_DEFAULT="qwen-plus"

# 按功能分配模型（全部要求为 qwen 系列）
AI_MODEL_SAFETY="qwen-plus"
AI_MODEL_STORY="qwen-plus"
AI_MODEL_READALONG_EVAL="qwen-turbo"
AI_MODEL_VISION="qwen-vl-plus"

# 兼容旧变量（可选，不配也可运行）
SAFETY_AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
SAFETY_AI_MODEL="qwen-plus"
SAFETY_AI_API_KEY=

# 生图（统一 Qwen）
AI_MODEL_IMAGE_GEN="qwen-vl-turbo"

# 调用外部 API 走本机代理（按需开启）
IMAGINE_PROXY=http://127.0.0.1:7890

# 旧生图提供商（VOLC/WANX）已停用，不再建议配置
# VOLC_ACCESSKEY=
# VOLC_SECRETKEY=
# WANX_API_KEY=

# 审核超时（秒）
SAFETY_AI_TIMEOUT_SEC=6

# 审核服务异常时是否拒绝合成：1=拒绝，0=放行（默认 0）
SAFETY_AI_FAIL_CLOSED=0

# 文本过长截断长度（字符），默认 5000
SAFETY_AI_MAX_CHARS=5000

# 缓存（秒/条数），降低重复文本请求成本
SAFETY_AI_CACHE_TTL_SEC=120
SAFETY_AI_CACHE_MAX=1024

# 图片生成绘本（多模态/视觉模型）
STORY_VISION_MODEL="qwen-vl-plus"

# 视觉识别超时（秒）：建议明显大于 SAFETY_AI_TIMEOUT_SEC，避免图片描述超时
STORY_VISION_TIMEOUT_SEC=60

# 视觉模型兜底列表（逗号分隔）：主模型失败/超时时会自动重试
# 示例：STORY_VISION_FALLBACK_MODELS="qwen-vl-plus-latest,qwen-vl-max"
STORY_VISION_FALLBACK_MODELS=""

# 绘本故事生成（LLM）
STORY_GEN_ENABLED=1
# 0=无有效大模型时直接报错，避免输出低质量兜底故事；1=允许退回启发式文案
STORY_GEN_ALLOW_HEURISTIC_FALLBACK=1
STORY_GEN_TIMEOUT_SEC=20
STORY_GEN_MAX_TOKENS=520
READALONG_ASR_GRACE_WAIT_SEC=8

# readalong ASR 启动阻塞预热：1=等待ASR加载完成再对外服务
READALONG_ASR_WARMUP_BLOCKING=1
READALONG_WAKE_MAX_WAIT_SEC=25
READALONG_WAKE_CHECK_INTERVAL_SEC=0.5
# ASR 识别质量参数（绘本描述建议）
READALONG_ASR_MODEL=small
READALONG_ASR_BEAM_SIZE=5
READALONG_ASR_VAD_FILTER=1
READALONG_ASR_REFINE_WITH_AI=1
READALONG_ASR_INITIAL_PROMPT="儿童普通话朗读，输出简体中文。"

READALONG_HF_ENDPOINT="https://hf-mirror.com"

AI_MODEL_AUDIO_DEFAULT="qwen-omni-turbo"
AI_MODEL_READALONG_ASR="qwen-omni-turbo"
AI_MODEL_READALONG_TTS="qwen-omni-turbo"
AI_TTS_VOICE="Cherry"
