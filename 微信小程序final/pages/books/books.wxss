  height: 100%;
  transform: skewX(-12deg);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
  z-index: 2;
}

.category-book-title {
  color: #2f2647;
  font-size: 27rpx;
  font-weight: 760;
  line-height: 1.32;
  text-align: center;
