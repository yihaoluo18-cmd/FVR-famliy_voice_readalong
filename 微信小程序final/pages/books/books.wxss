.active-category-header {
  margin-top: 20rpx;
}

/* 分类书屋（第一步） */
.category-houses-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 22rpx;
}

.category-houses-row {
  display: inline-flex;
  align-items: stretch;
  gap: 22rpx;
  padding: 4rpx 8rpx 18rpx;
}

.category-floating-paused .category-house-card {
  animation-play-state: paused;
}

.category-house-card {
  width: 248rpx;
  min-height: 380rpx;
  border-radius: 46rpx;
  padding: 24rpx 22rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 14rpx 30rpx rgba(125, 104, 171, 0.12),
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
  transition: transform 180ms ease, box-shadow 180ms ease;
  /* 参差不齐 + 漂浮：更“自由”的书屋 */
  --rz: 0deg;
  --baseY: 0rpx;
  --s: 1;
  transform: translateY(var(--baseY)) rotateZ(var(--rz)) scale(var(--s));
  transform-origin: center 70%;
  animation: categoryFloat 4.2s ease-in-out infinite;
  will-change: transform;
}

.category-house-card.active {
  transform: translateY(calc(var(--baseY) - 10rpx)) rotateZ(var(--rz)) scale(calc(var(--s) * 1.01));
  box-shadow:
    0 20rpx 36rpx rgba(107, 125, 197, 0.22),
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.7);
}

.category-float-0 { animation-delay: -0.0s; --baseY: 0rpx;  --rz: -1.1deg; --s: 1.00; }
.category-float-1 { animation-delay: -1.0s; --baseY: 12rpx; --rz: 0.8deg;  --s: 1.01; }
.category-float-2 { animation-delay: -2.0s; --baseY: -8rpx; --rz: -0.7deg; --s: 0.99; }
.category-float-3 { animation-delay: -3.0s; --baseY: 16rpx; --rz: 1.2deg;  --s: 1.00; }

@keyframes categoryFloat {
  0%, 100% {
    transform: translateY(var(--baseY)) rotateZ(var(--rz)) scale(var(--s));
  }
  50% {
    transform: translateY(calc(var(--baseY) - 12rpx)) rotateZ(var(--rz)) scale(var(--s));
  }
}

.category-house-ghost {
  position: absolute;
  top: 34rpx;
  right: 20rpx;
  font-size: 80rpx;
  opacity: 0.22;
  filter: grayscale(12%);
}

.category-house-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.category-house-title {
  color: #243047;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.18;
  /* 短标签更利落 */
  max-width: 200rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-house-desc {
  color: rgba(36, 48, 71, 0.66);
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.35;
}

.category-house-progress-track {
  margin-top: 14rpx;
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  overflow: hidden;
}

.category-house-progress {
  height: 100%;
  border-radius: 999rpx;
  min-width: 8rpx;
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.3) inset;
}

.category-house-count {
  margin-top: 10rpx;
  color: rgba(36, 48, 71, 0.74);
  font-size: 24rpx;
  font-weight: 760;
}

/* 第二步：当前分类书单改为图二风格的双列立体书卡 */
.category-book-list {
  display: grid;
  grid-template-columns: repeat(2, 280rpx);
  justify-content: space-between;
  column-gap: 64rpx;
  row-gap: 48rpx;
  padding: 12rpx 14rpx 34rpx;
}

.category-book-card {
  position: relative;
  border-radius: 24rpx;
  overflow: visible;
  padding-bottom: 14rpx;
  transform: translateZ(0);
  transform-style: preserve-3d;
  perspective: 1000rpx;
  will-change: transform;
  transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), filter 180ms ease;
}

.category-book-card:hover {
  transform: translateY(-2rpx) scale(1.015);
  z-index: 8;
  filter: drop-shadow(0 6rpx 10rpx rgba(101, 79, 156, 0.14));
}

.category-book-card-hover {
  transform: translateY(-2rpx) scale(1.015);
  z-index: 8;
  filter: drop-shadow(0 6rpx 10rpx rgba(101, 79, 156, 0.16));
}

.category-book-card:active {
  transform: translateY(0) scale(0.992);
  filter: drop-shadow(0 4rpx 8rpx rgba(101, 79, 156, 0.12));
  z-index: 3;
}

.category-book-cover-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 12rpx 0 rgba(205, 195, 234, 0.84),
    0 24rpx 32rpx rgba(99, 79, 150, 0.2),
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
  transform: perspective(1000rpx) rotateY(-11deg) translateX(6rpx);
  transform-origin: left center;
  transition: box-shadow 180ms ease;
}

.category-book-cover-wrap .category-book-cover {
  object-position: center top;
}

.category-book-cover-wrap::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: -13rpx;
  width: 22rpx;
  height: calc(100% - 26rpx);
  border-radius: 14rpx 10rpx 10rpx 14rpx;
  background: linear-gradient(180deg, rgba(225, 214, 252, 0.98), rgba(186, 169, 236, 0.98));
  box-shadow:
    5rpx 0 14rpx rgba(104, 74, 167, 0.26),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  z-index: 3;
}

.category-book-cover-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  z-index: 3;
}

.category-book-click-flash {
  position: absolute;
  left: -30%;
  top: 0;
  width: 46%;
  height: 100%;
  border-radius: 22rpx;
  background: linear-gradient(
    105deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.82) 45%,
    rgba(255, 255, 255, 0) 100%
  );
  transform: skewX(-18deg) translateX(0);
  opacity: 0;
  pointer-events: none;
  z-index: 4;
}

.category-book-card:hover .category-book-cover-wrap {
  box-shadow:
    0 10rpx 0 rgba(205, 195, 234, 0.82),
    0 20rpx 30rpx rgba(99, 79, 150, 0.2),
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.92);
}

.category-book-card-hover .category-book-cover-wrap {
  box-shadow:
    0 10rpx 0 rgba(205, 195, 234, 0.82),
    0 20rpx 30rpx rgba(99, 79, 150, 0.22),
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.92);
}

.category-book-card:active .category-book-click-flash {
  opacity: 1;
  animation: clickFlashSweep 360ms ease-out 1;
}

.category-book-card::after {
  content: none;
}

.category-book-card::before {
  content: '';
  position: absolute;
  left: 18rpx;
  right: 8rpx;
  top: 328rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(86, 70, 132, 0.16);
  filter: blur(6rpx);
  z-index: 0;
  pointer-events: none;
}

.category-book-main {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 86rpx;
  position: relative;
  z-index: 2;
  align-items: center;
  text-align: center;
}

.category-book-cover {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  background: #fff5f7;
}

.category-book-cover-gloss {
  position: absolute;
  top: 0;
  left: -8%;
