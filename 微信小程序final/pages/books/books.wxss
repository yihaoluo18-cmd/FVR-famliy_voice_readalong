/* AI书架部分 */
.ai-stories-section {
  min-height: 400rpx;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.bookshelf-container {
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.bookshelf-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.sparkle-icon {
  font-size: 40rpx;
}

.bookshelf-title {
