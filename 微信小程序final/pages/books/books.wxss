.guide-pulse {
  position: relative;
  z-index: 1001;
  isolation: isolate;
  animation: guidePulseRing 1.15s ease-in-out infinite;
}

@keyframes guidePulseRing {
  0%,
  100% {
    box-shadow: 0 0 0 3rpx rgba(240, 163, 194, 0.95), 0 6rpx 18rpx rgba(232, 121, 169, 0.16);
  }
  50% {
    box-shadow: 0 0 0 5rpx rgba(240, 163, 194, 0.62), 0 8rpx 22rpx rgba(232, 121, 169, 0.2);
  }
}

.guide-dim {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 20, 30, 0.35);
}

.guide-card-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1002;
  padding: 28rpx;
  box-sizing: border-box;
}

.guide-card {
  width: 100%;
  border-radius: 28rpx;
  background: #fff;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 -10rpx 36rpx rgba(0, 0, 0, 0.1);
}

.guide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f0a3c2;
  margin-bottom: 10rpx;
}

.guide-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #a84f74;
}

.guide-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.guide-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.guide-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.guide-btn.ghost {
  background: #f3f4f6;
  color: #6b7280;
}

.guide-btn.primary {
  background: #f0a3c2;
  color: #fff;
}
/* 容器 */
.container {
  min-height: 100vh;
  background:
    radial-gradient(360rpx 240rpx at 94% -4%, rgba(225, 196, 255, 0.36), rgba(225, 196, 255, 0)),
    radial-gradient(420rpx 280rpx at 0% 98%, rgba(203, 232, 255, 0.28), rgba(203, 232, 255, 0)),
    radial-gradient(280rpx 180rpx at 54% 38%, rgba(255, 223, 242, 0.2), rgba(255, 223, 242, 0)),
    linear-gradient(164deg, rgba(249, 242, 255, 0.98), rgba(242, 236, 255, 0.92) 45%, rgba(252, 247, 255, 0.97));
  padding: 32rpx;
  padding-bottom: 140rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  animation: slideDown 0.5s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-32rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.book-icon {
  font-size: 44rpx;
}

.header-text {
  color: #f0a3c2;
  font-size: 26rpx;
  font-weight: 900;
  flex: 1;
}

.star-icon {
  font-size: 32rpx;
}

/* AI横幅 */
.ai-banner {
  position: relative;
  background: linear-gradient(135deg, #fbcfe8 0%, #f0a3c2 100%);
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(240, 163, 194, 0.3);
  overflow: hidden;
  animation: scaleIn 0.5s ease-out;
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.banner-deco-top {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 120rpx;
  opacity: 0.2;
}

.banner-deco-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  font-size: 100rpx;
  opacity: 0.2;
}

.banner-content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.banner-icon-box {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.rotateClass {
  animation: rotate 3s ease-in-out infinite;
}

@keyframes rotate {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(10deg); }
  75% { transform: rotate(-10deg); }
}

.banner-icon {
  font-size: 56rpx;
}

.banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-title {
  color: white;
  font-size: 32rpx;
  font-weight: 900;
}

.banner-subtitle {
  color: #fef3c7;
  font-size: 24rpx;
  font-weight: 700;
}

.banner-button {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(10rpx);
}

.button-text {
  color: white;
  font-size: 22rpx;
  font-weight: 900;
}

/* 标签切换器 */
.tab-switcher {
  background: rgba(243, 232, 255, 0.8);
  border-radius: 32rpx;
  padding: 12rpx;
  display: flex;
  gap: 12rpx;
  border: 4rpx solid #fce7f3;
  margin-bottom: 48rpx;
}

.tab-item {
  position: relative;
  flex: 1;
  padding: 24rpx 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(to right, #f0a3c2, #e879a9);
  box-shadow: 0 8rpx 24rpx rgba(240, 163, 194, 0.3);
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 900;
}

.tab-item.active .tab-text {
  color: white;
}

.tab-item:not(.active) .tab-text {
  color: #f472b6;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fbbf24;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 900;
  color: #e879a9;
}

.badge-text {
  color: #e879a9;
  font-size: 20rpx;
  font-weight: 900;
}

/* 绘本列表 */
.books-list {
  display: flex;
  flex-direction: column;
  gap: 80rpx;
}

/* 精选阅读计划与最近阅读 */
.featured-reading-sections {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.featured-recommend-section,
.featured-recent-section {
  background: rgba(255, 255, 255, 0.56);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 34rpx;
  padding: 22rpx 18rpx 16rpx;
  box-shadow:
    0 10rpx 24rpx rgba(244, 194, 212, 0.12),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  overflow: hidden;
}

.featured-section-header {
  margin-bottom: 16rpx;
}

.featured-divider {
  height: 2rpx;
  margin: 2rpx 14rpx;
  background: linear-gradient(
    90deg,
    rgba(252, 231, 243, 0),
    rgba(251, 207, 232, 0.45),
    rgba(252, 231, 243, 0)
  );
}

.featured-book-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 4rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.featured-book-row:last-child {
  margin-bottom: 2rpx;
}

.recent-reading-row {
  margin-bottom: 22rpx;
}

.featured-left-book {
  width: 168rpx;
  flex-shrink: 0;
}

.featured-left-book.category-book-card {
  padding-bottom: 0;
}

.featured-left-book.category-book-card::after {
  content: none;
}

.featured-left-book.category-book-card::before {
  left: 10rpx;
  right: 6rpx;
  top: 196rpx;
  height: 14rpx;
}

.featured-right-widget {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.recommend-shelf-board {
  position: relative;
  border-radius: 22rpx;
  padding: 14rpx 14rpx 10rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.62));
  box-shadow:
    0 12rpx 18rpx rgba(244, 194, 212, 0.14),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.65);
  /* 避免封面 3D 旋转导致边缘被裁掉出现“半本” */
  overflow: visible;
}

.recommend-shelf-board::after {
  content: '';
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 0;
  height: 16rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: linear-gradient(180deg, rgba(255, 251, 252, 0.85), rgba(252, 231, 243, 0.55));
}

.recommend-shelf-scroll {
  width: 100%;
  white-space: nowrap;
  position: relative;
  z-index: 2;
}

.recommend-shelf-row {
  display: inline-flex;
  align-items: flex-end;
  gap: 18rpx;
  /* 增加左右留白，保证首尾也能完整展示 */
  padding: 4rpx 18rpx 14rpx;
}

.recommend-book-item {
  width: 192rpx;
  height: 250rpx;
  border-radius: 18rpx;
  overflow: hidden;
  position: relative;
  background: #f2f2f2;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow:
    0 5rpx 10rpx rgba(232, 121, 169, 0.12),
    0 10rpx 0 rgba(252, 231, 243, 0.85);
  /* 轻一点的 3D 角度，减少 GPU 压力也更不容易被裁边 */
  --rz: 0deg;
  --baseY: 0rpx;
  --s: 1;
  transform: perspective(900rpx) rotateY(-4deg) rotateZ(var(--rz)) translateY(var(--baseY)) scale(var(--s));
  transform-origin: left center;
  transition: transform 180ms ease;
  /* 静止时轻微漂浮，让推荐更“活” */
  animation: recommendFloat 3.6s ease-in-out infinite;
  will-change: transform;
}

.recommend-book-item:active {
  transform: perspective(900rpx) rotateY(-8deg) rotateZ(var(--rz)) translateY(calc(var(--baseY) + 2rpx)) scale(calc(var(--s) * 0.98));
}

.recommend-floating-paused .recommend-book-item {
  animation-play-state: paused;
}

.recommend-float-0 { animation-delay: -0.0s; --baseY: 0rpx;  --rz: -1.2deg; --s: 1.00; }
.recommend-float-1 { animation-delay: -0.8s; --baseY: 10rpx; --rz: 0.9deg;  --s: 1.01; }
.recommend-float-2 { animation-delay: -1.6s; --baseY: -6rpx; --rz: -0.6deg; --s: 0.99; }
.recommend-float-3 { animation-delay: -2.4s; --baseY: 14rpx; --rz: 1.3deg;  --s: 1.00; }

@keyframes recommendFloat {
  0%, 100% { transform: perspective(900rpx) rotateY(-4deg) rotateZ(var(--rz)) translateY(var(--baseY)) scale(var(--s)); }
  50% { transform: perspective(900rpx) rotateY(-4deg) rotateZ(var(--rz)) translateY(calc(var(--baseY) - 10rpx)) scale(var(--s)); }
}

.recommend-book-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.recommend-book-gloss {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, rgba(255, 255, 255, 0.36), rgba(255, 255, 255, 0) 46%);
}

/* 书名小标签：跟随封面一起滚动 */
.recommend-book-tag {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  z-index: 3;
  max-width: calc(100% - 24rpx);
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(252, 231, 243, 0.95);
  box-shadow: 0 8rpx 18rpx rgba(244, 194, 212, 0.18);
}

.recommend-book-tag-text {
  display: block;
  color: rgba(184, 122, 148, 0.96);
  font-size: 26rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.1;
}

.continue-reading-card {
  width: 100%;
  border-radius: 34rpx 24rpx 26rpx 34rpx;
  /* 给“绘本封面”预留更完整的横向空间，避免封面与说明文字重叠 */
  padding: 16rpx 20rpx 18rpx 220rpx;
  position: relative;
  min-height: 262rpx;
  box-shadow:
    0 8rpx 16rpx rgba(244, 194, 212, 0.12),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.4);
  border: 2rpx solid rgba(252, 231, 243, 0.9);
}

.continue-reading-card::before {
  content: '';
  position: absolute;
  left: 118rpx;
  top: 54rpx;
  width: 42rpx;
  height: 54rpx;
  border-radius: 0 18rpx 18rpx 0;
  background: inherit;
  filter: brightness(0.97);
}

.continue-reading-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.continue-reading-encourage {
  color: rgba(58, 64, 83, 0.82);
  font-size: 19rpx;
  font-weight: 700;
}

.continue-reading-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.continue-reading-progress-line {
  width: 160rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  overflow: hidden;
}

.continue-reading-progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.continue-reading-percent {
  color: rgba(58, 64, 83, 0.7);
  font-size: 34rpx;
  transform: scale(0.65);
  transform-origin: right center;
  font-weight: 700;
}

.continue-reading-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  position: relative;
  /* 确保封面放大后仍能在卡片内完整展示 */
  min-height: 224rpx;
}

.continue-reading-cover {
  width: 170rpx;
  position: absolute;
  /* 与封面宽度略错开，给文字区域留出一点点空隙（避免阴影/圆角造成视觉“重叠”） */
  left: -178rpx;
  top: 50%;
  transform: translateY(-50%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 14rpx rgba(90, 78, 134, 0.18),
    0 0 0 2rpx rgba(255, 255, 255, 0.72);
}

.continue-reading-cover-image {
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  display: block;
}

.continue-reading-cover-title {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 12rpx 10rpx;
  background: linear-gradient(180deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.62));
  z-index: 2;
}

.continue-reading-cover-title-text {
  display: block;
  color: rgba(255, 255, 255, 0.96);
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.2rpx;
}

.continue-reading-note {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.continue-reading-info-card {
  width: 100%;
  max-width: 360rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  box-shadow:
    0 10rpx 18rpx rgba(90, 78, 134, 0.10),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.46);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.continue-reading-pos {
  display: block;
  color: rgba(31, 41, 55, 0.92);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.15;
  margin: 0;
  text-align: center;
}

.continue-reading-total {
  display: block;
  color: rgba(58, 64, 83, 0.76);
  font-size: 22rpx;
  font-weight: 800;
  margin-top: 0;
  text-align: center;
}

.continue-reading-dots {
  color: rgba(58, 64, 83, 0.55);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  margin-right: 4rpx;
}

.target-bullseye {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: rgba(255, 236, 247, 0.92);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(184, 93, 162, 0.16);
  z-index: 2;
}

.target-ring {
  position: absolute;
  border-radius: 50%;
  border: 3rpx solid #f472b6;
}

.ring-outer { width: 50rpx; height: 50rpx; opacity: 0.5; }
.ring-mid { width: 32rpx; height: 32rpx; opacity: 0.75; }
.ring-inner { width: 16rpx; height: 16rpx; background: #fb7185; border-color: #fb7185; opacity: 0.88; }

.sticky-note-3d {
  flex: 1;
  background: linear-gradient(160deg, #fff3c8, #ffe7a8);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 246, 214, 0.95);
  padding: 18rpx 18rpx 16rpx;
  box-shadow:
    0 6rpx 0 rgba(233, 213, 152, 0.88),
    0 12rpx 18rpx rgba(150, 129, 79, 0.12);
  min-height: 138rpx;
}

.plan-note {
  position: relative;
  padding-top: 22rpx;
  padding-left: 42rpx;
}

.plan-note .target-bullseye {
  position: absolute;
  left: -18rpx;
  top: -18rpx;
}

.sticky-line {
  display: block;
  color: #5f4a2d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.progress-rings {
  margin-top: 12rpx;
  display: flex;
  gap: 14rpx;
}

.progress-ring {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  position: relative;
  background: conic-gradient(
    rgba(105, 125, 245, 0.85) calc(var(--ring-progress, 0) * 1%),
    rgba(255, 255, 255, 0.12) 0
  );
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 4rpx 10rpx rgba(108, 123, 203, 0.12);
}

.progress-ring:nth-child(2) {
  background: conic-gradient(
    rgba(52, 195, 164, 0.86) calc(var(--ring-progress, 0) * 1%),
    rgba(255, 255, 255, 0.12) 0
  );
}

.progress-ring::before {
  content: '';
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.36);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: inset 0 2rpx 8rpx rgba(140, 122, 206, 0.14);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.ring-fill {
  display: none;
}

.ring-label {
  position: absolute;
  color: #5a5795;
  font-size: 17rpx;
  font-weight: 800;
}

.reading-hand-note {
  display: block;
  width: 100%;
}

.reading-hand-icon {
  font-size: 46rpx;
}

.recent-note-unified {
  position: relative;
  padding-top: 26rpx;
  padding-left: 44rpx;
  min-height: 160rpx;
}

.note-corner-icon {
  position: absolute;
  left: -14rpx;
  top: -18rpx;
  font-size: 48rpx;
  line-height: 1;
}

/* 计划区书卡缩小约40%，尺寸与间距仍沿用书架风格 */
.featured-left-book .category-book-cover-wrap {
  height: 192rpx;
  border-radius: 18rpx;
}

.featured-left-book .category-book-cover {
  border-radius: 18rpx;
}

.featured-left-book .category-book-main {
  margin-top: 12rpx;
  min-height: 48rpx;
}

.featured-left-book .category-book-title {
  font-size: 26rpx;
  line-height: 1.2;
  margin: 0;
}

.book-card-wrapper {
  position: relative;
  animation: fadeInUp 0.5s ease-out both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.book-card {
  border-radius: 64rpx;
  overflow: hidden;
  border: 4rpx solid white;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.book-card:active {
  transform: scale(0.98);
}

/* 不同绘本的渐��背景 */
.book-forest {
  background: linear-gradient(135deg, #fffbeb 0%, #fde68a 100%);
}

.book-ocean {
  background: linear-gradient(135deg, #fff1f2 0%, #fbcfe8 100%);
}

.book-stars {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
}

.book-city {
  background: linear-gradient(135deg, #fef3c7 0%, #fde047 100%);
}

.book-dinosaur {
