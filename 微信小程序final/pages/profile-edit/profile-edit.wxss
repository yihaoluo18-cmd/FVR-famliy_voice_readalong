/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #fdf2f8, #fff);
  padding-bottom: 120rpx;
}

/* 粉色顶部横幅 */
.header-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(160deg, #e879a9 0%, #e879a9 100%);
  margin-bottom: 32rpx;
}

/* 头像区域 */
.avatar-section {
  position: relative;
  margin-bottom: 24rpx;
  animation: scaleIn 0.5s ease-out;
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1); }
}

.avatar-container {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid white;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.camera-button {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 72rpx;
  height: 72rpx;
  background: #f0a3c2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s;
}

.camera-button:active {
  transform: scale(0.9);
}

.camera-icon {
  font-size: 36rpx;
}

.page-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sparkle {
  color: #fde047;
  font-size: 28rpx;
}

.title-text {
  color: white;
  font-size: 32rpx;
  font-weight: 900;
}

/* 头像选择器 */
.avatar-picker {
  margin: 0 32rpx 32rpx;
  background: white;
  padding: 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(240, 163, 194, 0.15);
  border: 4rpx solid #fce7f3;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.picker-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 32rpx;
}

.picker-title .title-text {
  color: #b87a94;
  font-size: 28rpx;
  font-weight: 900;
}

.avatars-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.avatar-option {
  aspect-ratio: 1;
  border-radius: 32rpx;
  overflow: hidden;
  border: 6rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.avatar-option:active {
  transform: scale(0.9);
}

.avatar-option.selected {
  border-color: #f0a3c2;
  box-shadow: 0 4rpx 16rpx rgba(240, 163, 194, 0.3);
}

.option-image {
  width: 100%;
  height: 100%;
}

/* 编辑表单 */
.edit-form {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.form-item {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f9fafb;
  width:640rpx;
  margin-bottom: 10rpx;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.label-icon {
  font-size: 28rpx;
}

.item-label.purple {
  color: #e879a9;
}

.item-label.pink {
  color: #ec4899;
}

.item-label.blue {
  color: #b87a94;
}

.item-label.green {
  color: #ca8a04;
}

.item-label.orange {
  color: #f97316;
}

.item-input,
.item-picker {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: 4rpx solid;
}

.item-input.purple {
  background: #fdf2f8;
  border-color: #fce7f3;
  color: #831843;
  width: 610rpx;
}

.item-input.pink {
  background: #fef2f2;
  border-color: #fce7f3;
  color: #831843;
  width: 610rpx;
}

.item-input.blue {
  background: #fff5f7;
  border-color: #fce7f3;
  color: #b87a94;
  width: 610rpx;
}

.item-input.green {
  background: #fffbeb;
  border-color: #fef3c7;
  color: #92400e;
  width: 610rpx;
}

.item-input.orange {
  background: #fff7ed;
  border-color: #fed7aa;
  color: #7c2d12;
  width: 610rpx;
}

.item-picker.blue {
  background: #fff5f7;
  border-color: #fce7f3;
}

.picker-value {
  color: #b87a94;
  font-size: 30rpx;
  font-weight: 700;
}

.input-placeholder {
  color: #d1d5db;
  font-weight: 700;
}

/* 保存按钮 */
.save-button {
  margin-top: 16rpx;
  background: linear-gradient(to right, #f0a3c2, #ec4899);
  padding: 32rpx 0;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(240, 163, 194, 0.4);
  border: 4rpx solid white;
  transition: all 0.2s;
}

.save-button::after {
  border: none;
}

.save-button:active {
  transform: scale(0.97);
}

.save-icon {
  font-size: 40rpx;
}

.save-text {
  color: white;
  font-size: 32rpx;
  font-weight: 900;
}
