}

.mini-voice-item,
.mini-pet-item {
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: #f6f1ff;
  color: #4d4568;
  font-size: 22rpx;
  display: flex;
  align-items: center;
