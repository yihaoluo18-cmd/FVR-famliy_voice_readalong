.pet-entry-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pet-entry-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.25);
}

.pet-entry-arrow {
  font-size: 36rpx;
  color: #fbcfe8;
  font-weight: 700;
}

.avatar-option {
  position: relative;
}

.avatar-option-locked .option-image-dim {
  opacity: 0.55;
}

.avatar-frost {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  right: 8rpx;
  bottom: 52rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.avatar-frost-icon {
  font-size: 32rpx;
}

/* 3D按钮容器（保持原卡片尺寸） */
.metric-button-3d {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffffff, #e6e9ec);
  box-shadow: 
    8rpx 8rpx 16rpx rgba(0, 0, 0, 0.1),
    -8rpx -8rpx 16rpx rgba(255, 255, 255, 0.9),
    inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.8),
    inset -2rpx -2rpx 4rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.metric-button-3d {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  /* 中间圆形：紫粉渐变 + 超强立体浮雕 */
  background: radial-gradient(circle at 30% 30%, #f0e8ff 0%, #d9c8ff 40%, #bfa8ff 100%);
  box-shadow: 
    0 12rpx 22rpx rgba(180, 150, 255, 0.35),
    0 4rpx 8rpx rgba(180, 150, 255, 0.25),
    inset 0 -6rpx 8rpx rgba(140, 100, 255, 0.25),
    inset 0 6rpx 10rpx rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  position: relative;
}

/* 按下立体效果 */
.metric-button-3d:active {
  transform: scale(0.95);
  box-shadow: 
    0 6rpx 10rpx rgba(180, 150, 255, 0.25),
    inset 0 -4rpx 6rpx rgba(140, 100, 255, 0.2),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.7);
}

/* 按钮文字 */
.metric-button-text {
  font-size: 32rpx;
  font-weight: 900;
  color: #6c38b8;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 2;
}


.metric-card {
  flex: 1;
  background: linear-gradient(145deg, #f8f4ff 0%, #efe5ff 100%);
  border-radius: 36rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(140, 100, 255, 0.12);
  padding: 22rpx 18rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.guide-pulse {
  position: relative;
  z-index: 1001;
  isolation: isolate;
  animation: guidePulseRing 1.15s ease-in-out infinite;
}

@keyframes guidePulseRing {
  0%,
  100% {
    box-shadow: 0 0 0 3rpx rgba(240, 163, 194, 0.95), 0 6rpx 18rpx rgba(232, 121, 169, 0.16);
  }
  50% {
    box-shadow: 0 0 0 5rpx rgba(240, 163, 194, 0.62), 0 8rpx 22rpx rgba(232, 121, 169, 0.2);
  }
}

.guide-dim {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 20, 30, 0.35);
}

.guide-card-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1002;
  padding: 28rpx;
  box-sizing: border-box;
}

.guide-card {
  width: 100%;
  border-radius: 28rpx;
  background: #fff;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 -10rpx 36rpx rgba(0, 0, 0, 0.1);
}

.guide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f0a3c2;
  margin-bottom: 10rpx;
}

.guide-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #a84f74;
}

.guide-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.guide-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.guide-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.guide-btn.ghost {
  background: #f3f4f6;
  color: #6b7280;
}

.guide-btn.primary {
  background: #f0a3c2;
  color: #fff;
}
