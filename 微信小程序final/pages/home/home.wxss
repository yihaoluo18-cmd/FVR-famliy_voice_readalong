
/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #fdf2f8, #fff);
  padding: 32rpx;
  padding-bottom: 30rpx;
}

/* 顶部：伴宠 3D + 信息 */
.home-hero {
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
  margin: 10rpx 0 28rpx;
}

.home-pet-card {
  width: 330rpx;
  height: 360rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 30rpx rgba(232, 121, 169, 0.12);
  position: relative;
  overflow: visible;
}

.home-pet-card-switching {
  animation: homeCardSwitchPulse 0.9s ease-in-out infinite;
}

.home-pet-name {
  font-size: 50rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  margin-left: 30rpx;
  color: #ff8a4d;
  text-shadow: 0 3rpx 10rpx rgba(255, 180, 140, 0.35);

  position: relative;
  z-index: 1;
}
.home-tune-fab {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  z-index: 4;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(245, 236, 255, 0.72));
  border: 2rpx solid rgba(255, 255, 255, 0.94);
  color: #e879a9;
  font-size: 20rpx;
  font-weight: 800;
  box-shadow:
    0 8rpx 18rpx rgba(232, 121, 169, 0.18),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.75),
    inset 0 -2rpx 4rpx rgba(232, 121, 169, 0.08);
}

.home-tune-fab:active {
  transform: translateY(1rpx) scale(0.97);
}

.home-switch-fab {
  position: absolute;
  right: 94rpx;
  top: 12rpx;
  z-index: 4;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(245, 236, 255, 0.72));
  border: 2rpx solid rgba(255, 255, 255, 0.94);
  color: #e879a9;
  font-size: 20rpx;
  font-weight: 800;
  box-shadow:
    0 8rpx 18rpx rgba(232, 121, 169, 0.18),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.75),
    inset 0 -2rpx 4rpx rgba(232, 121, 169, 0.08);
}

.home-switch-fab:active {
  transform: translateY(1rpx) scale(0.97);
}

.home-pet-stage {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 44rpx;
  overflow: hidden;
}

.home-switching-overlay {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(165deg, rgba(255,255,255,0.28), rgba(255,248,250,0.18));
  backdrop-filter: blur(1px);
  -webkit-backdrop-filter: blur(1px);
  pointer-events: none;
}

.home-switching-ring {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(251,207,232,0.55);
  border-top-color: rgba(244,194,212,0.96);
  animation: homeSwitchSpin 0.75s linear infinite;
}

.home-switching-text {
  font-size: 20rpx;
  font-weight: 800;
  color: rgba(176,112,132,0.9);
  text-shadow: 0 2rpx 8rpx rgba(232,121,169,0.1);
  animation: homeSwitchTextPulse 1s ease-in-out infinite;
}

.home-pet-shadow {
  position: absolute;
  left: 50%;
  bottom: -12rpx;
  transform: translateX(-50%);
  width: 160rpx;
  height: 30rpx;
  background: rgba(251, 207, 232, 0.28);
  border-radius: 50%;
  filter: blur(10rpx);
}

.home-pet-meta {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

/* ===== 首页切换弹窗（居中） ===== */
.home-switch-mask{
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(17, 24, 39, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx;
  box-sizing: border-box;
}

.home-switch-modal{
  width: 620rpx;
  max-width: calc(100% - 36rpx);
  border-radius: 28rpx;
  background: rgba(255,255,255,0.92);
  border: 2rpx solid rgba(252, 231, 243, 0.9);
  box-shadow: 0 22rpx 70rpx rgba(232, 121, 169, 0.22);
  overflow: hidden;
}

.home-switch-header{
  display:flex;
  align-items:center;
  justify-content: space-between;
  padding: 20rpx 20rpx 12rpx;
}

.home-switch-title{
  font-size: 30rpx;
  font-weight: 900;
  color: #9d6b7f;
}

.home-switch-close{
  width: 54rpx;
  height: 54rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius: 999rpx;
  background: rgba(245, 236, 255, 0.8);
  border: 2rpx solid rgba(252, 231, 243, 0.9);
  color:#e879a9;
  font-weight: 900;
}

.home-switch-menu{
  padding: 10rpx 20rpx 22rpx;
  display:flex;
  flex-direction: column;
  gap: 14rpx;
}

.home-switch-item{
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(165deg, rgba(255,255,255,0.92), rgba(255,248,250,0.62));
  border: 2rpx solid rgba(252, 231, 243, 0.9);
}

.home-switch-item-title{
  display:block;
  font-size: 28rpx;
  font-weight: 900;
  color:#9d4e6e;
}

.home-switch-item-sub{
  display:block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(107,114,128,0.95);
  font-weight: 700;
}

.home-switch-body{
  padding: 8rpx 20rpx 22rpx;
}

.home-switch-back{
  display:inline-block;
  padding: 10rpx 10rpx;
  font-size: 22rpx;
  font-weight: 900;
  color:#f0a8c0;
}

.home-switch-grid{
  display:flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 10rpx;
}

.home-switch-mascot{
  width: 180rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.9);
  border: 2rpx solid rgba(252,231,243,0.95);
  padding: 12rpx;
  position: relative;
  box-sizing: border-box;
}

.home-switch-mascot-img{
  width: 100%;
  height: 120rpx;
  border-radius: 18rpx;
}

.home-switch-mascot-name{
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #ff8a4d;
  text-align:center;
}

.mascot-name-cute-dog { color: #f97316; }
.mascot-name-cute-fox { color: #fb7185; }
.mascot-name-cute-dino { color: #22c55e; }
.mascot-name-cute-cat { color: #a855f7; }
.mascot-name-cute-bunny { color: #ec4899; }
.mascot-name-cute-squirrel { color: #d97706; }
.mascot-name-cute-chick { color: #eab308; }
.mascot-name-cute-panda { color: #6b7280; }
.mascot-name-cute-koala { color: #65a30d; }
.mascot-name-cute-penguin { color: #0ea5e9; }

.home-switch-lock{
  position:absolute;
  right: 10rpx;
  top: 10rpx;
  font-size: 22rpx;
}

.home-switch-locked{
  opacity: 0.72;
}

.home-switch-img-dim{
  filter: grayscale(0.6);
  opacity: 0.72;
}

.home-form-grid{
  display:flex;
  gap: 16rpx;
  padding-top: 10rpx;
}

.home-form-card{
  flex: 1;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.94);
  border: 2rpx solid rgba(255,245,248,0.98);
  padding: 12rpx;
  position: relative;
  box-sizing: border-box;
  box-shadow: 0 4rpx 14rpx rgba(244, 194, 212, 0.08);
}

.home-form-poster{
  position: relative;
}

.home-form-poster-img{
  width: 100%;
  height: 150rpx;
  border-radius: 18rpx;
}

.home-form-badge{
  position:absolute;
  left: 10rpx;
  bottom: 10rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(252,231,243,0.98);
  border: 1rpx solid rgba(251,207,232,0.65);
  color:#b87a94;
  font-size: 20rpx;
  font-weight: 900;
}

.home-form-title{
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 900;
  color:#c9a8b5;
  text-align:center;
}

/* 整体状态布局 */
.status-grid {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  padding: 10rpx 0;
}

.status-row {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 圆形进度条外框 */
.status-circle {
  width: 100rpx;
  height: 100rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 👇 外圈灰色底（保留，用于承载进度条） */
.status-circle-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f3f4f6;
}

/* 👇 彩色进度条（保持不变） */
.status-circle-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(var(--color) var(--progress), transparent 0deg);
}

/* 中间渐变背景：基础样式 */
.status-circle::after {
  content: "";
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  z-index: 1;
}


.status-hunger .status-circle::after {
  background: linear-gradient(135deg, #ffd700, #ff6b35);
}


.status-clean .status-circle::after {
  background: linear-gradient(135deg, #fef3c7, #fbcfe8, #fce7f3, #fde68a);
}


.status-mood .status-circle::after {
  background: linear-gradient(135deg, #fbcfe8, #fde68a, #fef9c3);
}

.status-sleepy .status-circle::after {
  background: linear-gradient(135deg, #ff9a9e, #fad0c4, #ffecd2, #fcb69f);
}


.status-circle-content {
  position: relative;
  z-index: 999 !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.mini-emoji {
  font-size: 32rpx;
  margin-bottom: 2rpx;
  line-height: 1;
}

.status-percent {
  font-size: 20rpx;
  font-weight: bold;
  color: #fff; /* 改成白色，在渐变背景上更醒目 */
  line-height: 1;
}

.status-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.mini-ball {
  width: 70rpx;
  height: 70rpx;
  border-radius: 999rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 10rpx 20rpx rgba(232, 121, 169, 0.13),
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.84),
    inset 0 -4rpx 10rpx rgba(232, 121, 169, 0.08);
  background: linear-gradient(165deg, rgba(255, 255, 255, 0.82), rgba(245, 236, 255, 0.5));
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.mini-ball::before {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 12rpx;
  top: 8rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.2));
  filter: blur(0.5rpx);
  z-index: 2;
  pointer-events: none;
}

.mini-ball::after {
  content: "";
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  right: 16rpx;
  top: 18rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  z-index: 2;
  pointer-events: none;
}

.mini-liquid {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 999rpx;
  opacity: 0.95;
  transition: height 0.35s ease;
}

.mini-emoji {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  filter: drop-shadow(0 6rpx 10rpx rgba(0, 0, 0, 0.12));
  z-index: 3;
}

.mini-ball-food .mini-liquid { background: linear-gradient(180deg, #fde68a, #f59e0b); }
.mini-ball-clean .mini-liquid { background: linear-gradient(180deg, #fef9c3, #facc15); }
.mini-ball-mood .mini-liquid { background: linear-gradient(180deg, #fde68a, #fbbf24); }
.mini-ball-sleepy .mini-liquid { background: linear-gradient(180deg, #fef3c7, #f59e0b); }

.home-voice-row {
  display: flex;
  justify-content: flex-start;
  opacity: 0.98;
}

.home-tuning-panel {
  margin: 10rpx 0 24rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(160rpx 90rpx at 20% 8%, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0)),
    linear-gradient(150deg, rgba(255, 255, 255, 0.9), rgba(245, 236, 255, 0.72));
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 16rpx 32rpx rgba(232, 121, 169, 0.15),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.82),
    inset 0 -6rpx 14rpx rgba(232, 121, 169, 0.08);
  padding: 18rpx 18rpx 16rpx;
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}

.home-tuning-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.home-tuning-title {
  color: #b87a94;
  font-size: 22rpx;
  font-weight: 800;
}

.home-tuning-close {
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
}

.home-tune-row {
  margin: 8rpx 0 6rpx;
}

.home-tune-label {
  display: block;
  color: #4b5563;
  font-size: 21rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.home-tune-input-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.home-tune-input {
  /* 小程序 input 默认宽度不稳定，显式给宽，避免遮挡面板 */
  width: 240rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.75);
  font-size: 26rpx;
  font-weight: 800;
  box-shadow:
    0 8rpx 18rpx rgba(232, 121, 169, 0.08),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.75);
}

.home-tuning-actions {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.home-tuning-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  box-shadow:
    0 8rpx 16rpx rgba(232, 121, 169, 0.14),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.7);
}

.home-tuning-btn:active {
  transform: translateY(1rpx) scale(0.98);
}

.btn-light {
  color: #6b7280;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.88), rgba(243, 244, 246, 0.82));
}

.btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #f0a3c2, #e879a9);
}

/* 中部：两张进度卡 */
.home-metrics-row {
  display: flex;
  gap: 18rpx;
  margin: 0 0 26rpx;
}

.metric-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 36rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 22rpx 18rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.metric-ring {
  width: 150rpx;
  height: 150rpx;
  position: relative;
}

.metric-ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
  background: conic-gradient(from 0deg, rgba(252, 231, 243, 0.75) 0deg, rgba(252, 231, 243, 0.75) 360deg);
}

.metric-ring-fg {
  --p: 0;
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
  background: conic-gradient(from -90deg, rgba(251, 207, 232, 0.95) 0deg, rgba(244, 194, 212, 0.9) calc(var(--p) * 3.6deg), rgba(252, 231, 243, 0) 0deg);
  -webkit-mask: radial-gradient(transparent 56%, #000 57%);
  mask: radial-gradient(transparent 56%, #000 57%);
}

.metric-ring-yellow .metric-ring-fg { background: none; }
.metric-ring-fg-yellow {
  background: conic-gradient(from -90deg, rgba(254, 249, 195, 0.98) 0deg, rgba(253, 224, 71, 0.92) calc(var(--p) * 3.6deg), rgba(252, 231, 243, 0) 0deg);
  -webkit-mask: radial-gradient(transparent 56%, #000 57%);
  mask: radial-gradient(transparent 56%, #000 57%);
}

.metric-center {
  position: absolute;
  inset: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.8);
}

.metric-value {
  color: #9d6b7f;
  font-size: 34rpx;
  font-weight: 900;
}

.metric-sub {
  color: #a8989e;
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.metric-label {
  color: #a8989e;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

/* 四快捷入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-item-locked {
  opacity: 0.48;
  pointer-events: auto;
}

.quick-icon-ball {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 12rpx 24rpx rgba(232, 121, 169, 0.18),
    inset 0 6rpx 12rpx rgba(255, 255, 255, 0.9),
    inset 0 -6rpx 12rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  transition: all 0.2s ease;
}


.quick-icon-ball::before {
  content: "";
  position: absolute;
  left: 14rpx;
  right: 16rpx;
  top: 10rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, 
    rgba(255, 255, 255, 0.644), 
    rgba(255, 255, 255, 0.25)
  );
  z-index: 1;
  filter: blur(5rpx);
}


.quick-icon-ball::after {
  content: "";
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  right: 18rpx;
  top: 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  z-index: 1;
  filter: blur(2rpx); 
}
/* 🖱️ 按下时的3D按压效果 */
.quick-icon-ball:active {
  transform: translateY(2rpx) scale(0.96);
  box-shadow:
    0 6rpx 12rpx rgba(232, 121, 169, 0.12),
    inset 0 4rpx 8rpx rgba(0, 0, 0, 0.15),
    inset 0 -4rpx 8rpx rgba(255, 255, 255, 0.7);
}


/* 演说家（麦克风）：紫蓝渐变 → id = speaker */
.quick-icon-ball.ball-speaker {
  background: radial-gradient(circle at 30% 30%, #fef3c7 0%, #f472b6 40%, #e879a9 100%);
}

/* 涂色（蜡笔）：黄绿渐变 → id = color */
.quick-icon-ball.ball-color {
  background: radial-gradient(circle at 30% 30%, #fefce8 0%, #d9f99d 40%, #84cc16 100%);
}

/* 小柴伙伴（小狗）：暖棕渐变 → id = companion */
.quick-icon-ball.ball-companion {
  background: radial-gradient(circle at 30% 30%, #fef3c7 0%, #fcd34d 40%, #d97706 100%);
}

/* 宠物蛋（蛋）：橙黄渐变 → id = petEggGarden */
.quick-icon-ball.ball-petEggGarden {
  background: radial-gradient(circle at 30% 30%, #fff7ed 0%, #fac995 40%, #eeab87 100%);
}

.quick-icon {
  font-size: 44rpx;
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.15));
}

.quick-title {
  color: #a8989e;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

