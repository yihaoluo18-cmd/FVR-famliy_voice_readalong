/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f9ff, #fefce8 70%, #fdf2f8);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-sizing: border-box;
}

.list-mode,
.coloring-mode,
.title-bar,
.drawing-area,
.hint-card,
.color-palette,
.button-group,
.grid-item,
.canvas-container {
  box-sizing: border-box;
}

/* 列表模式 */
.list-mode {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  padding-bottom: 120rpx;
}

.fill-test-link {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #0d9488;
  text-decoration: underline;
}

/* 顶部横幅（模仿“小小演说家”） */
.header-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx 32rpx;
  background: linear-gradient(160deg, #f0a3c2 0%, #e879a9 100%);
  border-radius: 48rpx;
  box-shadow: 0 18rpx 60rpx rgba(232, 121, 169, 0.25);
  margin-bottom: 48rpx;
}

.crayon-icon-box {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.crayon-icon {
  font-size: 64rpx;
}

.page-title {
  margin-top: 0;
  margin-bottom: 8rpx;
  color: white;
  font-size: 40rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 0;
  color: #fef3c7;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

/* 顶部横幅进度条（模仿“小小演说家”） */
.progress-bar-container {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 24rpx;
  gap: 16rpx;
}

/* 模式切换（照搬“小小演说家”） */
.mode-switch {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  padding: 10rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
}

.mode-pill {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-pill.active {
  background: rgba(255, 255, 255, 0.95);
}

.mode-text {
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 900;
}

.mode-pill.active .mode-text {
  color: #e879a9;
}

.progress-label {
  color: #fef3c7;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  color: white;
  font-size: 24rpx;
  font-weight: 900;
}

/* 两个板块 */
.two-sections {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.section-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  padding: 20rpx;
  border: 4rpx solid #fce7f3;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.ai-section {
  border-color: #fce7f3;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(252, 231, 243, 0.65));
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.section-icon {
  font-size: 34rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #831843;
}

.ai-description {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.ai-steps {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.ai-step {
  font-size: 24rpx;
  color: #1f2937;
  font-weight: 700;
  padding-left: 10rpx;
}

.ai-badge {
  display: inline-block;
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 800;
  background: rgba(45, 212, 191, 0.18);
  border: 2rpx solid rgba(45, 212, 191, 0.35);
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
}

.part-selector.compact {
  margin: 8rpx 0 16rpx;
  padding: 10rpx 14rpx;
  border-radius: 28rpx;
  border-width: 3rpx;
}

/* 项目网格 */
.sketch-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
}

.grid-item {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(236, 72, 153, 0.1);
  border: 4rpx solid #fce7f3;
  transition: all 0.3s;
  animation: scaleIn 0.4s ease-out;
  position: relative;
}

.grid-item:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(236, 72, 153, 0.2);
}

.grid-thumbnail {
  width: 100%;
  height: 200rpx;
  display: block;
  background: #f3f4f6;
}

.grid-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: #be185d;
  padding: 16rpx 12rpx 4rpx;
}

.grid-age {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  padding: 0 12rpx 12rpx;
}

/* 题库分组 UI */
.bank-filter-bar {
  display: flex;
  justify-content: flex-start;
  gap: 16rpx;
  margin: 16rpx 0 12rpx;
}

.bank-filter-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.65);
  border: 4rpx solid rgba(243, 232, 255, 1);
  box-shadow: 0 8rpx 24rpx rgba(232, 121, 169, 0.08);
}

.bank-filter-btn.active {
  background: rgba(240, 163, 194, 0.18);
  border-color: rgba(240, 163, 194, 0.55);
  transform: scale(1.03);
}

.bank-filter-icon {
  font-size: 34rpx;
}

.bank-groups {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bank-category-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bank-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.bank-group-icon {
  font-size: 34rpx;
}

.bank-group-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #831843;
}

.bank-grid {
  margin-top: 6rpx;
}

.bank-thumb-wrap {
  position: relative;
}

.diff-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.15);
}

.diff-badge-text {
  font-size: 20rpx;
  font-weight: 900;
  color: #111827;
}

.diff-badge.simple {
  background: rgba(16, 185, 129, 0.22);
}

.diff-badge.medium {
  background: rgba(59, 130, 246, 0.22);
}

.diff-badge.hard {
  background: rgba(239, 68, 68, 0.22);
}

.bank-grid-title {
  padding-top: 10rpx;
  padding-bottom: 12rpx;
  font-size: 24rpx;
}

/* 小缩略图题库（模仿“小小演说家”） */
.bank-strip {
  margin: -24rpx 24rpx 24rpx;
  padding: 16rpx 0;
}

.bank-scroll {
  white-space: nowrap;
}

.bank-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 12rpx;
  width: 120rpx;
}

.bank-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 6rpx 20rpx rgba(240, 163, 194, 0.18);
  background: #fff;
}

.bank-qid {
  margin-top: 4rpx;
  font-size: 18rpx;
  font-weight: 900;
  color: #e879a9;
  display: block;
  width: 120rpx;
  max-width: 120rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  text-align: center;
}

/* 图片卡片（题目展示） */
.image-card {
  margin: 0 32rpx 48rpx;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(240, 163, 194, 0.2);
  border: 4rpx solid white;
  position: relative;
  animation: scaleIn 0.5s ease-out;
}

.story-image {
  width: 100%;
  height: 500rpx;
}

.image-prompt {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
  padding: 48rpx 32rpx 32rpx;
}

.prompt-text {
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.6;
}

.prompt-sub {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  line-height: 1.5;
}

/* 题库问题卡片（标签 + 简介 + 开始涂色） */
.question-card {
  margin: -16rpx 32rpx 40rpx;
  background: white;
  border-radius: 32rpx;
  padding: 28rpx;
  border: 2rpx solid #fce7f3;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 小小画室 */
.studio-section {
  margin: 0 32rpx 40rpx;
  border-radius: 40rpx;
  padding: 24rpx 22rpx 26rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.94) 0%, rgba(240, 253, 250, 0.65) 55%, rgba(255, 251, 235, 0.7) 100%);
  border: 4rpx solid rgba(251, 207, 232, 0.25);
  box-shadow: 0 18rpx 60rpx rgba(232, 121, 169, 0.10);
  overflow: hidden;
}

.studio-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.studio-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.studio-icon {
  font-size: 34rpx;
}

.studio-title {
  font-size: 30rpx;
  font-weight: 950;
  color: #831843;
}

.studio-subtitle {
  font-size: 22rpx;
  font-weight: 800;
  color: #e879a9;
  opacity: 0.85;
}

.studio-count {
  font-size: 22rpx;
  font-weight: 900;
  color: #0f766e;
  background: rgba(45, 212, 191, 0.14);
  border: 2rpx solid rgba(45, 212, 191, 0.22);
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
}

.studio-empty {
  padding: 24rpx 18rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 3rpx dashed rgba(236, 72, 153, 0.28);
  text-align: center;
}

.studio-empty-title {
  display: block;
  font-size: 26rpx;
  font-weight: 950;
  color: #be185d;
}

.studio-empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #6b7280;
  line-height: 1.5;
}

/* 展示架 */
.studio-rack {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 10rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 3rpx solid rgba(252, 231, 243, 0.9);
}

.rack-top {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.rack-title {
  font-size: 26rpx;
  font-weight: 950;
  color: #be185d;
}

.rack-hint {
  font-size: 22rpx;
  font-weight: 800;
  color: #9ca3af;
}

.rack-scroll {
  white-space: nowrap;
}

.rack-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 220rpx;
  margin-right: 14rpx;
}

.easel {
  position: relative;
  width: 220rpx;
  height: 260rpx;
}

.easel-leg {
  position: absolute;
  bottom: 0;
  width: 16rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #b45309 0%, #7c2d12 100%);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.18);
}
.easel-leg.left { left: 48rpx; transform: rotate(8deg); }
.easel-leg.right { right: 48rpx; transform: rotate(-8deg); }

.easel-crossbar {
  position: absolute;
  bottom: 72rpx;
  left: 34rpx;
  right: 34rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f59e0b 0%, #b45309 100%);
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.14);
}

.rack-caption {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #831843;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 画室删除按钮（右上角） */
.studio-delete {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(239, 68, 68, 0.82);
  border: 2rpx solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 12rpx 22rpx rgba(239, 68, 68, 0.35);
  backdrop-filter: blur(10rpx);
}
.studio-delete:active {
  transform: scale(0.96);
  opacity: 0.92;
}

/* 玻璃画框（通用） */
.glass-frame {
  position: absolute;
  left: 20rpx;
  top: 10rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background:
    radial-gradient(120% 120% at 15% 10%, rgba(255,255,255,0.72) 0%, rgba(255,255,255,0.30) 45%, rgba(255,255,255,0.10) 100%),
    linear-gradient(135deg, rgba(255,255,255,0.55) 0%, rgba(251,207,232,0.10) 55%, rgba(252,231,243,0.22) 100%);
  border: 6rpx solid rgba(255, 255, 255, 0.94);
  box-shadow:
    0 18rpx 45rpx rgba(0, 0, 0, 0.18),
    0 6rpx 0 rgba(232, 121, 169, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(22rpx) saturate(1.25);
  transform: translateZ(0);
}

.glass-frame:active {
  transform: translateY(2rpx) scale(0.98);
}

.glass-frame.mini {
  position: relative;
  left: 0;
  top: 0;
  width: 100%;
  height: 238rpx;
  border-radius: 26rpx;
}
.glass-frame.mini.tall {
  height: 308rpx;
}
.glass-frame.mini.portrait {
  height: 286rpx;
}
.glass-frame.mini.wide {
  height: 206rpx;
}
.glass-frame.mini.square {
  height: 238rpx;
}

.glass-frame.preview {
  position: relative;
  left: 0;
  top: 0;
  width: 100%;
  height: 640rpx;
  border-radius: 32rpx;
}

.glass-img {
  width: 100%;
  height: 100%;
  display: block;
}

.glass-shine {
  position: absolute;
  top: -30%;
  left: -40%;
  width: 60%;
  height: 160%;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.55) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-18deg);
  opacity: 0.55;
  pointer-events: none;
  animation: glassShineMove 3.4s ease-in-out infinite;
}

.glass-edge {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow: inset 0 0 0 2rpx rgba(236, 72, 153, 0.16);
  pointer-events: none;
}

.glass-frost {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(90% 70% at 20% 15%, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.08) 55%, rgba(255,255,255,0.02) 100%),
    linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 55%, rgba(255,255,255,0.10) 100%);
  mix-blend-mode: screen;
  opacity: 0.85;
  pointer-events: none;
}

.glass-glare {
  position: absolute;
  inset: 0;
  background: linear-gradient(125deg, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.10) 28%, rgba(255,255,255,0) 55%);
  opacity: 0.20;
  pointer-events: none;
  animation: glassGlarePulse 2.8s ease-in-out infinite;
}

.glass-spark {
  position: absolute;
  right: -20%;
  top: -10%;
  width: 60%;
  height: 60%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.0) 55%);
  opacity: 0.0;
  pointer-events: none;
  animation: glassSpark 4.8s ease-in-out infinite;
}

@keyframes glassShineMove {
  0% { left: -55%; opacity: 0.0; }
  15% { opacity: 0.55; }
  55% { left: 120%; opacity: 0.35; }
  100% { left: 120%; opacity: 0.0; }
}

@keyframes glassGlarePulse {
  0%, 100% { opacity: 0.16; }
  50% { opacity: 0.28; }
}

@keyframes glassSpark {
  0%, 65% { opacity: 0.0; transform: translate(0,0) scale(0.9); }
  75% { opacity: 0.22; transform: translate(-8rpx, 6rpx) scale(1.05); }
  85% { opacity: 0.10; transform: translate(-12rpx, 10rpx) scale(1.12); }
  100% { opacity: 0.0; transform: translate(-12rpx, 10rpx) scale(1.12); }
}

/* 仓库网格 */
.studio-warehouse {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 10rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 3rpx solid rgba(219, 234, 254, 0.85);
}

.warehouse-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.warehouse-title {
  font-size: 26rpx;
  font-weight: 950;
  color: #1d4ed8;
}

.warehouse-hint {
  font-size: 22rpx;
  font-weight: 800;
  color: #6b7280;
}

.warehouse-grid {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.warehouse-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.warehouse-item {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 0;
}

.warehouse-caption {
  font-size: 22rpx;
  font-weight: 900;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 画室预览弹窗 */
.studio-preview-modal {
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  padding: 30rpx 28rpx 64rpx;
  width: 100%;
  max-width: 750rpx;
  max-height: 86vh;
  animation: slideUpModal 0.4s ease-out;
  box-sizing: border-box;
}

.studio-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.studio-preview-title {
  font-size: 32rpx;
  font-weight: 950;
  color: #831843;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.studio-preview-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.studio-preview-close-text {
  font-size: 34rpx;
  font-weight: 900;
  color: #ef4444;
}

.studio-preview-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #9ca3af;
  text-align: center;
}

.qc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.qc-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
  color: #831843;
}

.qc-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fce7f3 0%, #fbcfe8 100%);
  border: 2rpx solid rgba(253, 230, 240, 0.95);
  box-shadow: 0 6rpx 16rpx rgba(232, 121, 169, 0.12);
  flex-shrink: 0;
}

.qc-tag-text {
  color: #e879a9;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  transform: translateY(-1rpx);
}

.qc-intro {
  display: block;
  color: #374151;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.7;
  margin-bottom: 14rpx;
}

/* 题库选题（小小演说家风格：进度 + 展示 + 标签简介） */
.bank-progress-block {
  margin-top: 8rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 6rpx solid rgba(243, 232, 255, 1);
  box-shadow: 0 12rpx 30rpx rgba(232, 121, 169, 0.08);
}

.bank-progress-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.bank-progress-label {
  font-size: 26rpx;
  font-weight: 900;
  color: #831843;
}

.bank-progress-value {
  font-size: 22rpx;
  font-weight: 800;
  color: #e879a9;
}

.bank-progress-bar {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(232, 121, 169, 0.12);
  overflow: hidden;
}

.bank-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(232, 121, 169, 0.9), rgba(236, 72, 153, 0.85));
}

.bank-current-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 14rpx 0 12rpx;
  gap: 12rpx;
}

.bank-current-cat {
  font-size: 24rpx;
  font-weight: 900;
  color: #831843;
  max-width: 60%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.diff-badge-inline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.08);
  color: #111827;
  font-size: 22rpx;
  font-weight: 900;
}

.diff-badge-inline.simple {
  background: rgba(16, 185, 129, 0.22);
}
.diff-badge-inline.medium {
  background: rgba(59, 130, 246, 0.22);
}
.diff-badge-inline.hard {
  background: rgba(239, 68, 68, 0.22);
}

.bank-current-image-card {
  border-radius: 24rpx;
  overflow: hidden;
  border: 6rpx solid rgba(252, 231, 243, 1);
  background: #fff;
}

.bank-current-image {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #f3f4f6;
}

.bank-current-title {
  padding: 12rpx 14rpx;
  background: rgba(236, 72, 153, 0.05);
  border-top: 4rpx solid rgba(252, 231, 243, 1);
}

.bank-current-title-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #be185d;
}

.bank-current-tags {
  margin-top: 12rpx;
  display: block;
}

.bank-tags-title {
  font-size: 24rpx;
  font-weight: 900;
  color: #831843;
  margin-right: 10rpx;
}

.bank-tag-item {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 800;
  color: #4338ca;
  padding: 6rpx 12rpx;
  background: rgba(67, 56, 202, 0.12);
  border-radius: 999rpx;
  margin-right: 10rpx;
  margin-top: 10rpx;
}

.bank-current-intro {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 4rpx solid rgba(243, 232, 255, 1);
}

.bank-intro-title {
  font-size: 24rpx;
  font-weight: 900;
  color: #831843;
}

.bank-intro-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
}

.bank-start-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: center;
}

.bank-start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(147, 197, 253, 0.98), rgba(244, 114, 182, 0.92));
  background-size: 220% 100%;
  box-shadow: 0 14rpx 30rpx rgba(232, 121, 169, 0.12);
  border: 5rpx solid rgba(255, 255, 255, 0.88);
  min-width: 240rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  animation: bankBtnFloat 2s ease-in-out infinite, bankBtnFlow 3.2s ease-in-out infinite;
  transition: transform 0.18s ease, box-shadow 0.2s ease;
}

.bank-start-button-text {
  font-size: 26rpx;
  font-weight: 950;
  color: #1f2937;
  display: block;
  text-align: center;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.bank-start-button::after {
  content: '';
  position: absolute;
  top: -20%;
  left: -30%;
  width: 30%;
  height: 140%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0));
  transform: skewX(-20deg);
  animation: bankBtnShine 2.8s ease-in-out infinite;
}

.bank-start-button:active {
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 0 8rpx 18rpx rgba(232, 121, 169, 0.18);
  animation-play-state: paused;
}

.bank-start-button:active::after {
  animation-play-state: paused;
}

@keyframes bankBtnFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

@keyframes bankBtnFlow {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes bankBtnShine {
  0%, 55% { left: -35%; opacity: 0; }
  65% { opacity: 1; }
  100% { left: 130%; opacity: 0; }
}

.bank-loading-hint {
  margin-top: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
}

.bank-thumb-strip {
  margin-top: 12rpx;
  padding: 4rpx 2rpx;
}

.bank-thumb-strip-inner {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.bank-thumb-dot {
  width: 118rpx;
  height: 118rpx;
  border-radius: 22rpx;
  overflow: hidden;
  border: 6rpx solid rgba(243, 232, 255, 1);
  background: #fff;
  position: relative;
}

.bank-thumb-dot.on {
  border-color: rgba(232, 121, 169, 0.7);
  box-shadow: 0 14rpx 30rpx rgba(232, 121, 169, 0.18);
  transform: scale(1.03);
}

.bank-thumb-image {
  width: 100%;
  height: 100%;
  display: block;
}


/* 涂色模式 */
.coloring-mode {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 16rpx 16rpx 32rpx;
  overflow-x: hidden;
}

.coloring-mode .title-bar {
  margin: 20rpx 0 0;
  width: 100%;
}

/* 顶部标题栏 */
.title-bar {
  width: 100%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  padding: 16rpx 40rpx;
  border-radius: 48rpx;
  border: 8rpx solid #fce7f3;
  box-shadow: 0 2rpx 8rpx rgba(236, 72, 153, 0.1);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  animation: slideDown 0.5s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.back-button,
.undo-button,
.finish-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}

.disabled {
  opacity: 0.45;
  pointer-events: none;
  filter: saturate(0.6);
}

.back-button {
  background: #fbcfe8;
}

.back-button:active,
.undo-button:active,
.finish-button:active {
  transform: scale(0.9);
}

.back-icon,
.undo-icon,
.finish-icon {
  font-size: 40rpx;
  font-weight: 900;
}

.back-icon {
  color: #f87171;
}

.undo-button {
  background: #fde68a;
}

.undo-icon {
  color: #b45309;
}

.finish-button {
  background: #fda4af;
}

.answer-button {
  background: linear-gradient(135deg, #fde68a, #fbcfe8);
  box-shadow: 0 10rpx 26rpx rgba(244, 194, 212, 0.35);
}

.finish-icon {
  color: #b87a94;
}

.title-info {
  flex: 1;
  text-align: center;
  margin: 0 24rpx;
}

.title-text {
  color: #be185d;
  font-size: 36rpx;
  font-weight: 900;
  display: block;
}

/* 绘画区域 */
.drawing-area {
  width: 100%;
  background: white;
  padding: 16rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(236, 72, 153, 0.2);
  border: 8rpx solid #ec4899;
  margin: 0 0 24rpx;
  transition: border-color 0.3s;
  animation: scaleIn 0.5s ease-out;
  /* 避免部分 DevTools / WebView 对 aspect-ratio 支持不稳定导致高度=0 */
  height: 680rpx;
  max-height: 880rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

/* 卡通涂色进度：全宽糖果条 + 轨道滑块小图标 */
.paint-progress-strip {
  position: relative;
  z-index: 5;
  width: 100%;
  margin: 0 0 16rpx;
  padding: 0;
  box-sizing: border-box;
  pointer-events: none;
}

.paint-progress-strip-inner {
  width: 100%;
  padding: 20rpx 22rpx 18rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96) 0%, rgba(250, 245, 255, 0.98) 50%, rgba(255, 251, 235, 0.95) 100%);
  border: 6rpx solid #f9a8d4;
  box-shadow:
    0 12rpx 0 rgba(192, 38, 211, 0.12),
    0 20rpx 40rpx rgba(232, 121, 169, 0.15),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

.paint-progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.paint-progress-title-block {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.paint-progress-stars {
  font-size: 26rpx;
  line-height: 1;
  animation: starTwinkle 1.6s ease-in-out infinite;
}

.paint-progress-title-block .paint-progress-stars:last-child {
  animation-delay: 0.4s;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.65; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.12); }
}

.paint-progress-title {
  font-size: 30rpx;
  font-weight: 950;
  color: #9d4e6e;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.paint-progress-percent-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  padding: 6rpx 18rpx 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fef3c7 0%, #fbcfe8 100%);
  border: 4rpx solid #fde68a;
  box-shadow: 0 4rpx 0 rgba(157, 62, 110, 0.15);
}

.paint-progress-percent-num {
  font-size: 40rpx;
  font-weight: 950;
  color: #e879a9;
  line-height: 1;
}

.paint-progress-percent-sign {
  font-size: 22rpx;
  font-weight: 900;
  color: #e879a9;
  margin-left: 2rpx;
}

/* 轨道：外层留白给滑块气泡，内层 meter 与条同宽保证百分比对齐 */
.paint-progress-rail {
  margin-top: 4rpx;
  /* 给滑块气泡左右留空，避免高进度时冲出边界 */
  padding: 0 30rpx;
  box-sizing: border-box;
}

.paint-progress-rail-meter {
  position: relative;
  height: 56rpx;
  width: 100%;
}

.paint-progress-rail-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(232, 121, 169, 0.14);
  overflow: hidden;
  border: 3rpx solid rgba(251, 207, 232, 0.35);
}

.paint-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #fbcfe8 0%, #f472b6 45%, #f472b6 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.45);
  transition: width 0.25s ease-out;
}

.paint-progress-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  transition: left 0.25s ease-out;
}

.paint-progress-thumb-bubble {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(160deg, #fff 0%, #fef3c7 100%);
  border: 5rpx solid #f472b6;
  box-shadow:
    0 6rpx 0 rgba(219, 39, 119, 0.2),
    0 10rpx 24rpx rgba(232, 121, 169, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.paint-progress-thumb-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.paint-progress-hint {
  display: block;
  margin-top: 12rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 850;
  color: #e879a9;
  letter-spacing: 1rpx;
}

/* 语义部位选择条 */
.part-selector {
  width: calc(100% - 48rpx);
  margin: 8rpx 24rpx 16rpx;
  padding: 10rpx 14rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 4rpx solid #fee2e2;
  box-shadow: 0 4rpx 16rpx rgba(248, 113, 113, 0.15);
  box-sizing: border-box;
}

.part-scroll {
  display: flex;
  white-space: nowrap;
}

.part-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  font-size: 24rpx;
  color: #4b5563;
}

.part-chip.active {
  background: #fee2e2;
  border-color: #f97316;
  color: #b91c1c;
}

.part-color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  box-shadow: 0 0 0 2rpx #fff;
}

.part-text {
  white-space: nowrap;
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.canvas-container {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 48rpx;
  overflow: hidden;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: crosshair;
}

.base-canvas,
.paint-canvas,
.highlight-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  border-radius: 48rpx;
  background: transparent;
}

.base-canvas {
  z-index: 0;
}

.lineart-canvas {
  opacity: 1;
  pointer-events: none;
}

.base-image-fallback {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.forced-lineart-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.paint-canvas {
  z-index: 2;
  background: transparent;
}

.highlight-canvas {
  z-index: 3;
}

.hidden-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  /* 一些 WebView 会对 opacity:0 的 canvas 跳过绘制，导致 canvasGetImageData 全 0 */
  opacity: 0.001;
  pointer-events: none;
}

/* 轻量调试信息 */
.mini-debug {
  width: calc(100% - 48rpx);
  margin: 0 24rpx 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.mini-debug-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
  margin: 6rpx 0;
}

.mini-debug-k {
  font-size: 22rpx;
  font-weight: 900;
  color: #6b7280;
}

.mini-debug-v {
  font-size: 22rpx;
  font-weight: 900;
  color: #111827;
  word-break: break-all;
}

/* 闪烁特效 */
.sparkle {
  position: absolute;
  font-size: 56rpx;
  pointer-events: none;
  animation: sparkleFloat 0.8s ease-out forwards;
  transform: translate(-50%, -50%);
}

@keyframes sparkleFloat {
  0% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(0);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, calc(-50% - 80rpx)) scale(2);
  }
}

/* 提示卡片 */
.hint-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  padding: 20rpx 24rpx;
  border-radius: 36rpx;
  border: 4rpx solid #fce7f3;
  box-shadow: 0 6rpx 24rpx rgba(236, 72, 153, 0.15);
  margin: 0 0 24rpx;
  animation: slideUp 0.35s ease-out;
}

.hint-row {
  display: flex;
  align-items: center;
  margin: 8rpx 0;
  flex-wrap: wrap;
}

.hint-title {
  color: #be185d;
  font-size: 26rpx;
  font-weight: 900;
  margin-right: 12rpx;
}

.hint-text {
  color: #374151;
  font-size: 26rpx;
  font-weight: bold;
  flex: 1;
  min-width: 200rpx;
}

.rec-colors {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 68rpx;
}

.rec-color {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.rec-color:active {
  transform: scale(1.2);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 颜色选择器 */
.color-palette {
  width: calc(100% - 48rpx);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(40rpx);
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(236, 72, 153, 0.2);
  border: 4rpx solid #fce7f3;
  animation: slideUp 0.5s ease-out 0.2s both;
}

.palette-scroll {
  white-space: nowrap;
  display: flex;
}

.palette-scroll::after {
  content: '';
  display: inline-block;
  width: 1rpx;
}

.color-button {
  display: inline-block;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 4rpx 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  border: 8rpx solid transparent;
  transition: all 0.2s;
  vertical-align: middle;
  flex-shrink: 0;
}

.color-button:active {
  transform: scale(0.9);
}

.color-button.selected {
  transform: scale(1.3);
  border-color: white;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 按钮组 */
.button-group {
  width: 100%;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
}

.finish-button {
  flex: 1;
  background: linear-gradient(135deg, #86efac, #74e8a0);
  border: none;
  border-radius: 32rpx;
  padding: 20rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(134, 239, 172, 0.3);
  transition: all 0.3s;
  animation: slideUp 0.5s ease-out 0.3s both;
}

.finish-button:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(134, 239, 172, 0.2);
}

.finish-text {
  color: white;
  font-size: 32rpx;
  font-weight: 900;
  display: block;
  text-align: center;
}

/* 彩带效果 */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.confetti {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  animation: confettiFall 3s ease-out forwards;
}

.confetti-1 {
  left: 10%;
  animation-delay: 0s;
}

.confetti-2 {
  left: 20%;
  animation-delay: 0.1s;
}

.confetti-3 {
  left: 30%;
  animation-delay: 0.2s;
}

.confetti-4 {
  left: 40%;
  animation-delay: 0.3s;
}

.confetti-5 {
  left: 60%;
  animation-delay: 0.4s;
}

.confetti-6 {
  left: 70%;
  animation-delay: 0.5s;
}

.confetti-7 {
  left: 80%;
  animation-delay: 0.6s;
}

.confetti-8 {
  left: 90%;
  animation-delay: 0.7s;
}

@keyframes confettiFall {
  0% {
    top: -100rpx;
    opacity: 1;
    transform: rotate(0deg);
  }
  100% {
    top: 100%;
    opacity: 0;
    transform: rotate(720deg);
  }
}

/* 模态框隔离层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 评分弹窗 */
