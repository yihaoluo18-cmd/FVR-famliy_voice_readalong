.repair-smoke.sm1{ margin-left:-74rpx; animation-delay: 0s; }
.repair-smoke.sm2{ margin-left:-26rpx; width: 74rpx; height: 46rpx; animation-delay: 0.18s; }
.repair-smoke.sm3{ margin-left: 34rpx; width: 70rpx; height: 44rpx; animation-delay: 0.36s; }
.repair-smoke.sm4{ margin-left: 88rpx; width: 84rpx; height: 52rpx; animation-delay: 0.54s; }
.repair-smoke.sm5{ margin-left: 10rpx; top: 142rpx; width: 56rpx; height: 36rpx; animation-delay: 0.72s; }

@keyframes repairSmokeRise{
  0%{ opacity: 0; transform: translate(-50%, 22rpx) scale(0.86); filter: blur(2rpx); }
  18%{ opacity: 0.55; }
  55%{ opacity: 0.92; transform: translate(-50%, -18rpx) scale(1.08); filter: blur(3.2rpx); }
  100%{ opacity: 0; transform: translate(-50%, -66rpx) scale(1.22); filter: blur(4.4rpx); }
