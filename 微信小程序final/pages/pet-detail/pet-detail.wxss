.tuning-input{
  flex:1;
  height: 34rpx;
  background: rgba(255,255,255,0.75);
  border: 2rpx solid rgba(209, 213, 219, 0.7);
  border-radius: 12rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
}

/* ========== 小狐狸主题：粉色系（仅 mascotId === cute-fox） ========== */
.page.page--fox {
  background: linear-gradient(180deg, #fff5f7 0%, #fce7f3 45%, #fbcfe8 100%);
}

.page.page--fox .pet-panel {
  background: rgba(255, 255, 255, 0.52);
  border: 2rpx solid rgba(244, 114, 182, 0.42);
  box-shadow: 0 12rpx 40rpx rgba(236, 72, 153, 0.1);
}

.page.page--fox .panel-title {
  color: #9d174d;
}

.page.page--fox .care-btn {
  color: #831843;
  border-color: rgba(244, 114, 182, 0.55);
}

.page.page--fox .feed {
  background: linear-gradient(180deg, #fce7f3, #fbcfe8);
}

.page.page--fox .play {
  background: linear-gradient(180deg, #fbcfe8, #f9a8d4);
}

.page.page--fox .clean {
  background: linear-gradient(180deg, #f9a8d4, #f472b6);
}

.page.page--fox .care-on {
  box-shadow: 0 6rpx 14rpx rgba(236, 72, 153, 0.22);
}

.page.page--fox .hatch-inline {
  border-color: rgba(244, 114, 182, 0.5);
  background: rgba(255, 250, 252, 0.88);
}

.page.page--fox .hatch-inline-title,
.page.page--fox .hatch-inline-tip {
  color: #9d174d;
}

.page.page--fox .hatch-inline-btn {
  background: linear-gradient(90deg, #f472b6, #e879a9);
}

.page.page--fox .egg-hint-ring {
  box-shadow:
    0 0 0 6rpx rgba(251, 207, 232, 0.35),
    0 0 36rpx rgba(244, 114, 182, 0.22),
    0 0 74rpx rgba(236, 72, 153, 0.12);
}

.page.page--fox .egg-hint-arrow {
  border-bottom-color: rgba(236, 72, 153, 0.78);
  filter: drop-shadow(0 10rpx 16rpx rgba(236, 72, 153, 0.18));
}

.page.page--fox .egg-hint-text {
  color: rgba(190, 24, 93, 0.96);
  border-color: rgba(244, 114, 182, 0.45);
  box-shadow: 0 14rpx 30rpx rgba(236, 72, 153, 0.12);
}

.page.page--fox .stat-chip {
  border-color: rgba(244, 114, 182, 0.4);
  background: rgba(255, 250, 252, 0.88);
}

.page.page--fox .stat-name,
.page.page--fox .stat-value {
  color: #9d174d;
}

.page.page--fox .pet-name {
  color: #831843;
}

.page.page--fox .stage-tag {
  color: #9d174d;
  background: rgba(252, 231, 243, 0.95);
  border: 1rpx solid rgba(251, 207, 232, 0.9);
}

.page.page--fox .toggle-pill {
  color: #9d174d;
  background: rgba(255, 250, 252, 0.85);
}

.page.page--fox .toggle-on {
  background: linear-gradient(180deg, #fbcfe8, #f9a8d4);
}

.page.page--fox .form-pill {
  color: #9d174d;
  border-color: rgba(244, 114, 182, 0.45);
  background: rgba(255, 250, 252, 0.75);
}

.page.page--fox .form-on {
  background: #fce7f3;
  border-color: #e879a9;
}

.page.page--fox .pet-stage-showcase {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96) 0%, rgba(252, 231, 243, 0.92) 45%, rgba(251, 207, 232, 0.75) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    0 8rpx 32rpx rgba(190, 24, 93, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.page.page--fox .showcase-inner {
  background: radial-gradient(ellipse 80% 70% at 50% 45%, #fff5f7 0%, #fce7f3 52%, #f9a8d4 100%);
}

.page.page--fox .mode-switch-fab {
  background: radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.96), rgba(251, 207, 232, 0.65) 35%, rgba(236, 72, 153, 0.38) 70%, rgba(219, 39, 119, 0.15) 100%);
  box-shadow:
    0 18rpx 46rpx rgba(236, 72, 153, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}

.page.page--fox .mode-switch-text {
  color: rgba(157, 23, 77, 0.96);
}

.page.page--fox .quick-action-fab {
  background: radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.96), rgba(252, 231, 243, 0.7) 35%, rgba(244, 114, 182, 0.35) 70%, rgba(236, 72, 153, 0.16) 100%);
  box-shadow:
    0 20rpx 56rpx rgba(236, 72, 153, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}

.page.page--fox .quick-action-text {
  color: rgba(157, 23, 77, 0.94);
}

.page.page--fox .quick-action-emoji {
  filter: saturate(1.05);
}

.page.page--fox .nurture-bubble {
  border-color: rgba(244, 114, 182, 0.65);
  box-shadow:
    0 20rpx 60rpx rgba(236, 72, 153, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
}

.page.page--fox .nurture-bubble-icon,
.page.page--fox .nurture-bubble-icon-zzz {
  color: rgba(190, 24, 93, 0.88);
  text-shadow: 0 0 18rpx rgba(252, 231, 243, 0.9);
}

.page.page--fox .nurture-bubble-label {
  color: rgba(131, 24, 67, 0.95);
  border-color: rgba(244, 114, 182, 0.35);
  background: rgba(255, 250, 252, 0.75);
}

.page.page--fox .nurture-bubble-cover {
  border-color: rgba(236, 72, 153, 0.45);
  background-color: rgba(255, 250, 252, 0.96);
  box-shadow: 0 12rpx 36rpx rgba(236, 72, 153, 0.15);
}

.page.page--fox .nurture-bubble-cover-icon {
  color: rgba(190, 24, 93, 0.9);
}

.page.page--fox .nurture-bubble-cover-label {
  color: rgba(131, 24, 67, 0.96);
  border-color: rgba(244, 114, 182, 0.38);
}

.page.page--fox .fox-deco-leaf,
.page.page--fox .fox-deco-fox {
  opacity: 0.11;
}

.page.page--fox .model-load-card::before {
  background: linear-gradient(
    115deg,
    rgba(255, 255, 255, 0) 30%,
    rgba(251, 207, 232, 0.32) 45%,
    rgba(236, 72, 153, 0.14) 55%,
    rgba(255, 255, 255, 0) 70%
  );
}

.page.page--fox .star4 {
  color: rgba(244, 114, 182, 0.94);
}

.page.page--fox .star7 {
  color: rgba(236, 72, 153, 0.9);
}

.page.page--fox .spark {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.95), rgba(244, 114, 182, 0.7));
  box-shadow: 0 0 18rpx rgba(236, 72, 153, 0.32);
}

.page.page--fox .star {
  background: rgba(244, 114, 182, 0.75);
  box-shadow: 0 0 16rpx rgba(236, 72, 153, 0.32);
}

.page.page--fox .wand {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.88), rgba(236, 72, 153, 0.78) 24%, rgba(244, 114, 182, 0.76) 52%, rgba(251, 207, 232, 0.72));
  box-shadow:
    0 0 26rpx rgba(236, 72, 153, 0.22),
    0 0 46rpx rgba(251, 207, 232, 0.16);
}

.page.page--fox .wand::after {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(244, 114, 182, 0.68));
  box-shadow: 0 0 18rpx rgba(244, 114, 182, 0.26);
}

.page.page--fox .repair-smoke {
  background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.9), rgba(251, 191, 36, 0.22) 40%, rgba(236, 72, 153, 0.08) 75%, rgba(255, 255, 255, 0));
}

.page.page--fox .repair-spark.sp2 {
  background: rgba(244, 114, 182, 0.88);
  box-shadow: 0 0 18rpx rgba(244, 114, 182, 0.28);
}

.page.page--fox .repair-spark.sp3 {
  background: rgba(236, 72, 153, 0.88);
  box-shadow: 0 0 18rpx rgba(236, 72, 153, 0.28);
}

.page.page--fox .upgrade-smoke {
  background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.92), rgba(251, 207, 232, 0.35) 45%, rgba(236, 72, 153, 0.08) 75%, rgba(255, 255, 255, 0));
}

.page.page--fox .upgrade-title {
  color: #e879a9;
}

.page.page--fox .growth-row-bottom {
  background: rgba(255, 250, 252, 0.94);
  border: 2rpx solid rgba(244, 114, 182, 0.38);
}

.page.page--fox .growth-title,
.page.page--fox .growth-meta {
  color: #b87a94;
}

.page.page--fox .growth-stage-hint {
  color: #c9a8b5;
}

.page.page--fox .growth-fill-h {
  background: linear-gradient(90deg, #fbcfe8 0%, #f472b6 45%, #ec4899 100%);
  box-shadow: 0 0 16rpx rgba(236, 72, 153, 0.35);
}

.page.page--fox .stage-memo-note {
  background: rgba(255, 250, 252, 0.94);
  border-color: rgba(244, 114, 182, 0.5);
  box-shadow: 0 14rpx 34rpx rgba(236, 72, 153, 0.08);
}

.page.page--fox .stage-memo-note::after {
  background: linear-gradient(135deg, rgba(251, 207, 232, 0.55), rgba(255, 255, 255, 0));
}

.page.page--fox .stage-memo-fold {
  background: rgba(251, 207, 232, 0.45);
}

.page.page--fox .stage-memo-title,
.page.page--fox .stage-memo-range {
  color: #9d174d;
}

.page.page--fox .stage-memo-on {
  border-color: rgba(236, 72, 153, 0.55);
  box-shadow: 0 18rpx 50rpx rgba(236, 72, 153, 0.16);
}

.page.page--fox .stage-tier-1 {
  border-color: rgba(244, 114, 182, 0.55);
}

.page.page--fox .stage-tier-2 {
  border-color: rgba(244, 114, 182, 0.5);
  background: rgba(255, 245, 250, 0.94);
}

.page.page--fox .stage-tier-3 {
  border-color: rgba(236, 72, 153, 0.48);
  background: rgba(255, 242, 249, 0.94);
}

.page.page--fox .bottom-row {
  background: rgba(255, 250, 252, 0.92);
}

.page.page--fox .meta {
  color: #9d174d;
}

.page.page--fox .section-title {
  color: #be185d;
}

.page.page--fox .action-on {
  border-color: #f472b6;
  background: #fce7f3;
}

.page.page--fox .action-showcase-btn {
  border: 2rpx solid rgba(244, 114, 182, 0.58);
  background: rgba(252, 231, 243, 0.55);
  color: #9d174d;
}

.page.page--fox .status-ball {
  border-color: rgba(244, 114, 182, 0.48);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65),
    0 14rpx 32rpx rgba(236, 72, 153, 0.1);
}

.page.page--fox .status-ball-label {
  color: rgba(157, 23, 77, 0.95);
}

/* 狐狸主题：状态球内液体由黄条改为粉白条 */
.page.page--fox .status-ball-food .status-ball-liquid {
  background: linear-gradient(180deg, rgba(244, 114, 182, 0.78), rgba(251, 207, 232, 0.5));
}

.page.page--fox .status-ball-food .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.82) 0%,
      rgba(255, 255, 255, 0.82) 12%,
      rgba(249, 168, 212, 0.28) 12%,
      rgba(249, 168, 212, 0.28) 24%
    ),
    linear-gradient(180deg, rgba(249, 168, 212, 0.72), rgba(236, 72, 153, 0.42));
}

.page.page--fox .status-ball-clean .status-ball-liquid {
  background: linear-gradient(180deg, rgba(252, 231, 243, 0.88), rgba(244, 114, 182, 0.45));
}

.page.page--fox .status-ball-clean .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 245, 250, 0.78) 0%,
      rgba(255, 245, 250, 0.78) 12%,
      rgba(251, 207, 232, 0.35) 12%,
      rgba(251, 207, 232, 0.35) 24%
    ),
    linear-gradient(180deg, rgba(251, 207, 232, 0.7), rgba(244, 114, 182, 0.38));
}

.page.page--fox .status-ball-mood .status-ball-liquid {
  background: linear-gradient(180deg, rgba(236, 72, 153, 0.82), rgba(219, 39, 119, 0.42));
}

.page.page--fox .status-ball-mood .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(252, 231, 243, 0.75) 0%,
      rgba(252, 231, 243, 0.75) 12%,
      rgba(236, 72, 153, 0.22) 12%,
      rgba(236, 72, 153, 0.22) 24%
    ),
    linear-gradient(180deg, rgba(244, 114, 182, 0.78), rgba(219, 39, 119, 0.4));
}

.page.page--fox .status-ball-sleepy .status-ball-liquid {
  background: linear-gradient(180deg, rgba(219, 39, 119, 0.8), rgba(190, 24, 93, 0.38));
}

.page.page--fox .status-ball-sleepy .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 228, 240, 0.68) 0%,
      rgba(255, 228, 240, 0.68) 12%,
      rgba(190, 24, 93, 0.2) 12%,
      rgba(190, 24, 93, 0.2) 24%
    ),
    linear-gradient(180deg, rgba(236, 72, 153, 0.72), rgba(157, 23, 77, 0.36));
}

.page.page--fox .status-note {
  border: 2rpx solid rgba(236, 72, 153, 0.22);
  box-shadow: 0 10rpx 26rpx rgba(236, 72, 153, 0.08);
}

.page.page--fox .status-note-title {
  color: rgba(157, 23, 77, 0.92);
}

.page.page--fox .status-note-score {
  color: rgba(219, 39, 119, 0.95);
}

.page.page--fox .status-note-unit {
  color: rgba(157, 23, 77, 0.82);
}

.page.page--fox .status-note-mood {
  border-color: rgba(244, 114, 182, 0.38);
}

.page.page--fox .status-note-food {
  border-color: rgba(244, 114, 182, 0.42);
}

.page.page--fox .status-note-clean {
  border-color: rgba(249, 168, 212, 0.45);
}

.page.page--fox .status-note-sleepy {
  border-color: rgba(236, 72, 153, 0.35);
}

.page.page--fox .liquid-container {
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6),
    0 14rpx 34rpx rgba(236, 72, 153, 0.1);
}

.page.page--fox .liquid-mood .liquid-fill {
  background: linear-gradient(180deg, rgba(236, 72, 153, 0.82), rgba(251, 207, 232, 0.45));
}

.page.page--fox .liquid-sleepy .liquid-fill {
  background: linear-gradient(180deg, rgba(219, 39, 119, 0.65), rgba(244, 114, 182, 0.4));
}

.page.page--fox .primary-btn {
  background: linear-gradient(90deg, #ec4899, #e879a9) !important;
}

.page.page--fox .tuning-entry {
  border-color: rgba(244, 114, 182, 0.5);
  color: #9d174d;
  background: rgba(255, 250, 252, 0.88);
}

.page.page--fox .tuning-panel {
  border-color: rgba(244, 114, 182, 0.45);
  background: rgba(255, 250, 252, 0.94);
}

.page.page--fox .tuning-title {
  color: #9d174d;
}

.page.page--fox .tuning-item {
  background: rgba(252, 231, 243, 0.45);
  border-color: rgba(244, 114, 182, 0.3);
}

.page.page--fox .tuning-label,
.page.page--fox .tuning-input-hint {
  color: #9d174d;
}

.page.page--fox .tuning-save {
  border-color: rgba(244, 114, 182, 0.55);
  background: rgba(251, 207, 232, 0.5);
  color: #831843;
}

.page.page--fox .cam-on {
  border-color: rgba(244, 114, 182, 0.55);
  background: rgba(252, 231, 243, 0.45);
}

.page.page--fox .cam-mode-pill {
  color: #9d174d;
}
