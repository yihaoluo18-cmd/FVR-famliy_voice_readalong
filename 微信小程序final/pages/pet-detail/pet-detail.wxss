/* gearSpin 已弃用（圈圈齿轮已移除） */

@keyframes petStageNudge {
  0%, 100% { transform: scale(1); }
  35% { transform: scale(1.018); }
  70% { transform: scale(0.995); }
}
.pet-stage-nudge {
  animation: petStageNudge 0.45s ease;
}

/* 破壳点击：让整个展示框都抖动 + 闪光（否则蛋本体看不出来） */
.pet-stage-hatch-shake {
  animation: hatchStageShake 0.18s ease-in-out 1;
}
@keyframes hatchStageShake {
  0% { transform: translateX(0); }
  18% { transform: translateX(-10rpx) rotate(-0.35deg); }
  40% { transform: translateX(9rpx) rotate(0.35deg); }
  62% { transform: translateX(-6rpx) rotate(-0.25deg); }
  100% { transform: translateX(0); }
}

.hatch-stage-flash{
  position:absolute;
  inset: 0;
  z-index: 75; /* 低于 model-load-mask(80)，但高于 canvas */
  pointer-events:none;
  background: radial-gradient(circle at 50% 45%, rgba(255,255,255,0.82), rgba(255,255,255,0) 62%);
  animation: hatchStageFlash 0.22s ease-out 1;
}
@keyframes hatchStageFlash{
  0%{ opacity: 0; transform: scale(0.96); }
  35%{ opacity: 1; transform: scale(1.02); }
  100%{ opacity: 0; transform: scale(1.06); }
}
.pet-stage-glow {
  box-shadow:
    0 8rpx 36rpx rgba(251, 146, 60, 0.35),
    0 0 0 3rpx rgba(255, 255, 255, 0.5);
}

