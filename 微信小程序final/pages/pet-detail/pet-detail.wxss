.page {
  min-height: 100vh;
  padding: 12rpx 16rpx 36rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fef3c7 0%, #fef9c3 100%);
}
.loading { padding: 140rpx 0; text-align: center; }
.loading-text { font-size: 26rpx; color: #9ca3af; }

.pet-panel {
  background: rgba(255, 255, 255, 0.42);
  border-radius: 28rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.45);
  padding: 12rpx 12rpx 14rpx;
  box-shadow: 0 12rpx 40rpx rgba(251, 191, 36, 0.12);
  position: relative;
}
.panel-title {
  display: block;
  text-align: center;
  font-size: 58rpx;
  color: #7c2d12;
  font-weight: 900;
  margin-top: 4rpx;
}
.care-row { display: flex; gap: 12rpx; margin: 10rpx 26rpx 8rpx; }
.care-btn {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #7c2d12;
  border: 2rpx solid rgba(217, 119, 6, 0.5);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
.care-btn:active { transform: scale(0.97); }
.feed { background: #fde047; }
.play { background: #fb923c; }
.clean { background: #f97316; }
.care-on { transform: scale(1.04); box-shadow: 0 6rpx 12rpx rgba(217, 119, 6, 0.2); }
.feed-hatched-glow {
  animation: feedHintGlow 1.1s ease-in-out infinite;
  border-color: rgba(34, 197, 94, 0.55);
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.18);
}

@keyframes feedHintGlow {
  0%, 100% {
    box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.18);
    transform: translateY(0) scale(1);
    filter: brightness(1);
  }
  50% {
    box-shadow: 0 12rpx 30rpx rgba(34, 197, 94, 0.35);
    transform: translateY(-1rpx) scale(1.04);
    filter: brightness(1.08);
  }
}

.hatch-inline {
  margin: 10rpx 20rpx 0;
  padding: 16rpx 16rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx dashed rgba(245, 158, 11, 0.55);
}

.hatch-inline-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
  color: #7c2d12;
  text-align: center;
}

.hatch-inline-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.hatch-inline-btn {
  width: 340rpx;
  height: 66rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #fbcfe8, #e879a9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.hatch-inline-done {
  background: linear-gradient(90deg, #f0a8c0, #fde68a);
}

.hatch-inline-tip {
  font-size: 22rpx;
  color: #92400e;
  text-align: center;
  line-height: 1.4;
}

/* 孵化：高光提示（点击蛋敲碎） */
.egg-hint-overlay {
  position: absolute;
  inset: 0;
  z-index: 70; /* 低于 model-load-mask(z-index:80)，避免加载遮罩被抢 */
  display: block;
  background: rgba(255, 255, 255, 0);
}

.egg-hint-ring {
  position: absolute;
  left: 50%;
  top: 52%;
  width: 160rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 6rpx solid rgba(250, 204, 21, 0.65);
  box-shadow:
    0 0 0 6rpx rgba(250, 204, 21, 0.12),
    0 0 36rpx rgba(251, 146, 60, 0.18),
    0 0 74rpx rgba(232, 121, 169, 0.10);
  animation: eggHintPulse 1.2s ease-in-out infinite;
}

.egg-hint-arrow {
  position: absolute;
  left: 50%;
  top: 25%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 22rpx solid rgba(232, 121, 169, 0.72);
  filter: drop-shadow(0 10rpx 16rpx rgba(232, 121, 169, 0.15));
}

.egg-hint-text {
  position: absolute;
  left: 50%;
  top: 18%;
  transform: translateX(-50%);
  width: max-content;
  max-width: 80%;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(250, 204, 21, 0.40);
  color: rgba(232, 121, 169, 0.95);
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(232, 121, 169, 0.10);
  animation: eggHintTextFloat 1.2s ease-in-out infinite;
}

@keyframes eggHintPulse {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.9;
    filter: brightness(1);
  }
  50% {
    transform: translate(-50%, -50%) scale(1.06);
    opacity: 1;
    filter: brightness(1.15);
  }
}

@keyframes eggHintTextFloat {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-6rpx); }
}

.stage-wrap { position: relative; display: flex; padding-top: 6rpx; align-items: flex-start; }
.side { width: 92rpx; flex-shrink: 0; display: flex; flex-direction: column; gap: 10rpx; }
.stat-chip {
  background: rgba(255, 255, 255, 0.75);
  border: 2rpx solid rgba(245, 158, 11, 0.35);
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx;
}
.stat-emoji { font-size: 28rpx; }
.stat-name { font-size: 24rpx; color: #92400e; font-weight: 700; }
.stat-value { font-size: 22rpx; color: #78350f; }

.center-zone { flex: 1; min-width: 0; margin: 0 6rpx; }
.name-row { display: flex; align-items: center; justify-content: center; gap: 10rpx; }
.pet-name { font-size: 34rpx; color: #7c2d12; font-weight: 900; }
.stage-tag {
  font-size: 20rpx;
  color: #92400e;
  background: rgba(254, 240, 138, 0.9);
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  font-weight: 700;
}
.view-toggle { display: flex; gap: 10rpx; margin: 8rpx 40rpx; }
.toggle-pill {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  color: #92400e;
  font-weight: 700;
  transition: transform 0.18s ease, background 0.2s ease;
}
.toggle-on { background: #fbbf24; }
.toggle-pill:active { transform: scale(0.96); }

.form-row {
  display: flex;
  gap: 8rpx;
  margin: 6rpx 12rpx 0;
  justify-content: center;
}
.form-pill {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.65);
  font-size: 20rpx;
  color: #92400e;
  font-weight: 700;
  border: 2rpx solid rgba(251, 191, 36, 0.45);
  transition: transform 0.18s ease, background 0.2s ease;
}
.form-pill:active { transform: scale(0.95); }
.form-on {
  background: #fcd34d;
  border-color: #d97706;
}
.form-locked {
  opacity: 0.45;
}

/* 模型主展示区：更大画幅 + 层次与光晕 */
.pet-stage-showcase {
  position: relative;
  margin-top: 10rpx;
  height: 720rpx;
  border-radius: 40rpx;
  padding: 4rpx;
  box-sizing: border-box;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.95) 0%, rgba(254, 230, 138, 0.9) 45%, rgba(251, 191, 36, 0.55) 100%);
  box-shadow:
    0 8rpx 32rpx rgba(180, 83, 9, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  transition: box-shadow 0.25s ease, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.showcase-inner {
  position: relative;
  height: 100%;
  border-radius: 36rpx;
  overflow: hidden;
  background: radial-gradient(ellipse 80% 70% at 50% 45%, #fffbeb 0%, #fde68a 55%, #f59e0b 100%);
}

/* 左上角：2D/3D 切换小球 */
.mode-switch-fab {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  z-index: 25;
  width: 78rpx;
  height: 78rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 28%, rgba(255,255,255,0.95), rgba(250,204,21,0.55) 35%, rgba(244,194,212,0.35) 70%, rgba(244,194,212,0.18) 100%);
  border: 2rpx solid rgba(255,255,255,0.55);
  box-shadow:
    0 18rpx 46rpx rgba(232, 121, 169, 0.14),
    inset 0 1rpx 0 rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}
.mode-switch-fab:active {
  transform: scale(0.97);
}
.mode-switch-text {
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(184, 122, 148, 0.92);
  text-shadow: 0 0 14rpx rgba(255,255,255,0.45);
}

/* 右上角：快速动作触发按钮 */
.quick-action-fab {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  z-index: 26;
  width: 86rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 28%, rgba(255,255,255,0.95), rgba(251,191,36,0.55) 35%, rgba(244,194,212,0.25) 70%, rgba(244,194,212,0.18) 100%);
  border: 2rpx solid rgba(255,255,255,0.65);
  box-shadow:
    0 20rpx 56rpx rgba(244,194,212,0.12),
    inset 0 1rpx 0 rgba(255,255,255,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}
.quick-action-fab:active {
  transform: scale(0.97);
}
.quick-action-emoji {
  font-size: 30rpx;
  line-height: 1;
  text-shadow: 0 0 14rpx rgba(255,255,255,0.35);
}
.quick-action-text {
  font-size: 18rpx;
  font-weight: 900;
  color: rgba(184, 122, 148, 0.9);
  text-shadow: 0 0 12rpx rgba(255,255,255,0.35);
}

/* 透明大气泡（植树式收集提示） */
.nurture-bubble-layer {
  position: absolute;
  inset: 0;
  z-index: 22;
  pointer-events: none;
}

.nurture-bubble {
  position: absolute;
  width: 138rpx;
  height: 138rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  box-shadow:
    0 20rpx 60rpx rgba(232, 121, 169, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  animation: nurtureBubbleToTopBounce 4.2s ease-in-out both;
}

/* 首次孵化期（egg_model_active）：气泡不随 4.2s 动画淡出，进入成长形态后恢复普通动画 */
.nurture-bubble.nurture-bubble--hatch-persist {
  animation: nurtureBubbleHatchPersist 2.8s ease-in-out infinite;
}

@keyframes nurtureBubbleHatchPersist {
  0%,
  100% {
    opacity: 1;
    transform: translateY(0rpx) scale(1);
  }
  50% {
    opacity: 1;
    transform: translateY(-16rpx) scale(1.05);
  }
}

@keyframes nurtureBubbleToTopBounce {
  0% {
    opacity: 0;
    transform: translateY(26rpx) scale(0.92);
  }
  14% {
    opacity: 1;
    transform: translateY(0rpx) scale(1.0);
  }
  /* 漂浮向顶部 */
  55% {
    opacity: 0.98;
    transform: translateY(-86rpx) scale(1.04);
  }
  /* 触碰边界：轻微回弹 */
  68% {
    opacity: 1;
    transform: translateY(-78rpx) scale(0.995);
  }
  /* 顶部停留一段时间 */
  86% {
    opacity: 0.98;
    transform: translateY(-80rpx) scale(1.01);
  }
  100% {
    opacity: 0;
    transform: translateY(-94rpx) scale(0.98);
  }
}

.nurture-bubble-icon {
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 0 18rpx rgba(255, 255, 255, 0.5);
}
.nurture-bubble-icon-zzz {
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: rgba(232, 121, 169, 0.70);
  text-shadow:
    0 0 14rpx rgba(232, 121, 169, 0.25),
    0 0 30rpx rgba(250, 204, 21, 0.10);
}

.nurture-bubble-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(107, 33, 168, 0.90);
  background: rgba(255, 255, 255, 0.55);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(232, 121, 169, 0.18);
  box-shadow: 0 10rpx 30rpx rgba(232, 121, 169, 0.10);
}

/* 2D：气泡叠在 image 之上 */
.nurture-bubble-layer--over-poster {
  z-index: 30;
}

/* 3D：叠在 webgl 上只能用 cover-view（无 backdrop-filter，用实底保证可见） */
.nurture-bubble-cover {
  position: absolute;
  z-index: 10;
  width: 138rpx;
  height: 138rpx;
  border-radius: 69rpx;
  background-color: rgba(255, 255, 255, 0.94);
  border: 3rpx solid rgba(232, 121, 169, 0.42);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: nurtureBubbleCoverBounce 4.2s ease-in-out both;
}

.nurture-bubble-cover.nurture-bubble-cover--egg {
  animation: nurtureBubbleCoverEggFloat 2.8s ease-in-out infinite;
}

@keyframes nurtureBubbleCoverBounce {
  0% {
    opacity: 0;
    transform: translateY(26rpx) scale(0.92);
  }
  14% {
    opacity: 1;
    transform: translateY(0rpx) scale(1);
  }
  55% {
    opacity: 0.98;
    transform: translateY(-72rpx) scale(1.04);
  }
  68% {
    opacity: 1;
    transform: translateY(-64rpx) scale(0.995);
  }
  86% {
    opacity: 0.98;
    transform: translateY(-66rpx) scale(1.01);
  }
  100% {
    opacity: 0;
    transform: translateY(-78rpx) scale(0.98);
  }
}

@keyframes nurtureBubbleCoverEggFloat {
  0%,
  100% {
    opacity: 1;
    transform: translateY(0rpx) scale(1);
  }
  50% {
    opacity: 1;
    transform: translateY(-18rpx) scale(1.05);
  }
}

.nurture-bubble-cover-icon {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.1;
  color: rgba(232, 121, 169, 0.88);
  text-align: center;
}

.nurture-bubble-cover-icon.nurture-bubble-icon-zzz {
  font-size: 30rpx;
  letter-spacing: 8rpx;
}

.nurture-bubble-cover-label {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 900;
  color: rgba(107, 33, 168, 0.95);
  text-align: center;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(232, 121, 169, 0.22);
  max-width: 118rpx;
  line-height: 1.2;
}

.poster, .three-canvas { width: 100%; height: 712rpx; display: block; }

/* 微信小程序 webgl canvas 属于原生层：普通 view 遮罩不一定能压住。
   在加载/修复/升阶遮罩期间，直接隐藏 canvas，彻底杜绝“模型与弹层重叠”。 */
.three-canvas {
  opacity: 1;
  transition: opacity 180ms ease, transform 180ms ease;
}
.three-canvas-hidden {
  opacity: 0;
  transform: scale(0.996);
  pointer-events: none;
}
.three-canvas-show {
  opacity: 1;
  transform: scale(1);
}

/* 柴犬专属展示框淡印装饰 */
.shiba-frame-deco {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.shiba-deco-bone {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.09;
  filter: saturate(0.9);
}

.shiba-deco-dog {
  position: absolute;
  font-size: 36rpx;
  opacity: 0.08;
}

.shiba-frame-deco text {
  transform: rotate(-6deg);
}

/* 狐狸详情页展示框淡印（与柴犬框同一布局逻辑） */
.fox-frame-deco {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.fox-deco-leaf {
  position: absolute;
  font-size: 38rpx;
  opacity: 0.09;
  filter: saturate(1.05);
}

.fox-deco-fox {
  position: absolute;
  font-size: 34rpx;
  opacity: 0.085;
}

.fox-frame-deco text {
  transform: rotate(-5deg);
}

/* 鼠标交互层：覆盖在 canvas 上，接收鼠标拖拽/滚轮事件 */
.three-interact-layer{
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  background: rgba(0,0,0,0);
}
.mask { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.35); }
.fail { background: rgba(254, 243, 199, 0.55); }
.mask-txt { font-size: 24rpx; color: #78350f; font-weight: 700; }
.mask-retry {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b45309;
  font-weight: 700;
  text-decoration: underline;
}

/* 3D 模型加载进度遮罩 */
.model-load-mask {
  background: rgba(255, 248, 220, 0.16);
  z-index: 80;
}
.page-lock-layer {
  position: absolute;
  inset: 0;
  z-index: 60;
  background: rgba(255, 255, 255, 0.0);
}
.page-lock-btn {
  position: absolute;
  left: 50%;
  top: 28rpx;
  transform: translateX(-50%);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(245, 158, 11, 0.25);
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(120, 53, 15, 0.95);
}
.model-load-card {
  position: absolute;
  inset: 0;
  width: auto;
  max-width: none;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 36rpx; /* 与 showcase-inner 对齐 */
  background: rgba(255, 255, 255, 0.48);
  border: 2rpx dashed rgba(245, 158, 11, 0.28);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 破壳点击：抖动 + 闪光 */
.hatch-shake {
  animation: hatchShake 0.18s ease-in-out 1;
}
@keyframes hatchShake {
  0% { transform: translateX(0); }
  18% { transform: translateX(-8rpx) rotate(-0.4deg); }
  40% { transform: translateX(7rpx) rotate(0.4deg); }
  62% { transform: translateX(-5rpx) rotate(-0.3deg); }
  100% { transform: translateX(0); }
}

.hatch-flash::after{
  content:"";
  position:absolute;
  inset:-10rpx;
  background: radial-gradient(circle at 50% 45%, rgba(255,255,255,0.75), rgba(255,255,255,0) 60%);
  opacity: 0;
  animation: hatchFlash 0.22s ease-out 1;
  pointer-events:none;
}
@keyframes hatchFlash {
  0%{ opacity: 0; transform: scale(0.96); }
  35%{ opacity: 1; transform: scale(1.02); }
  100%{ opacity: 0; transform: scale(1.06); }
}

.hatch-mini-progress{
  margin-top: 16rpx;
  width: 100%;
}
.hatch-mini-bar{
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(244,194,212,0.10);
  overflow: hidden;
  border: 2rpx solid rgba(251, 191, 36, 0.18);
}
.hatch-mini-fill{
  height: 100%;
  width: 0%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(250,204,21,0.92), rgba(251,146,60,0.78));
  transition: width 0.18s ease;
  box-shadow: 0 0 16rpx rgba(251,146,60,0.22);
}
.hatch-mini-tip{
  display:block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(120,53,15,0.92);
  font-weight: 800;
  text-align: center;
}

.hatch-progress-overlay{
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 76;
  padding: 12rpx 12rpx 10rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.35);
  border: 2rpx solid rgba(251, 191, 36, 0.16);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
.hatch-preload-row{
  margin-top: 10rpx;
  display:flex;
  align-items:center;
  justify-content: space-between;
  gap: 10rpx;
}
.hatch-preload-tip{
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(120,53,15,0.75);
}

.model-load-card::before {
  content: "";
  position: absolute;
  inset: -60rpx -80rpx;
  background: linear-gradient(
    115deg,
    rgba(255, 255, 255, 0) 30%,
    rgba(250, 204, 21, 0.22) 45%,
    rgba(232, 121, 169, 0.18) 55%,
    rgba(255, 255, 255, 0) 70%
  );
  transform: translateX(-40%);
  animation: shimmerSweep 1.6s ease-in-out infinite;
  pointer-events: none;
}

@keyframes shimmerSweep {
  0%, 100% { transform: translateX(-40%) rotate(0deg); opacity: 0.65; }
  50% { transform: translateX(15%) rotate(0deg); opacity: 1; }
}

/* 滴滴魔法：用纯 CSS 水滴动画填充加载空窗 */
.magic-drops {
  position: relative;
  height: 46rpx;
  margin-bottom: 8rpx;
  overflow: visible;
}

/* 可爱闪亮星星：沿圆形轨道旋转，最后汇入“中间锅底” */
.magic-star {
  position: absolute;
  left: 50%;
  /* 炼药锅在 scene 中央附近：magic-drops 作为锚点，需要把中心点向下抬到 scene 内 */
  top: 180rpx;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  line-height: 1;
  font-weight: 900;
  opacity: 0;
  pointer-events: none;
  text-shadow:
    0 0 12rpx rgba(255, 255, 255, 0.65),
    0 0 22rpx rgba(250, 204, 21, 0.45);
  animation: starOrbitToPot 1.65s ease-in-out infinite;
}

.star1 { color: rgba(250, 204, 21, 0.98); animation-delay: -0.05s; }
.star2 { color: rgba(251, 146, 60, 0.96); animation-delay: -0.28s; }
.star3 { color: rgba(250, 204, 21, 0.92); animation-delay: -0.51s; font-size: 26rpx; }
.star4 { color: rgba(59, 130, 246, 0.92); animation-delay: -0.74s; }
.star5 { color: rgba(251, 146, 60, 0.94); animation-delay: -0.97s; font-size: 30rpx; }
.star6 { color: rgba(250, 204, 21, 0.92); animation-delay: -1.20s; }
.star7 { color: rgba(59, 130, 246, 0.88); animation-delay: -1.43s; font-size: 24rpx; }

@keyframes starOrbitToPot {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(0deg) translateX(185rpx) scale(0.6);
  }
  12% {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(70deg) translateX(170rpx) scale(1.06);
  }
  45% {
    opacity: 0.95;
    transform: translate(-50%, -50%) rotate(200deg) translateX(115rpx) scale(1.1);
  }
  72% {
    opacity: 0.9;
    transform: translate(-50%, -50%) rotate(290deg) translateX(48rpx) scale(0.98);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(360deg) translateX(0rpx) scale(0.62);
  }
}
.drop {
  position: absolute;
  top: 2rpx;
  width: 12rpx;
  height: 18rpx;
  border-radius: 8rpx 8rpx 14rpx 14rpx;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.98), rgba(250,204,21,0.95) 18%, rgba(249,115,22,0.9) 55%, rgba(234,88,12,0.85));
  opacity: 0.98;
  box-shadow:
    0 0 18rpx rgba(251,146,60,0.35),
    0 0 8rpx rgba(250,204,21,0.22);
  transform: translateX(0) translateY(0) scale(1);
  animation: dropFloat 1.05s ease-in-out infinite;
}
.drop1 { left: 68rpx; animation-delay: 0s; }
.drop2 { left: 160rpx; animation-delay: 0.14s; }
.drop3 { left: 270rpx; animation-delay: 0.28s; }
.drop4 { left: 340rpx; animation-delay: 0.42s; opacity: 0.85; }
.drop5 { left: 420rpx; animation-delay: 0.56s; opacity: 0.8; height: 16rpx; }
.drop6 { left: 220rpx; animation-delay: 0.7s; opacity: 0.88; height: 20rpx; }
.drop7 { left: 500rpx; animation-delay: 0.84s; opacity: 0.78; height: 14rpx; }

@keyframes dropFloat {
  0% { transform: translateY(3rpx) translateX(0) scale(0.92); opacity: 0.55; filter: blur(0.3rpx); }
  25% { transform: translateY(-12rpx) translateX(6rpx) scale(1.08); opacity: 1; filter: blur(0); }
  55% { transform: translateY(-4rpx) translateX(-4rpx) scale(1.01); opacity: 0.82; }
  80% { transform: translateY(-7rpx) translateX(3rpx) scale(0.98); opacity: 0.9; }
  100% { transform: translateY(3rpx) translateX(0) scale(0.92); opacity: 0.55; filter: blur(0.3rpx); }
}
.model-load-magic-text {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(120, 53, 15, 0.95);
  font-weight: 700;
  animation: magicTextBreath 0.9s ease-in-out infinite;
}

@keyframes magicTextBreath {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.92; }
  50% { transform: translateY(-2rpx) scale(1.03); opacity: 1; }
}

/* 升阶动画遮罩（升级时提示并播放） */
.upgrade-overlay {
  position: absolute;
  inset: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.55);
}
.upgrade-card {
  width: 560rpx;
  max-width: calc(100% - 40rpx);
  padding: 28rpx 18rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(245, 158, 11, 0.35);
  box-shadow: 0 22rpx 66rpx rgba(251, 146, 60, 0.18);
  text-align: center;
  position: relative;
  overflow: hidden;
  min-height: 200rpx;
}
.upgrade-card::after {
  content: "";
  position: absolute;
  left: -60%;
  top: -40%;
  width: 160%;
  height: 140%;
  background: radial-gradient(circle at 50% 50%, rgba(250,204,21,0.25), rgba(244,194,212,0) 60%);
  animation: upgradeGlow 1.1s ease-in-out infinite;
}
@keyframes upgradeGlow {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.04); opacity: 1; }
}
.upgrade-burst {
  height: 118rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

/* ================= 升级新庆祝层：轮廓长大 + 彩带 + 彩纸 ================= */
.upgrade-celebrate-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.upgrade-highlight {
  position: absolute;
  left: 50%;
  top: 44%;
  width: 320rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(ellipse at center, rgba(250,204,21,0.42) 0%, rgba(244,194,212,0.18) 45%, rgba(255,255,255,0) 70%);
  filter: blur(2rpx);
  animation: upgradeHighlightPulse 1.1s ease-in-out infinite;
}

@keyframes upgradeHighlightPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(0.96); opacity: 0.78; }
  50% { transform: translate(-50%, -50%) scale(1.06); opacity: 1; }
}

.upgrade-silhouette {
  position: absolute;
  left: 50%;
  top: 46%;
  width: 160rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  animation: silhouetteGrow 1.1s ease-in-out infinite;
}

.upgrade-silhouette-emoji {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 94rpx;
  font-weight: 900;
  /* 用多重 text-shadow 模拟“轮廓感” */
  color: rgba(244,194,212,0.08);
  text-shadow:
    0 0 0 rgba(244,194,212,0.55),
    0 0 18rpx rgba(244,194,212,0.22),
    0 0 30rpx rgba(250,204,21,0.18);
}

@keyframes silhouetteGrow {
  0% { transform: translate(-50%, -50%) scale(0.35); opacity: 0.2; }
  35% { transform: translate(-50%, -50%) scale(1.08); opacity: 1; }
  65% { transform: translate(-50%, -50%) scale(0.98); opacity: 0.95; }
  100% { transform: translate(-50%, -50%) scale(1.0); opacity: 0.85; }
}

.upgrade-ribbons {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.upgrade-ribbon {
  position: absolute;
  left: 50%;
  top: 46%;
  width: 260rpx;
  height: 22rpx;
  border-radius: 999rpx;
  transform-origin: left center;
  filter: drop-shadow(0 10rpx 18rpx rgba(244,194,212,0.12));
  animation: ribbonSweep 1.1s ease-in-out infinite;
  opacity: 0;
}

.upgrade-ribbon.r1 {
  background: linear-gradient(90deg, rgba(250,204,21,0.85), rgba(244,194,212,0.65));
  top: 34%;
  animation-delay: 0s;
}
.upgrade-ribbon.r2 {
  background: linear-gradient(90deg, rgba(251,207,232,0.78), rgba(253,230,138,0.82));
  top: 46%;
  animation-delay: 0.12s;
}
.upgrade-ribbon.r3 {
  background: linear-gradient(90deg, rgba(253,224,71,0.7), rgba(244,194,212,0.62));
  top: 58%;
  animation-delay: 0.24s;
}

@keyframes ribbonSweep {
  0% { opacity: 0; transform: translateX(-50%) rotate(-18deg) scaleX(0.7); }
  35% { opacity: 1; transform: translateX(-50%) rotate(8deg) scaleX(1); }
  70% { opacity: 0.75; transform: translateX(-50%) rotate(18deg) scaleX(0.92); }
  100% { opacity: 0; transform: translateX(-50%) rotate(26deg) scaleX(0.7); }
}

.upgrade-confetti {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.confetti {
  position: absolute;
  left: 50%;
  top: 38%;
  width: 14rpx;
  height: 14rpx;
  border-radius: 4rpx;
  opacity: 0;
  animation: confettiPop 1.1s ease-in-out infinite;
}

.confetti.f1 { left: 42%; top: 34%; background: rgba(250,204,21,0.95); animation-delay: 0s; }
.confetti.f2 { left: 48%; top: 30%; background: rgba(244,194,212,0.9); animation-delay: 0.08s; }
.confetti.f3 { left: 54%; top: 36%; background: rgba(251,207,232,0.92); animation-delay: 0.16s; }
.confetti.f4 { left: 58%; top: 42%; background: rgba(253,230,138,0.88); animation-delay: 0.24s; }
.confetti.f5 { left: 46%; top: 44%; background: rgba(251,146,60,0.92); animation-delay: 0.32s; }
.confetti.f6 { left: 40%; top: 42%; background: rgba(244,194,212,0.88); animation-delay: 0.40s; }
.confetti.f7 { left: 56%; top: 26%; background: rgba(250,204,21,0.88); animation-delay: 0.48s; }
.confetti.f8 { left: 62%; top: 32%; background: rgba(244,194,212,0.88); animation-delay: 0.56s; }
.confetti.f9 { left: 34%; top: 38%; background: rgba(252,231,243,0.95); animation-delay: 0.64s; }

@keyframes confettiPop {
  0% { opacity: 0; transform: rotate(0deg) scale(0.7); }
  20% { opacity: 1; }
  60% { opacity: 0.95; }
  100% { opacity: 0; transform: translateY(120rpx) rotate(110deg) scale(1); }
}
/* 升级“烟雾飘升”特效：替换掉小黄圈 */
.upgrade-smoke {
  position: absolute;
  left: 50%;
  top: 62%;
  width: 44rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.92), rgba(251,191,36,0.28) 45%, rgba(244,194,212,0.08) 75%, rgba(255,255,255,0));
  filter: blur(1.6rpx);
  opacity: 0;
  transform: translate(-50%, 0) scale(0.85);
  animation: upgradeSmokeRise 1.25s ease-in-out infinite;
  pointer-events: none;
}
.upgrade-smoke.s1 { margin-left: -56rpx; animation-delay: 0s; }
.upgrade-smoke.s2 { margin-left: -18rpx; width: 56rpx; height: 34rpx; animation-delay: 0.14s; }
.upgrade-smoke.s3 { margin-left: 22rpx; width: 48rpx; height: 30rpx; animation-delay: 0.28s; }
.upgrade-smoke.s4 { margin-left: 64rpx; width: 60rpx; height: 36rpx; animation-delay: 0.42s; }
.upgrade-smoke.s5 { margin-left: 10rpx; top: 66%; width: 40rpx; height: 26rpx; animation-delay: 0.56s; }

@keyframes upgradeSmokeRise {
  0% {
    opacity: 0;
    transform: translate(-50%, 16rpx) scale(0.82);
    filter: blur(1.2rpx);
  }
  20% {
    opacity: 0.55;
  }
  55% {
    opacity: 0.95;
    transform: translate(-50%, -18rpx) scale(1.06);
    filter: blur(2.2rpx);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -46rpx) scale(1.18);
    filter: blur(3.2rpx);
  }
}
.upgrade-title {
  z-index: 1;
  position: relative;
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #e879a9;
}
.upgrade-sub {
  z-index: 1;
  position: relative;
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(120, 53, 15, 0.95);
}

/* 场景动画：孵化 / 成长 / 修复（替代进度条） */
.scene {
  margin-top: 6rpx;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 孵化：弹跳蛋蛋 + 闪光 ===== */
.scene-hatch { position: relative; width: 200rpx; height: 150rpx; }
.egg-shell {
  position: absolute;
  left: 50%;
  top: 24rpx;
  width: 120rpx;
  height: 140rpx;
  transform: translateX(-50%);
  border-radius: 60rpx 60rpx 56rpx 56rpx / 78rpx 78rpx 62rpx 62rpx;
  background: radial-gradient(circle at 40% 30%, rgba(255,255,255,0.95), rgba(253,230,138,0.95) 55%, rgba(245,158,11,0.95));
  box-shadow: 0 14rpx 34rpx rgba(251, 146, 60, 0.25);
  animation: hatchBounce 0.95s ease-in-out infinite;
}
.egg-crack {
  position: absolute;
  left: 50%;
  top: 78rpx;
  width: 88rpx;
  height: 6rpx;
  transform: translateX(-50%) rotate(-6deg);
  border-radius: 999rpx;
  background: rgba(120, 53, 15, 0.35);
  animation: crackPulse 0.95s ease-in-out infinite;
}
.spark {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.95), rgba(251,207,232,0.72));
  box-shadow: 0 0 18rpx rgba(244, 194, 212, 0.35);
  opacity: 0.8;
  animation: sparkPop 1.1s ease-in-out infinite;
}
.spark.s1 { left: 20rpx; top: 30rpx; animation-delay: 0s; }
.spark.s2 { right: 18rpx; top: 52rpx; animation-delay: 0.18s; }
.spark.s3 { left: 34rpx; bottom: 18rpx; animation-delay: 0.34s; }

@keyframes hatchBounce {
  0%, 100% { transform: translateX(-50%) translateY(0) rotate(0deg); }
  35% { transform: translateX(-50%) translateY(-10rpx) rotate(-2deg); }
  70% { transform: translateX(-50%) translateY(-2rpx) rotate(2deg); }
}
@keyframes crackPulse {
  0%, 100% { opacity: 0.25; transform: translateX(-50%) rotate(-6deg) scaleX(0.9); }
  50% { opacity: 0.55; transform: translateX(-50%) rotate(-6deg) scaleX(1.05); }
}
@keyframes sparkPop {
  0%, 100% { transform: scale(0.6); opacity: 0.35; }
  45% { transform: scale(1.1); opacity: 0.9; }
  70% { transform: scale(0.9); opacity: 0.7; }
}

/* ===== 成长：小狗头部呼吸 + 星星环绕 ===== */
.scene-grow { position: relative; width: 220rpx; height: 150rpx; }
.pup-head {
  position: absolute;
  left: 50%;
  top: 46rpx;
  width: 110rpx;
  height: 92rpx;
  transform: translateX(-50%);
  border-radius: 60rpx;
  background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.95), rgba(251,191,36,0.9) 55%, rgba(245,158,11,0.9));
  box-shadow: 0 14rpx 38rpx rgba(245, 158, 11, 0.22);
  animation: pupBreath 1.05s ease-in-out infinite;
}
.pup-ear {
  position: absolute;
  top: 36rpx;
  width: 40rpx;
  height: 54rpx;
  border-radius: 26rpx 26rpx 10rpx 10rpx;
  background: rgba(245,158,11,0.85);
  animation: earWiggle 0.9s ease-in-out infinite;
}
.ear-l { left: 62rpx; transform: rotate(-18deg); animation-delay: 0s; }
.ear-r { right: 62rpx; transform: rotate(18deg); animation-delay: 0.12s; }
.star {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: rgba(253,230,138,0.88);
  transform: rotate(45deg);
  border-radius: 4rpx;
  box-shadow: 0 0 16rpx rgba(251,207,232,0.45);
  animation: starOrbit 1.2s linear infinite;
}
.star.st1 { left: 20rpx; top: 38rpx; animation-delay: 0s; }
.star.st2 { right: 18rpx; top: 74rpx; animation-delay: 0.22s; }
.star.st3 { left: 34rpx; bottom: 22rpx; animation-delay: 0.44s; }

@keyframes pupBreath {
  0%, 100% { transform: translateX(-50%) scale(1); }
  45% { transform: translateX(-50%) scale(1.04); }
}
@keyframes earWiggle {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.15); }
}
@keyframes starOrbit {
  0% { transform: rotate(45deg) translateY(0); opacity: 0.55; }
  50% { transform: rotate(45deg) translateY(-10rpx); opacity: 0.95; }
  100% { transform: rotate(45deg) translateY(0); opacity: 0.55; }
}

/* ===== 修复：更大的精致魔法棒 + 烟雾上飘（删除圈圈齿轮） ===== */
.scene-repair { position: relative; width: 260rpx; height: 220rpx; }
.wand {
  position: absolute;
  left: 50%;
  top: 112rpx;
  width: 196rpx;
  height: 14rpx;
  transform: translateX(-50%) rotate(-14deg);
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.88), rgba(251,207,232,0.82) 22%, rgba(253,230,138,0.72) 55%, rgba(244,194,212,0.68));
  box-shadow:
    0 0 26rpx rgba(232, 121, 169, 0.22),
    0 0 46rpx rgba(250, 204, 21, 0.12);
  animation: wandSweep 0.95s ease-in-out infinite;
}
.wand::before{
  content:"";
  position:absolute;
  left:-10rpx;
  top:50%;
  width: 34rpx;
  height: 34rpx;
  transform: translateY(-50%);
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.95), rgba(250,204,21,0.75) 45%, rgba(251,146,60,0.28) 72%, rgba(255,255,255,0));
  box-shadow: 0 0 22rpx rgba(250,204,21,0.25);
}
.wand::after{
  content:"";
  position:absolute;
  right:-14rpx;
  top:50%;
  width: 26rpx;
  height: 26rpx;
  transform: translateY(-50%) rotate(20deg);
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(251, 207, 232, 0.65));
  box-shadow: 0 0 18rpx rgba(251, 207, 232, 0.22);
}

