}


/* ================= 状态存放：四个黄色漂浮球（液体内部） ================= */
.float-balls-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  padding: 0 18rpx 6rpx;
  margin-top: 10rpx;
}

.status-ball-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  flex: 0 0 auto;
}

.status-ball {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(251, 191, 36, 0.45);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65),
    0 14rpx 32rpx rgba(251, 191, 36, 0.10);
  overflow: hidden;
}

/* 微微上下浮动（每个球略微错开节奏） */
.status-ball {
  animation: statusBallFloat 2.4s ease-in-out infinite;
}
.status-ball-food { animation-delay: 0s; }
.status-ball-clean { animation-delay: -0.4s; }
.status-ball-mood { animation-delay: -0.8s; }
.status-ball-sleepy { animation-delay: -1.2s; }

@keyframes statusBallFloat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
  100% { transform: translateY(0); }
}

.status-ball-liquid {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 0%;
  transition: height 0.45s ease;
}

.status-ball-liquid-wave {
  position: absolute;
  left: -10rpx;
  right: -10rpx;
  bottom: 0;
  height: 0%;
  transition: height 0.45s ease;
  border-radius: 999rpx 999rpx 0 0;
  opacity: 0.95;
  background-size: 120% 28rpx;
  animation: statusBallLiquidFlow 1.05s linear infinite;
}

@keyframes statusBallLiquidFlow {
  0% { background-position: 0% 0%; }
  100% { background-position: 0% 28rpx; }
}

.status-ball-gloss {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 26rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  transform: rotate(-12deg);
  box-shadow: 0 0 18rpx rgba(255, 255, 255, 0.18);
  pointer-events: none;
  z-index: 2;
}

.status-ball-emoji {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 38rpx;
  text-shadow: 0 0 18rpx rgba(255, 255, 255, 0.22);
  z-index: 3;
  pointer-events: none;
}

.status-ball-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 42rpx;
  height: 42rpx;
  transform: translate(-50%, -50%);
  z-index: 3;
  pointer-events: none;
}

.status-ball-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(146, 64, 14, 0.95);
  text-align: center;
  white-space: nowrap;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.25);
}

/* 不同球：同形状，不同色阶（黄色系） */
.status-ball-food .status-ball-liquid {
  background: linear-gradient(180deg, rgba(250, 204, 21, 0.75), rgba(251, 146, 60, 0.45));
}
.status-ball-food .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 244, 178, 0.75) 0%,
      rgba(255, 244, 178, 0.75) 12%,
      rgba(250, 204, 21, 0.15) 12%,
      rgba(250, 204, 21, 0.15) 24%
    ),
    linear-gradient(180deg, rgba(250, 204, 21, 0.70), rgba(251, 146, 60, 0.40));
}

.status-ball-clean .status-ball-liquid {
  background: linear-gradient(180deg, rgba(255, 231, 153, 0.75), rgba(250, 204, 21, 0.38));
}
.status-ball-clean .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 252, 220, 0.65) 0%,
      rgba(255, 252, 220, 0.65) 12%,
      rgba(255, 231, 153, 0.18) 12%,
      rgba(255, 231, 153, 0.18) 24%
    ),
    linear-gradient(180deg, rgba(255, 231, 153, 0.72), rgba(250, 204, 21, 0.34));
}

.status-ball-mood .status-ball-liquid {
  background: linear-gradient(180deg, rgba(250, 204, 21, 0.88), rgba(245, 158, 11, 0.42));
}
.status-ball-mood .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 246, 196, 0.72) 0%,
      rgba(255, 246, 196, 0.72) 12%,
      rgba(245, 158, 11, 0.18) 12%,
      rgba(245, 158, 11, 0.18) 24%
    ),
    linear-gradient(180deg, rgba(250, 204, 21, 0.82), rgba(245, 158, 11, 0.38));
}

.status-ball-sleepy .status-ball-liquid {
  background: linear-gradient(180deg, rgba(245, 158, 11, 0.85), rgba(161, 98, 7, 0.36));
}
.status-ball-sleepy .status-ball-liquid-wave {
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 238, 155, 0.60) 0%,
      rgba(255, 238, 155, 0.60) 12%,
      rgba(161, 98, 7, 0.16) 12%,
      rgba(161, 98, 7, 0.16) 24%
    ),
    linear-gradient(180deg, rgba(245, 158, 11, 0.78), rgba(161, 98, 7, 0.34));
}

