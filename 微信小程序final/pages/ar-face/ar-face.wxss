/* ═══════════════════════════════════
   AR 面具演说家 - 整体布局
═══════════════════════════════════ */
page {
  background: #000;
  height: 100vh;
  overflow: hidden;
}

.ar-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* 相机全屏 */
.ar-camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* ─── 权限错误界面 ─── */
.camera-error {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #1e1b4b, #831843);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  z-index: 10;
  padding: 60rpx;
}

.error-icon { font-size: 120rpx; }

.error-title {
  color: white;
  font-size: 40rpx;
  font-weight: 900;
}

.error-desc {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
  text-align: center;
  line-height: 1.7;
}

.error-btn {
  margin-top: 20rpx;
  background: #f0a3c2;
  color: white;
  font-size: 30rpx;
  font-weight: 900;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,92,246,0.5);
}

/* ─── UI 叠加层 ─── */
.overlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}
/* 需要可点击的子区域单独开启指针事件 */
.top-bar,
.question-card,
.face-frame-wrap,
.rec-indicator,
.bottom-panel,
.result-modal {
  pointer-events: auto;
}

/* ─── 顶部导航栏 ─── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 32rpx 24rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.65), transparent);
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.3);
  backdrop-filter: blur(8rpx);
}

.back-img {
  width: 36rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.top-title {
  color: white;
  font-size: 34rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.ar-badge {
  background: linear-gradient(135deg, #e879a9, #e879a9);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 0 16rpx rgba(139,92,246,0.8);
}

.ar-badge-text {
  color: white;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.stars-pill {
  background: rgba(254,243,199,0.2);
  border: 2rpx solid #fde047;
  padding: 8rpx 24rpx;
  border-radius: 48rpx;
  backdrop-filter: blur(8rpx);
}

.stars-pill-text {
  color: #fde047;
  font-size: 26rpx;
  font-weight: 900;
}

/* ─── 题目卡片 ─── */
.question-card {
  margin: 0 32rpx 0;
  background: rgba(139,92,246,0.85);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.4s ease-out;
  pointer-events: none;
}

.question-card.visible {
  opacity: 1;
  transform: translateY(0);
}

.question-label {
  color: #fef3c7;
  font-size: 22rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.question-text {
  color: white;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.5;
}

/* ─── 人脸扫描框 ─── */
.face-frame-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  pointer-events: none;
}

.face-frame {
  position: relative;
  width: 480rpx;
  height: 560rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 四个角的装饰线 */
.corner {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(255,255,255,0.8);
  border-style: solid;
}

.corner.tl { top: 0; left: 0; border-width: 6rpx 0 0 6rpx; border-radius: 12rpx 0 0 0; }
.corner.tr { top: 0; right: 0; border-width: 6rpx 6rpx 0 0; border-radius: 0 12rpx 0 0; }
.corner.bl { bottom: 0; left: 0; border-width: 0 0 6rpx 6rpx; border-radius: 0 0 0 12rpx; }
.corner.br { bottom: 0; right: 0; border-width: 0 6rpx 6rpx 0; border-radius: 0 0 12rpx 0; }

.face-frame.tracked .corner {
  border-color: #fbcfe8;
  animation: cornerPulse 1.5s ease-in-out infinite;
}

@keyframes cornerPulse {
  0%, 100% { border-color: #fbcfe8; }
  50% { border-color: #fde68a; box-shadow: 0 0 12rpx rgba(251,207,232,0.8); }
}

.face-hint {
  color: rgba(255,255,255,0.85);
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
  text-align: center;
}

.face-hint.tracking {
  color: #fbcfe8;
}

/* 面具叠加 */
.mask-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.mask-overlay.show {
  opacity: 1;
}

.mask-img {
  width: 440rpx;
  height: 440rpx;
  transform-origin: center top;
}

@keyframes floatMask {
  0%, 100% { transform: translateY(0) rotate(-2deg); }
  50% { transform: translateY(-16rpx) rotate(2deg); }
}

.mask-img.floatAnim {
  animation: floatMask 2.5s ease-in-out infinite;
}

/* ─── 录音指示器 ─── */
.rec-indicator {
  position: absolute;
  top: 200rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(239,68,68,0.8);
  padding: 12rpx 28rpx;
  border-radius: 48rpx;
  backdrop-filter: blur(8rpx);
  z-index: 10;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  background: white;
  border-radius: 50%;
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.rec-text {
  color: white;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

/* ─── 底部控制面板 ─── */
.bottom-panel {
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 70%, transparent 100%);
  padding: 24rpx 32rpx 48rpx;
}

/* 面具选择区 */
.mask-section {
  margin-bottom: 32rpx;
}

.mask-section-label {
  color: rgba(255,255,255,0.7);
  font-size: 22rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.mask-scroll {
  width: 100%;
  white-space: nowrap;
}

.mask-list {
  display: flex;
  gap: 24rpx;
  padding: 8rpx 0;
}

.mask-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  transition: transform 0.2s;
}

.mask-item:active {
  transform: scale(0.92);
}

.mask-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.1);
  transition: all 0.2s;
}

.mask-thumb-img {
  width: 100%;
  height: 100%;
}

.no-mask {
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-mask-emoji {
  font-size: 56rpx;
}

.mask-item.selected .mask-thumb {
  border-color: #fbcfe8;
  box-shadow: 0 0 0 6rpx rgba(251,207,232,0.5);
  transform: scale(1.1);
}

.mask-item-name {
  color: rgba(255,255,255,0.8);
  font-size: 20rpx;
  font-weight: 700;
}

.mask-item.selected .mask-item-name {
  color: #fde68a;
}

/* 录音区域 */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.record-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-btn-inner {
  width: 144rpx;
  height: 144rpx;
  background: #f0a3c2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid white;
  box-shadow: 0 8rpx 32rpx rgba(139,92,246,0.6);
  transition: all 0.2s;
  z-index: 2;
}

.record-btn.recording .record-btn-inner {
  background: #ef4444;
  box-shadow: 0 8rpx 32rpx rgba(239,68,68,0.6);
  animation: recordPulse 1s ease-in-out infinite;
}

@keyframes recordPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.record-btn-icon {
  font-size: 72rpx;
  line-height: 1;
}

/* 波纹动画 */
.ripple {
  position: absolute;
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(239,68,68,0.6);
  animation: rippleAnim 1.5s ease-out infinite;
}

.ripple.r2 {
  animation-delay: 0.5s;
}

@keyframes rippleAnim {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(2); opacity: 0; }
}

.record-hint {
  color: rgba(255,255,255,0.85);
  font-size: 26rpx;
  font-weight: 700;
}

.finish-btn {
  background: linear-gradient(135deg, #fbcfe8, #e879a9);
  padding: 24rpx 56rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(244,194,212,0.5);
  border: 2rpx solid rgba(255,255,255,0.3);
}

.finish-btn.hidden {
  opacity: 0;
  pointer-events: none;
}

.finish-btn-text {
  color: white;
  font-size: 30rpx;
  font-weight: 900;
}

/* ─── 评分结果弹窗 ─── */
.result-modal {
  position: absolute;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.result-bg {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(12rpx);
}

.result-card {
  position: relative;
  width: 100%;
  background: linear-gradient(160deg, #fdf2f8, #fff);
  border-radius: 48rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 24rpx 64rpx rgba(0,0,0,0.5);
  border: 4rpx solid white;
  animation: cardIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardIn {
  from { transform: scale(0.7) translateY(60rpx); opacity: 0; }
  to { transform: scale(1) translateY(0); opacity: 1; }
}

.result-mascot {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.result-mascot-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #fef3c7;
  box-shadow: 0 8rpx 32rpx rgba(139,92,246,0.3);
}

.result-mascot-emoji {
  font-size: 120rpx;
  line-height: 200rpx;
  text-align: center;
  display: block;
}

/* 结果装饰 sparkle */
.result-sparkle {
  position: absolute;
  font-size: 32rpx;
  animation: sparklePop 1.5s ease-in-out infinite;
}

.result-sparkle.s1 { top: -16rpx; right: -8rpx; animation-delay: 0s; }
.result-sparkle.s2 { bottom: 0; left: -16rpx; animation-delay: 0.5s; }
.result-sparkle.s3 { top: 50%; right: -32rpx; animation-delay: 1s; }

@keyframes sparklePop {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.3) rotate(20deg); opacity: 0.8; }
}

.result-title {
  color: #b87a94;
  font-size: 42rpx;
  font-weight: 900;
}

/* 分数环 */
.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0a3c2, #e879a9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(139,92,246,0.4);
  border: 6rpx solid white;
}

.score-num {
  color: white;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1;
}

.score-unit {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  font-weight: 700;
}

/* 星级 */
.star-rating {
  display: flex;
  gap: 8rpx;
}

.rating-star {
  font-size: 40rpx;
  transition: all 0.3s;
}

.rating-star.dim {
  filter: grayscale(100%);
  opacity: 0.35;
}

.rating-star.lit {
  filter: drop-shadow(0 0 8rpx rgba(251,191,36,0.8));
}

/* 反馈 */
.feedback-box {
  background: #f5f3ff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  border: 2rpx solid #fce7f3;
  width: 100%;
}

.feedback-text {
  color: #b87a94;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.6;
  display: block;
}

.transcript-text {
  margin-top: 12rpx;
  color: #9ca3af;
  font-size: 24rpx;
  display: block;
}

/* 奖励 */
.reward-banner {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  border: 2rpx solid #fde047;
}

.reward-text {
  color: #92400e;
  font-size: 30rpx;
  font-weight: 900;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-again {
  flex: 1;
  background: white;
  border: 4rpx solid #fef3c7;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  transition: all 0.2s;
}

.btn-again text {
  color: #e879a9;
  font-size: 30rpx;
  font-weight: 900;
}

.btn-again:active {
  transform: scale(0.96);
  background: #f5f3ff;
}

.btn-done {
  flex: 1;
  background: linear-gradient(135deg, #f0a3c2, #e879a9);
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(244,194,212,0.4);
  transition: all 0.2s;
}

.btn-done text {
  color: white;
  font-size: 30rpx;
  font-weight: 900;
}

.btn-done:active {
  transform: scale(0.96);
}
